// compiler/front/import.cdb - the self-hosted importer toward root-hash equality
// (ladder rung A, stage 15a.2 — the real expression parser, axis 1).
//
// Reads a source `fn main(<params>) -> <i64|bool> = <expr>` from stdin and prints the
// program ROOT HASH the Rust importer would compute for it (`codedb import` ->
// `root ...`). `<expr>` is a real expression over the full i64 operator set, the
// comparison and logical operators, bool literals, `if`, `let` bindings, and identifier
// references to either a `let` binding or a function parameter — parsed by a scannerless recursive-descent
// parser that builds the TYPED Expression object tree bottom-up: each parse function
// returns the content hash of the Expression object it just built (children referenced
// by hash) AND its inferred TYPE CODE (`tyc`: 0 = i64, 1 = bool), so no explicit AST
// tree is needed and objects are emitted in dependency order. Type inference threads
// up through `Pr.tyc` into each node's `type` field, and the declared return type
// (parsed from the header, `i64` or `bool`) sets the signature's return. For a single
// non-recursive `main` the body's birth is genesis, so there is no migration/history
// chain yet (axis 2, the multi-symbol step) — only the typed objects, gated by
// root-hash equality (tests/selfhost_frontend.rs). The parser does NOT type-check, so
// the oracle only applies to type-valid programs.
//
// Grammar (this increment), in loosest-to-tightest precedence:
//   expr       := bitor
//   bitor      := logor (('|' not '||') logor)*             i64
//   logor      := logand ('||' logand)*                     bool
//   logand     := bitxor ('&&' bitxor)*                     bool
//   bitxor     := bitand ('^' bitand)*                      i64
//   bitand     := equality (('&' not '&&') equality)*       i64
//   equality   := relational (('=='|'!=') relational)*      bool
//   relational := shift (('<'|'>'|'<='|'>=') shift)*        bool
//   shift      := add (('<<'|'>>') add)*                    i64
//   add        := mul (('+'|'-') mul)*                      i64
//   mul        := unary (('*'|'/'|'%') unary)*              i64
//   unary      := ('-'|'~'|'!') unary | atom                i64/bool
//   atom       := <decimal int>                  i64
//               | `true` | `false`               bool
//               | `if` expr `then` expr `else` expr
//               | `let` IDENT `:` TYPE `=` expr `in` expr
//               | IDENT                           (local_ref / param_ref)
// The header is `fn main ( IDENT: TYPE , ... ) -> TYPE =` — the parameters feed the
// signature's `params` (a list of Type hashes) and the root's `param_names`, and an
// in-body reference to one becomes a `param_ref` by its positional index. Binary levels
// are left-associative; `<<`/`>>` are distinguished from lone `<`/`>`, and `&&`/`||`
// from single `&`/`|`. `let`/`if` make the parser mutually recursive (atom <-> the
// binary ladder), so import.cdb imports + compiles as one recursion group. An
// identifier resolves first against the `let` scope — a `local_ref` by de-Bruijn depth
// (innermost binding = 0) — and, failing that, against the parameter table — a
// `param_ref` by index; so a `let` shadows a same-named parameter, the two are separate
// namespaces (a let's depth does not count parameters), and the node is typed by the
// binding/param it names. Both the let scope and the parameter table are Copy `Scope`
// values threaded as input params down the ladder (the let scope is extended only into
// a `let` body). No parens yet, and binding/param types are i64/bool only. No-new-symbol
// builtins and the other object kinds are later increments.
//
// The objects for `fn main(<params>) -> <ret> = E` are, in order: the result Type(s) (i64
// and/or bool); the body Expression tree; the FunctionSignature; the SymbolBirth;
// the FunctionDef; the ProgramRoot. The SHA-256 core, stdin pump, padding, the
// multi-block driver, the hex word emitter, and mem_cap live in
// compiler/front/lib.cdb (imported first). The move-only memory string threads by
// MOVE across helper calls (returned inside a record); within a function it stays
// owned and `string_get` borrows it. Every bounds check is a nested `if p < len`
// because the language's `&&` is strict (it evaluates both operands).

record PBi { p: string  i: i64 }
record OS { out: string  s: string }
record DH { h: string  sig: string  sym: string }
record OB { b: array<u8, 96>  i: i64 }

// A pure inner-scan accumulator (Copy): a cursor and a keep-going flag.
record P2 { p: i64  go: bool }
// A scanner result: the threaded memory and the index it walked to.
record MI { mem: string  i: i64 }
// A parse result (and every binary level's loop accumulator): the threaded memory,
// the content hash of the Expression object built, its TYPE CODE (`tyc`: 0 = i64,
// 1 = bool — the inferred result type, threaded so each node's `type` field and the
// function's return type are correct), and the cursor past it.
record Pr { mem: string  hash: string  tyc: i64  next: i64 }
// A RAW-AST parse result (and every raw binary level's loop accumulator): the threaded
// memory, the raw-AST JSON STRING built for the node (a complete canonical JSON object,
// children embedded inline — NOT a content hash), and the cursor past it. The raw AST is
// type-free (sized/hex literals all serialize as `literal_i64`, refs are by-name), so
// there is no type code; it feeds the migration `operation.body` (the dual serialization).
record Rr { mem: string  raw: string  next: i64 }
// A push-range result: the string being built and the threaded source memory.
record PRR { out: string  mem: string }
// The lexical scope, holding BOTH a function's parameters and its enclosing `let`
// bindings in one Copy array (so it threads as a plain input param — never moved or
// returned). Parameters occupy indices [0, np) and the live `let` bindings [np, n),
// where np is threaded separately. Each entry is encoded as one i64,
// (start * 2000000 + end) * 16 + btyc, where [start,end) is the name's byte range in the
// source and btyc its type code (0 = i64, 1 = bool). A let at index i has de-Bruijn
// depth n-1-i (innermost = 0); a parameter at index i is `param_ref` index i. The array
// is small (12) because the v0 backend gives each aggregate local its full byte size, so
// the functions that juggle several Scope-typed locals must stay under the frame budget;
// 12 combined params+bindings is ample for an axis-1 single function. `rgord` rides along
// (the scope is already threaded everywhere): -1 means "not a recursion-group member" (a
// call resolves to a create_function symbol); >= 0 means this body IS a recursion-group
// member of that ordinal, so a call (a self-call, in a single-member group) resolves to the
// `recursion_group:<rgord>` symbol instead.
// `aord` (only meaningful when rgord >= 0) is the WL canonical ORDINAL of the
// alphabetically-FIRST clique member (see order_clique). parse_call maps a callee's
// alphabetical rank (from clique_rank) to its WL ordinal via aord: rank 0 (the alpha-first
// member) -> aord; rank 1 (the other, for a two-member clique) -> 1 - aord. For a
// single-member group aord = 0 (the sole member is alpha-first with ordinal 0).
record Scope { ids: array<i64, 12>  n: i64  rgord: i64  aord: i64 }
// A header-parse result: the threaded memory, the declared return type code, the
// body's start position (just past `=`), the parameter table, and the function
// name's byte range [ns, ne) in the source (used by axis-2's canonical ordering
// and SymbolBirth local_nonce; ignored on the single-function path).
record HdrR { mem: string  rettyc: i64  bodypos: i64  params: Scope  ns: i64  ne: i64 }
// A param-list-scan result: the threaded memory, the position just past `)`, and the
// accumulated parameter table.
record PpR { mem: string  pos: i64  ps: Scope }
// A name-lookup result: whether the name was found, the matching slot INDEX (the
// caller derives a let's de-Bruijn depth as n-1-idx, or uses idx directly as a param
// index), the binding/param's type code, and the threaded source memory.
record RD { found: bool  idx: i64  btyc: i64  mem: string }
// The resolve loop's accumulator (move-only — it carries the threaded memory): the
// scan index and the best (highest = innermost) matching binding index (-1 = none).
record RScan { i: i64  best: i64  mem: string }
// A range-compare result: whether the two byte ranges are equal, and threaded memory.
record REq { eq: bool  mem: string }
// The byte-compare loop accumulator (Copy): the offset and the still-equal flag.
record CCmp { j: i64  eq: bool }
// A built node carrying the threaded memory and its content hash (the caller assembles
// the surrounding Pr, supplying the type code and cursor).
record MH { mem: string  hash: string }
// A type-name classification result: the type code and the threaded source memory.
record TC { code: i64  mem: string }
// A parsed top-level function's source span (all Copy): the name's byte range [ns, ne),
// the BODY's start byte `bs` in the source (just past `=`), and the declared return type
// code `rtc`. Axis-2 carries two of these (one per function) to drive canonical ordering
// and the migration/history chain; the body itself is RE-PARSED from `bs` on demand (both
// typed — for the Expression hash — and raw — for the migration body), so no literal value
// span is stored (bodies may now be any expression, not just a literal).
record Sl { ns: i64  ne: i64  bs: i64  rtc: i64 }
// A function's three content hashes (SymbolBirth, FunctionDef, FunctionSignature)
// with the threaded source memory — the per-symbol inputs to a ProgramRoot.
record FObj { mem: string  sym: string  def: string  sig: string  pn: string }
// The lexicographic-compare loop accumulator (Copy): the offset `j` and a 3-state code
// `c` (2 = still equal/continue, 0 = A<B, 1 = A>B, 3 = equal at exhaustion).
record Lc { j: i64  c: i64 }
// Carrier between build_mig1's two payload halves (also split for the frame budget): the
// partial buffer, the threaded source memory, the reused name/genesis/out1, the raw-AST
// body JSON (kept across both halves — it appears in the operation AND the
// function_source_matches postcondition), and the function's return type code (for the
// `return_type` name, which appears in both halves too).
record Pc { out: string  mem: string  name: string  gen: string  o1: string  body: string  opparams: string  rtc: i64 }
// build_mig1's second payload half returns the full payload, out1 (kept for the history
// preimage), and the threaded memory.
record MigB { pay: string  o1: string  mem: string }
// Migration context bundling the (already-built) `parent_history_hash` FIELD value (the
// JSON `null` for the genesis migration, or `"<hash>"` for a later one) and the symbol's
// canonical ordinal — passed as one record so mig1_pay_a stays under the 8-machine-param cap.
record MigCtx { field: string  ord: i64 }
// The parent_history_hash field value and the (kept) raw parent history hash — build_mig1
// builds the field once while threading `par` back for the history-hash preimage prefix.
record MigPar { field: string  par: string }
// Carrier between mig1_pay_a's two halves (split for the v0 frame budget once the migration
// became ordinal/parent-parameterized): the partial buffer (up to the operation `"name":"`),
// the threaded memory, the kept function name, the kept input-root hash (for the precondition),
// and the kept raw-AST body (for the function_source_matches postcondition).
record PayMid { buf: string  mem: string  name: string  gen: string  body: string }
// A symbol-hash comparison result, threading both (move-only) operands back out.
record CmpS { le: bool  a: string  b: string }
// Two functions' (SymbolBirth, FunctionDef, FunctionSignature) hashes ordered by symbol
// hash — the ProgramRoot's `symbols`/`param_names` arrays are symbol-hash-ordered (its
// `names` array is display-name-ordered), so the two can disagree and must be sorted apart.
record Six { s0: string  d0: string  g0: string  s1: string  d1: string  g1: string }
// The call-graph scan accumulator for `find_callee_rtc` (move-only — it carries the threaded
// memory): the cursor, whether the previous token was the `fn` keyword (so the next ident is a
// function NAME), whether the named function was found, and its return type code.
record FScan { p: i64  prevfn: bool  found: bool  rtc: i64  mem: string }
// The body-scan accumulator for `body_calls` (move-only): the cursor, a found flag, threaded mem.
record BC { p: i64  found: bool  mem: string }
// The fn-declaration scan accumulator for `clique_rank` (move-only): the cursor, whether the
// previous token was the `fn` keyword, a running count of declared names <= the callee, threaded mem.
record CRScan { p: i64  prevfn: bool  count: i64  mem: string }
// A RecursionGroup object's hash plus the (kept) member def/sig/symbol it references — they
// reappear in the ProgramRoot's symbols/recursion_groups arrays, so they thread back out.
record RGc { hash: string  def: string  sig: string  sym: string }
// A TWO-member RecursionGroup's hash plus the (kept) def/sig/symbol of each member (ordinals 0,1)
// — like RGc but for a mutual-recursion clique; they reappear in the ProgramRoot's symbols array.
record RG2 { rg: string  d0: string  g0: string  s0: string  d1: string  g1: string  s1: string }
// A WL refinement COLOUR as Copy bytes (so it selects branch-free in recolor and threads through
// the raw clique for free): up to 72 bytes (a "sha256:"+64hex hash is 71; the empty round-1 colour
// is n = 0). Indexed [0, n) when emitted into the recoloured body.
record Color { b: array<u8, 72>  n: i64 }
// recolor's result: the recoloured (erased) body string, with the member-0 name threaded back
// (recolor borrows it for call-name matching but does not consume it).
record RErase { erased: string  name0: string }
// member_color's result: a member's WL colour (a hash string) with mem + name0 threaded back.
record MCol { mem: string  name0: string  color: string }
// order_clique's result: the threaded memory and whether f0 (the FIRST source function) is the
// clique's WL ordinal 0, plus aord (the alpha-first member's WL ordinal — threaded into the body parse).
record OClq { mem: string  f0first: bool  aord: i64 }
// a 71-char string-equality result with both operands threaded back (for comparing WL colour hashes).
record Eq2 { a: string  b: string  eq: bool }
// to_color's byte-copy accumulator (Copy: the colour bytes and the cursor).
record CB { b: array<u8, 72>  k: i64 }
// A parsed call argument list: the args JSON fragment (`"h1","h2"` — quoted typed-Expression
// hashes, comma-separated; empty for no args), the source position past the matching `)`, and
// the threaded memory.
record ArgsR { mem: string  frag: string  next: i64 }
// A pair of (move-only) param-name fragments routed through one conditional (order_pp) — so
// two fragments can be swapped into symbol-hash order without double-moving either.
record PP { p0: string  p1: string }
// The two display-ordered member name source ranges (low/high), bundled so the two-member
// recursion-group root assembler stays under the v0 8-machine-parameter cap.
record NR { lns: i64  lne: i64  hns: i64  hne: i64 }
// ---- Inc 2: three-member discretizing recursion clique (generalizes the two-member WL) ----
// A member NAME packed into Copy bytes (a function name; <= 23 bytes), so the three clique
// names select branch-free in the recolour and ride as one Copy bundle (Names3) with no
// move-only threading. Smaller than Color (names are short; colours are 71-byte hashes).
record Name { b: array<u8, 24>  n: i64 }
// fill_name's byte-copy accumulator (Copy).
record NB { b: array<u8, 24>  k: i64 }
// The three clique member names (source order), Copy — built once, fixed across WL rounds.
record Names3 { n0: Name  n1: Name  n2: Name }
// The three members' current WL COLOURS (source order), Copy — recomputed each round and
// read by the recolour to rewrite a peer call to `@recursion-peer:<that member's colour>`.
record Cols3 { c0: Color  c1: Color  c2: Color }
// match_name's result: whether a call-name range equals a packed Name, with raw threaded back
// (raw is a move-only string read by string_get, so it must be returned to the recolour walk).
record MatchR { hit: bool  raw: string }
// member_color3's result: one member's WL colour as Copy bytes, with mem threaded back.
record MC3 { mem: string  col: Color }
// three_colours's result: the three members' WL colours (source order) for one round + mem.
record ThreeC { mem: string  q0: Color  q1: Color  q2: Color }
// clique3_order's result: whether 1-WL discretizes the clique (all three colours distinct);
// if so, s0/s1/s2 are the SOURCE indices of WL ordinals 0/1/2, and `aord` packs the
// alpha-rank -> ordinal permutation (base 4: ord-of-alpha0 + ord-of-alpha1*4 + ord-of-alpha2*16),
// the generalization of the two-member `aord`. mem threaded back. disc = false -> defer (Inc 4).
record Clq3 { mem: string  disc: bool  s0: i64  s1: i64  s2: i64  aord: i64 }
// build_recursion_group3's result: the RecursionGroup object hash plus the three concatenated
// 71-char accumulators (defs/sigs/syms, ordinal order) threaded back for the ProgramRoot's arrays.
record RG3 { rg: string  defs: string  sigs: string  syms: string }
// clique3_colours's result: the three converged WL colours (source order), whether they
// discretize the clique (all distinct), and mem threaded back. (Split from the ordinal/aord
// derivation so each holds at most a few Colour/ThreeC locals within the v0 frame budget.)
record ColRes { mem: string  disc: bool  q0: Color  q1: Color  q2: Color }
// One WL round's result: the three colours as a Copy Cols3 + their distinct count + mem. Returned
// by wl_round so the move-only ThreeC stays in ITS frame (clique3_colours holds only Cols3s).
record RoundR { mem: string  cols: Cols3  nc: i64 }
// The three clique member names (Copy) + mem threaded back — build_names3's result, so the
// name-building temporaries (slice_to_str/to_name) stay off clique3_colours's frame.
record NamesR { mem: string  names: Names3 }
// wl_two's result: the round-2 colours (Cols3) + their distinct count + whether a third round is
// needed (the count grew from round 1) + mem. Keeps rounds 1 and 2 in wl_two's frame.
record TwoR { mem: string  cols: Cols3  nc: i64  need3: bool }
// build_clique3_members's result: the three members' concatenated ordinal-order hashes, the
// param-name offset table, and the RecursionGroup hash — so build_clique3_root keeps only this
// (not the three FObj + concat temporaries) on its frame.
record Clq3M { mem: string  syms: string  defs: string  sigs: string  pns: string  rg: string  pnoff: array<i64, 9> }

// ===========================================================================
// General-m ProgramRoot assembler (Inc 1: the n-function create_function path).
// The arrays sort independently of canonical order — `names` by DISPLAY name, and
// `param_names`/`symbols` by SYMBOL HASH (src/model.rs normalize_root) — so the
// assembler is canonical-order-agnostic: it takes the m functions' 71-char hashes
// concatenated (syms/defs/sigs) plus the source `mem` + packed name/param spans, and
// emits each array in its own sorted order. The two selection sorts use COPY
// accumulators (a permutation array + a `used` bitmask), so there is no move-only loop
// accumulator; the emitters read the owned source/hash buffers with `string_get`
// (never moving them — the lex.cdb borrow discipline) and thread them back out.
// ===========================================================================
// A selection-sort permutation result threading the (move-only) hash buffer back.
record PermS { perm: array<i64, 8>  s: string }
// A selection-sort permutation result threading the (move-only) source memory back.
record PermM { perm: array<i64, 8>  mem: string }
// The selection sort's outer accumulator (Copy): the permutation so far, a `used`
// bitmask (bit i set once index i has been placed), and the output position.
record SortA { perm: array<i64, 8>  used: i64  p: i64 }
// The selection sort's inner min-scan accumulator (Copy): the best index so far and cursor.
record BestA { best: i64  i: i64 }
// disp_perm's outer / inner accumulators thread the move-only `mem` (its compare reuses
// name_le, which consumes and returns mem), so both loops carry it (the resolve-loop pattern).
record DOut { perm: array<i64, 8>  used: i64  p: i64  mem: string }
record DMin { best: i64  i: i64  mem: string }
// toposortN's result: the canonical (Kahn toposort) permutation (perm[k] = the source index
// placed at canonical position k), the threaded memory, and `ok` (false if the call graph has a
// cycle — a clique or any SCC, which is a recursion group, deferred to a later increment).
record Topo3 { perm: array<i64, 8>  mem: string  ok: bool }
// adjN's result: the n×n call-adjacency bitmask (bit i*n+j set iff function i calls function j,
// self-calls included) plus the threaded memory.
record Adj { mask: i64  mem: string }
// adjN's loop accumulator (move-only — body_calls consumes/returns mem): the mask so far, the
// flat (i,j) cursor k in [0, n*n), and the memory.
record AdjAcc { mask: i64  k: i64  mem: string }
// kahnN's outer accumulator (move-only — name_le carries mem): the permutation so far, a `done`
// bitmask (bit i set once source function i has been emitted), the output position, and memory.
record KOut { perm: array<i64, 8>  done: i64  p: i64  mem: string }
// kahnN's inner min-scan accumulator (Copy + threaded mem): the best ready index so far and cursor.
record KMin { best: i64  i: i64  mem: string }
// emit_names threads the buffer plus the (owned, borrowed) source mem and symbol hashes back.
record EmitN { buf: string  mem: string  syms: string }
// emit_pnames threads the buffer plus the symbol hashes and concatenated param-name fragments.
record EmitP { buf: string  syms: string  pns: string }
// emit_symbols threads the buffer plus the symbol/definition/signature hashes.
record EmitS { buf: string  syms: string  defs: string  sigs: string }
// assemble_root's inputs bundled (under the 8-param cap): the source memory and the m
// functions' concatenated 71-char symbol/definition/signature hashes + concatenated
// param-name fragments (sliced by `pnoff`), all in canonical order.
record RootStr { mem: string  syms: string  defs: string  sigs: string  pns: string }
// assemble_root's result: the ProgramRoot hash plus every move-only buffer threaded back
// (so the caller's chain can keep accumulating across the m = 1, 2, 3 intermediate roots).
record AsmOut { hash: string  mem: string  syms: string  defs: string  sigs: string  pns: string }
// parse_all's result: the threaded memory, the packed per-function spans (ns, ne, bs, rtc for
// function k at [4k, 4k+4)), and the function count.
record Prog { mem: string  spans: array<i64, 32>  n: i64 }
// parse_all's loop accumulator (move-only — carries the threaded memory): memory, the spans
// built so far, the count, and the scan cursor.
record PAcc { mem: string  spans: array<i64, 32>  n: i64  pos: i64 }
// One parsed top-level function (factored out of parse_all's loop so the HdrR/Pr locals live
// in parse_one's frame, not the loop's): threaded memory, the name range, body start, return
// type, and the position past the body (the next function or EOF).
record POne { mem: string  ns: i64  ne: i64  bs: i64  rtc: i64  next: i64 }
// reorder_spans' loop accumulator (Copy): the canonically-ordered spans built so far + cursor.
record RA { arr: array<i64, 32>  k: i64 }
// The n-function chain state threaded across steps: the (plain) source memory, the running
// history hash (the next symbol's birth, and a migration's parent), the running output root (the
// next migration's input), the concatenated symbol/def/sig hashes + param-name fragments
// accumulated so far (canonical order), and the cumulative param-name offset table (pnoff[k] =
// start of function k's fragment in `pns`).
record ChainAcc { mem: string  prevhist: string  prevroot: string  syms: string  defs: string  sigs: string  pns: string  pnoff: array<i64, 9> }
// build_augN's result: the source COPY with the extra-callee table appended (sym entries for
// canonical ordinals 1..k-1), the plain source threaded back (for build_mig1's raw serialization),
// the threaded symbol accumulator, and the SOURCE length (the parse bound for build_fn_objs_xc).
record Aug2 { aug: string  src: string  syms: string  slen: i64 }
// append_entries' accumulator: the table buffer plus the threaded (borrowed) source + symbols.
record EntAcc { buf: string  src: string  syms: string }
// xc_scan's result/accumulator: whether a table entry's name matched the call, the matched
// symbol's offset, the scan cursor, and the threaded memory.
record XC { hit: bool  off: i64  pos: i64  mem: string }

// ---------------------------------------------------------------------------
// byte classifiers (ASCII; + - * / and whitespace)
// ---------------------------------------------------------------------------

fn is_ws_b(b: i64) -> bool = b == 32 || b == 9 || b == 10 || b == 13
fn is_digit_b(b: i64) -> bool = b >= 48 && b <= 57
// A hex digit: 0-9, a-f, or A-F (for `0x...` integer literals).
fn is_hexdigit_b(b: i64) -> bool = (b >= 48 && b <= 57) || (b >= 97 && b <= 102) || (b >= 65 && b <= 70)
fn is_ident_b(b: i64) -> bool = (b >= 97 && b <= 122) || (b >= 65 && b <= 90) || (b >= 48 && b <= 57) || b == 95
fn is_unary_op(b: i64) -> bool = b == 45 || b == 126 || b == 33
fn is_mulop(b: i64) -> bool = b == 42 || b == 47 || b == 37
fn is_addop(b: i64) -> bool = b == 43 || b == 45
// Two-char `<<` / `>>`.
fn is_shift_op(b1: i64, b2: i64) -> bool = (b1 == 60 && b2 == 60) || (b1 == 62 && b2 == 62)
// Single-char bitwise (a doubled `&&`/`||` is logical — bool, a later increment).
fn is_and_op(b1: i64, b2: i64) -> bool = b1 == 38 && b2 != 38
fn is_xor_op(b: i64) -> bool = b == 94
fn is_or_op(b1: i64, b2: i64) -> bool = b1 == 124 && b2 != 124
// Equality `==` / `!=` (both are two-char, ending in `=`).
fn is_eq_start(b1: i64, b2: i64) -> bool = (b1 == 61 || b1 == 33) && b2 == 61
// Relational `<` `>` `<=` `>=` — a `<`/`>` NOT doubled (a doubled one is shift,
// which binds tighter and is consumed first); `<=`/`>=` when followed by `=`.
fn is_rel_start(b1: i64, b2: i64) -> bool = (b1 == 60 && b2 != 60) || (b1 == 62 && b2 != 62)
// Logical `&&` / `||` (doubled; the single `&`/`|` is bitwise, tighter).
fn is_logand(b1: i64, b2: i64) -> bool = b1 == 38 && b2 == 38
fn is_logor(b1: i64, b2: i64) -> bool = b1 == 124 && b2 == 124

// ---------------------------------------------------------------------------
// canonical-string building
// ---------------------------------------------------------------------------

// Append a static byte slice to `out`.
fn push_lit(out: string, s: slice<'static, u8>) -> string effects[state] =
  let n: i64 = len(s) in
  let seed: PBi = { p: out, i: 0 } in
  let done: PBi =
    loop a = seed while a.i < n do
      let cur: PBi = a in
      let pp: string = cur.p in
      let pushed: unit = string_push(pp, s[cur.i]) in
      let r: PBi = { p: pp, i: cur.i + 1 } in r
  in done.p

fn push_byte(out: string, b: u8) -> string effects[state] =
  let pushed: unit = string_push(out, b) in
  out

// Append the decimal digits of a non-negative integer `n` to `out`, most-significant
// digit first (recursive: thread the move-only buffer through the higher-digit call,
// then push the last digit). Used for the bare-integer `depth` of a local_ref.
fn push_dec(out: string, n: i64) -> string effects[state] =
  if n < 10 then push_byte(out, to_u8(48 + n))
  else
    let hi: string = push_dec(out, n / 10) in
    push_byte(hi, to_u8(48 + n % 10))

// Append `s` to `out`, CONSUMING s (for a value used exactly once).
fn push_str(out: string, s: string) -> string effects[state] =
  let n: i64 = string_len(s) in
  let seed: PBi = { p: out, i: 0 } in
  let done: PBi =
    loop a = seed while a.i < n do
      let cur: PBi = a in
      let pp: string = cur.p in
      let pushed: unit = string_push(pp, string_get(s, cur.i)) in
      let r: PBi = { p: pp, i: cur.i + 1 } in r
  in done.p

// Append `s` to `out`, THREADING s back (for a hash reused across objects).
fn push_kept(out: string, s: string) -> OS effects[state] =
  let n: i64 = string_len(s) in
  let seed: PBi = { p: out, i: 0 } in
  let done: PBi =
    loop a = seed while a.i < n do
      let cur: PBi = a in
      let pp: string = cur.p in
      let pushed: unit = string_push(pp, string_get(s, cur.i)) in
      let r: PBi = { p: pp, i: cur.i + 1 } in r
  in
  let res: OS = { out: done.p, s: s } in res

// Append `mem`[start, end) to `out`, threading both move-only buffers back.
fn push_range(out: string, mem: string, start: i64, endd: i64) -> PRR effects[state] =
  let done: PBi =
    loop a = { p: out, i: start } while a.i < endd do
      let cur: PBi = a in
      let oo: string = cur.p in
      let pushed: unit = string_push(oo, string_get(mem, cur.i)) in
      let r: PBi = { p: oo, i: cur.i + 1 } in r
  in
  let res: PRR = { out: done.p, mem: mem } in res

// Render the 8-word state as "sha256:" + 64 lowercase hex chars (a string).
fn state_to_hash(st: State) -> string effects[alloc, state] =
  let h0: string = push_lit(string_with_capacity(80), b"sha256:") in
  let h1: string = push_word_hex(h0, st.a) in
  let h2: string = push_word_hex(h1, st.b) in
  let h3: string = push_word_hex(h2, st.c) in
  let h4: string = push_word_hex(h3, st.d) in
  let h5: string = push_word_hex(h4, st.e) in
  let h6: string = push_word_hex(h5, st.f) in
  let h7: string = push_word_hex(h6, st.g) in
  let h8: string = push_word_hex(h7, st.h) in
  h8

// hash_object_canonical: "sha256:" + hex(SHA-256(OBJECT_DOMAIN || kind || \0 ||
// schema || \0 || payload)). schema is a single decimal digit (always 1 here).
// `payload` is consumed.
fn hash_object(kind: slice<'static, u8>, schema: i64, payload: string) -> string effects[alloc, state] =
  // Preimage buffer sized for the largest object in scope: an n-function ProgramRoot grows with n
  // (a 4-symbol root's payload is ~2030 bytes + framing, already past the former 2048), and the
  // create_function chain is capped at eight functions (the packed spans), whose root is ~4-5 KB.
  // 8192 covers that worst case. (Sizing from string_len(payload) instead miscompiles in the v0
  // backend: borrowing the move-only `payload` before push_str moves it traps at runtime.)
  let p0: string = string_with_capacity(8192) in
  let p1: string = push_lit(p0, b"codedb/object/v1\0") in
  let p2: string = push_lit(p1, kind) in
  let p3: string = push_byte(p2, to_u8(0)) in
  let p4: string = push_byte(p3, to_u8(48 + schema)) in
  let p5: string = push_byte(p4, to_u8(0)) in
  let p6: string = push_str(p5, payload) in
  let msglen: i64 = string_len(p6) in
  let padded: string = pad(p6, msglen) in
  let nblocks: i64 = string_len(padded) / 64 in
  let st: State = hash_blocks(padded, nblocks) in
  state_to_hash(st)

// hash_bytes: "sha256:" + hex(SHA-256(domain || payload)). Unlike hash_object there is
// no kind/schema framing — this is the raw domain-separated hash used for migration and
// history records (MIGRATION_DOMAIN/HISTORY_DOMAIN, which already include a trailing \0).
// `payload` is consumed.
fn hash_domain(domain: slice<'static, u8>, payload: string) -> string effects[alloc, state] =
  // Migration/history record preimage; 8192 covers the largest (an operation embeds the raw body
  // twice). A fixed size, not string_len(payload) (the borrow-before-move miscompiles — see
  // hash_object).
  let p0: string = string_with_capacity(8192) in
  let p1: string = push_lit(p0, domain) in
  let p2: string = push_str(p1, payload) in
  let msglen: i64 = string_len(p2) in
  let padded: string = pad(p2, msglen) in
  let nblocks: i64 = string_len(padded) / 64 in
  let st: State = hash_blocks(padded, nblocks) in
  state_to_hash(st)

// ---------------------------------------------------------------------------
// the scanners (memory threaded back; string_get borrows the owned `mem`)
// ---------------------------------------------------------------------------

// Advance past whitespace from `pos`; return the next significant index.
fn skip_ws(mem: string, pos: i64, len: i64) -> MI =
  let done: P2 =
    loop a = { p: pos, go: true } while a.go do
      if a.p >= len then (let s: P2 = { p: a.p, go: false } in s)
      else if is_ws_b(to_i64(string_get(mem, a.p))) then (let s: P2 = { p: a.p + 1, go: true } in s)
      else (let s: P2 = { p: a.p, go: false } in s)
  in
  let res: MI = { mem: mem, i: done.p } in res

// Advance over decimal digits from `start`; return the first non-digit index.
fn scan_digits(mem: string, start: i64, len: i64) -> MI =
  let done: P2 =
    loop a = { p: start, go: true } while a.go do
      if a.p >= len then (let s: P2 = { p: a.p, go: false } in s)
      else if is_digit_b(to_i64(string_get(mem, a.p))) then (let s: P2 = { p: a.p + 1, go: true } in s)
      else (let s: P2 = { p: a.p, go: false } in s)
  in
  let res: MI = { mem: mem, i: done.p } in res

// Advance over hex digits from `start`; return the first non-hex-digit index.
fn scan_hex(mem: string, start: i64, len: i64) -> MI =
  let done: P2 =
    loop a = { p: start, go: true } while a.go do
      if a.p >= len then (let s: P2 = { p: a.p, go: false } in s)
      else if is_hexdigit_b(to_i64(string_get(mem, a.p))) then (let s: P2 = { p: a.p + 1, go: true } in s)
      else (let s: P2 = { p: a.p, go: false } in s)
  in
  let res: MI = { mem: mem, i: done.p } in res

// Advance over identifier bytes from `start`; return the first non-ident index.
fn scan_ident(mem: string, start: i64, len: i64) -> MI =
  let done: P2 =
    loop a = { p: start, go: true } while a.go do
      if a.p >= len then (let s: P2 = { p: a.p, go: false } in s)
      else if is_ident_b(to_i64(string_get(mem, a.p))) then (let s: P2 = { p: a.p + 1, go: true } in s)
      else (let s: P2 = { p: a.p, go: false } in s)
  in
  let res: MI = { mem: mem, i: done.p } in res

// Scan forward from `start` for the first byte == `target`; return the index JUST PAST it
// (or `len` if absent), with `mem` threaded back. Factored out of parse_header so its
// loop's intermediate values do not inflate parse_header's stack frame past the v0 budget.
fn find_byte(mem: string, start: i64, len: i64, target: i64) -> MI =
  let done: P2 =
    loop a = { p: start, go: true } while a.go do
      if a.p >= len then (let s: P2 = { p: a.p, go: false } in s)
      else if to_i64(string_get(mem, a.p)) == target then (let s: P2 = { p: a.p + 1, go: false } in s)
      else (let s: P2 = { p: a.p + 1, go: true } in s)
  in
  let res: MI = { mem: mem, i: done.p } in res

// Scan forward from `start` for the `->` token (bytes 45, 62); return the index just past
// it. Same frame-budget rationale as find_byte (two-byte variant).
fn skip_to_arrow(mem: string, start: i64, len: i64) -> MI =
  let done: P2 =
    loop a = { p: start, go: true } while a.go do
      if a.p + 1 >= len then (let s: P2 = { p: a.p, go: false } in s)
      else if to_i64(string_get(mem, a.p)) == 45 && to_i64(string_get(mem, a.p + 1)) == 62 then (let s: P2 = { p: a.p + 2, go: false } in s)
      else (let s: P2 = { p: a.p + 1, go: true } in s)
  in
  let res: MI = { mem: mem, i: done.p } in res

// Parse a `fn <name>(<params>) -> <rettype> =` header beginning at `start`: skip the
// `fn` keyword and read the name into [ns, ne), find `(`, scan the parameter list into
// a positional table, then find `->`, read the return-type identifier (sized/bool/i64),
// and find the separating `=`. Returns the threaded memory, the return type code, the
// body's start (past `=`), the parameter table, and the name range. A multi-function
// program calls this once per function, passing the previous body's end as `start`.
fn parse_header(mem: string, start: i64, len: i64) -> HdrR =
  // skip whitespace, the two-byte `fn` keyword, and the gap before the name
  let sw0: MI = skip_ws(mem, start, len) in
  let m_a: string = sw0.mem in
  let sw1: MI = skip_ws(m_a, sw0.i + 2, len) in
  let m_b: string = sw1.mem in
  let ns: i64 = sw1.i in
  let nm: MI = scan_ident(m_b, ns, len) in
  let m_c: string = nm.mem in
  let ne: i64 = nm.i in
  // find the opening `(` (byte 40) of the parameter list, starting past the name
  let op: MI = find_byte(m_c, ne, len, 40) in
  let m_d: string = op.mem in
  let emptyp: Scope = { ids: [0x0; 12], n: 0, rgord: 0 - 1, aord: 0 } in
  let pr: PpR = scan_params(m_d, op.i, len, emptyp) in
  let m0: string = pr.mem in
  let params: Scope = pr.ps in
  // find `->` just past the `)`, then read the return-type identifier
  let arrow: MI = skip_to_arrow(m0, pr.pos, len) in
  let m_e: string = arrow.mem in
  let sw: MI = skip_ws(m_e, arrow.i, len) in
  let m1: string = sw.mem in
  let ts: i64 = sw.i in
  let te_r: MI = scan_ident(m1, ts, len) in
  let m2: string = te_r.mem in
  let te: i64 = te_r.i in
  // the return type identifier [ts, te) -> type code (i64/bool/sized).
  let rc: TC = type_code_of(m2, ts, te) in
  let rettyc: i64 = rc.code in
  let m3: string = rc.mem in
  // find the separating `=`
  let eqr: MI = find_byte(m3, te, len, 61) in
  let m4: string = eqr.mem in
  let res: HdrR = { mem: m4, rettyc: rettyc, bodypos: eqr.i, params: params, ns: ns, ne: ne } in res

// ---------------------------------------------------------------------------
// lexical scope: push a `let` binding; resolve an identifier to its de-Bruijn depth
// ---------------------------------------------------------------------------

// Push a `let` binding (name `mem`[start,end), declared type code `btyc`) onto `scope`.
fn push_scope(scope: Scope, start: i64, endd: i64, btyc: i64) -> Scope =
  let code: i64 = (start * 2000000 + endd) * 16 + btyc in
  let r: Scope = { ids: array_set(scope.ids, scope.n, code), n: scope.n + 1, rgord: scope.rgord, aord: scope.aord } in r

// Compare `mem`[a, a+tlen) to `mem`[b, b+tlen) byte by byte; thread `mem` back (a
// helper taking `mem` by value drops it, and string_get rejects `&string`, so the
// move-only buffer is returned rather than borrowed). The loop stops at the first
// mismatch — the condition is a nested `if` because `&&` is strict.
fn range_eq(mem: string, a: i64, b: i64, tlen: i64) -> REq =
  let done: CCmp =
    loop c = { j: 0, eq: true } while (if c.j < tlen then c.eq else false) do
      let cc: CCmp = c in
      let lb: i64 = to_i64(string_get(mem, a + cc.j)) in
      let rb: i64 = to_i64(string_get(mem, b + cc.j)) in
      let r: CCmp = { j: cc.j + 1, eq: if lb == rb then true else false } in r
  in
  let res: REq = { eq: done.eq, mem: mem } in res

// Lexicographically compare two names mem[as_, ae) and mem[bs, be); return eq = true iff
// name A <= name B (the canonical-ordering predicate for axis-2's two functions). Bytes
// are compared one at a time; a name that is a prefix of (or equal to) the other is the
// smaller-or-equal one. `string_get` borrows `mem` inside the loop (as in range_eq); the
// owned `mem` is threaded back out.
fn name_le(mem: string, as_: i64, ae: i64, bs: i64, be: i64) -> REq =
  let done: Lc =
    loop a = { j: 0, c: 2 } while a.c == 2 do
      if a.j >= ae - as_ && a.j >= be - bs then (let s: Lc = { j: a.j, c: 3 } in s)
      else if a.j >= ae - as_ then (let s: Lc = { j: a.j, c: 0 } in s)
      else if a.j >= be - bs then (let s: Lc = { j: a.j, c: 1 } in s)
      else
        let ca: i64 = to_i64(string_get(mem, as_ + a.j)) in
        let cb: i64 = to_i64(string_get(mem, bs + a.j)) in
        if ca < cb then (let s: Lc = { j: a.j, c: 0 } in s)
        else if ca > cb then (let s: Lc = { j: a.j, c: 1 } in s)
        else (let s: Lc = { j: a.j + 1, c: 2 } in s)
  in
  let le: bool = done.c != 1 in
  let res: REq = { eq: le, mem: mem } in res

// Scan the whole source for the top-level `fn <name>` declaration whose name equals
// `mem`[callns, callne) and return its return-type code (the type of a call to it). Used
// by parse_call to type a cross-symbol call: it self-resolves from the source rather than
// threading a symbol table through the parser. The scan walks identifiers, tracking whether
// the previous one was the `fn` keyword (102,110) so the next identifier is a function name;
// a call SITE (`name(`) is never preceded by `fn`, so only declarations match. The move-only
// `mem` is carried in the accumulator (range_eq/skip_to_arrow consume + return it). If the
// name is not found (an invalid program — out of the oracle's domain) the code is 0 (i64).
fn find_callee_rtc(mem: string, callns: i64, callne: i64, len: i64) -> TC =
  let tlen: i64 = callne - callns in
  let done: FScan =
    loop a = { p: 0, prevfn: false, found: false, rtc: 0, mem: mem } while (if a.found then false else a.p < len) do
      let cur: FScan = a in
      let sw: MI = skip_ws(cur.mem, cur.p, len) in
      let m1: string = sw.mem in
      let p1: i64 = sw.i in
      if p1 >= len then (let s: FScan = { p: len, prevfn: false, found: false, rtc: 0, mem: m1 } in s)
      else
        let idr: MI = scan_ident(m1, p1, len) in
        let m2: string = idr.mem in
        let ie: i64 = idr.i in
        if ie > p1 then
          let isfn: bool = if ie - p1 == 2 then (to_i64(string_get(m2, p1)) == 102 && to_i64(string_get(m2, p1 + 1)) == 110) else false in
          if isfn then (let s: FScan = { p: ie, prevfn: true, found: false, rtc: 0, mem: m2 } in s)
          else if cur.prevfn then
            let er: REq = if ie - p1 == tlen then range_eq(m2, p1, callns, tlen) else (let rr: REq = { eq: false, mem: m2 } in rr) in
            let m3: string = er.mem in
            if er.eq then
              let arrow: MI = skip_to_arrow(m3, ie, len) in
              let sw2: MI = skip_ws(arrow.mem, arrow.i, len) in
              let tr: MI = scan_ident(sw2.mem, sw2.i, len) in
              let tc: TC = type_code_of(tr.mem, sw2.i, tr.i) in
              (let s: FScan = { p: ie, prevfn: false, found: true, rtc: tc.code, mem: tc.mem } in s)
            else (let s: FScan = { p: ie, prevfn: false, found: false, rtc: 0, mem: m3 } in s)
          else (let s: FScan = { p: ie, prevfn: false, found: false, rtc: 0, mem: m2 } in s)
        else (let s: FScan = { p: p1 + 1, prevfn: false, found: false, rtc: 0, mem: m2 } in s)
  in
  let res: TC = { code: done.rtc, mem: done.mem } in res

// Does the body span `mem`[bs, be) contain a call `<name>(` where name == `mem`[ns,ne)?
// The call-graph edge for axis-2's canonical ordering (a callee is created BEFORE its
// caller). Matches the parser's call detection exactly: an identifier equal to the name and
// IMMEDIATELY followed by `(` (no whitespace), so a bare reference does not count. Bounded by
// `be` so a function's body never sees the next function's header. Threads `mem` back.
fn body_calls(mem: string, bs: i64, be: i64, ns: i64, ne: i64) -> REq =
  let tlen: i64 = ne - ns in
  let done: BC =
    loop a = { p: bs, found: false, mem: mem } while (if a.found then false else a.p < be) do
      let cur: BC = a in
      let sw: MI = skip_ws(cur.mem, cur.p, be) in
      let m1: string = sw.mem in
      let p1: i64 = sw.i in
      if p1 >= be then (let s: BC = { p: be, found: false, mem: m1 } in s)
      else
        let idr: MI = scan_ident(m1, p1, be) in
        let m2: string = idr.mem in
        let ie: i64 = idr.i in
        if ie > p1 then
          let er: REq = if ie - p1 == tlen then range_eq(m2, p1, ns, tlen) else (let rr: REq = { eq: false, mem: m2 } in rr) in
          let m3: string = er.mem in
          let paren: bool = if ie < be then to_i64(string_get(m3, ie)) == 40 else false in
          if (if er.eq then paren else false) then (let s: BC = { p: ie, found: true, mem: m3 } in s)
          else (let s: BC = { p: ie, found: false, mem: m3 } in s)
        else (let s: BC = { p: p1 + 1, found: false, mem: m2 } in s)
  in
  let res: REq = { eq: done.found, mem: done.mem } in res

// The CALLEE's ordinal within a recursion group: its alphabetical rank among the group's member
// names (the canonical member ordering — see the spike: within a single SCC the member order, and
// hence the `recursion_group:<ord>` nonces, is alphabetical by name). For this increment the group
// is the WHOLE program (a mutual-recursion clique that IS every top-level function), so the rank is
// taken over all `fn <name>` declarations: count the declared names that are <= the callee name
// (mem[callns,callne)); rank = count - 1 (subtracting the callee's own self-match, since names are
// distinct). Mirrors find_callee_rtc's declaration walk (an identifier right after the `fn` keyword
// is a function NAME) but does NOT early-exit — it must see every member to rank correctly. The
// move-only `mem` is carried in the accumulator (name_le consumes + returns it) and threaded back.
fn clique_rank(mem: string, callns: i64, callne: i64, len: i64) -> TC =
  let done: CRScan =
    loop a = { p: 0, prevfn: false, count: 0, mem: mem } while a.p < len do
      let cur: CRScan = a in
      let sw: MI = skip_ws(cur.mem, cur.p, len) in
      let m1: string = sw.mem in
      let p1: i64 = sw.i in
      if p1 >= len then (let s: CRScan = { p: len, prevfn: false, count: cur.count, mem: m1 } in s)
      else
        let idr: MI = scan_ident(m1, p1, len) in
        let m2: string = idr.mem in
        let ie: i64 = idr.i in
        if ie > p1 then
          let isfn: bool = if ie - p1 == 2 then (to_i64(string_get(m2, p1)) == 102 && to_i64(string_get(m2, p1 + 1)) == 110) else false in
          if isfn then (let s: CRScan = { p: ie, prevfn: true, count: cur.count, mem: m2 } in s)
          else if cur.prevfn then
            // this identifier [p1, ie) is a function NAME; count it if it is <= the callee name.
            let le: REq = name_le(m2, p1, ie, callns, callne) in
            let nc: i64 = if le.eq then cur.count + 1 else cur.count in
            (let s: CRScan = { p: ie, prevfn: false, count: nc, mem: le.mem } in s)
          else (let s: CRScan = { p: ie, prevfn: false, count: cur.count, mem: m2 } in s)
        else (let s: CRScan = { p: p1 + 1, prevfn: false, count: cur.count, mem: m2 } in s)
  in
  let rk: i64 = done.count - 1 in
  let res: TC = { code: rk, mem: done.mem } in res

// Look up the name `mem`[start,end) among scope slots [lo, hi), keeping the highest
// (innermost / last) match — so a shadowing let binding resolves to the nearest one —
// and report whether it was found, the matching slot index, and that slot's type code.
// The loop carries the move-only `mem` (range_eq consumes and returns it each step), so
// the result is rebuilt into a fresh record (the v0 loop-accumulator-return workaround).
// The CALLER turns idx into a de-Bruijn depth (n-1-idx) for a let, or a param index.
fn lookup(sc: Scope, lo: i64, hi: i64, mem: string, start: i64, endd: i64) -> RD =
  let tlen: i64 = endd - start in
  let done: RScan =
    loop a = { i: lo, best: 0 - 1, mem: mem } while a.i < hi do
      let cur: RScan = a in
      let code: i64 = sc.ids[cur.i] in
      let rest: i64 = code / 16 in
      let be: i64 = rest % 2000000 in
      let bs: i64 = rest / 2000000 in
      let m0: string = cur.mem in
      let er: REq =
        if be - bs == tlen then range_eq(m0, bs, start, tlen)
        else (let rr: REq = { eq: false, mem: m0 } in rr)
      in
      let nb: i64 = if er.eq then cur.i else cur.best in
      let r: RScan = { i: cur.i + 1, best: nb, mem: er.mem } in r
  in
  let bi: i64 = done.best in
  let m1: string = done.mem in
  let fnd: bool = if bi < 0 then false else true in
  let bt: i64 = if bi < 0 then 0 else sc.ids[bi] % 16 in
  let res: RD = { found: fnd, idx: bi, btyc: bt, mem: m1 } in res

// Resolve an identifier `mem`[start,end). The ONE combined scope holds the function's
// parameters at indices [0, np) and the enclosing `let` bindings at [np, n). Check the
// let region first — a match is a `local_ref` by de-Bruijn depth (scope.n - 1 - idx),
// so a `let` shadows a same-named parameter — then the parameter region — a match is a
// `param_ref` by its index. Lets and params are separate namespaces (a let's depth does
// not count params); the node is typed by the binding/param it names. (A name in neither
// is an undefined variable — a type-invalid program, outside the oracle.)
fn resolve_ident(scope: Scope, np: i64, mem: string, start: i64, endd: i64) -> Pr effects[alloc, state] =
  let lk: RD = lookup(scope, np, scope.n, mem, start, endd) in
  if lk.found then
    let h: string = build_local_ref(scope.n - 1 - lk.idx, lk.btyc) in
    let res: Pr = { mem: lk.mem, hash: h, tyc: lk.btyc, next: endd } in res
  else
    let lk2: RD = lookup(scope, 0, np, lk.mem, start, endd) in
    let h: string = build_param_ref(lk2.idx, lk2.btyc) in
    let res: Pr = { mem: lk2.mem, hash: h, tyc: lk2.btyc, next: endd } in res

// Recursively scan the parameter list starting at `pos` (just past `(`, or just past a
// `,`), accumulating each `IDENT : TYPE` into the positional table `ps` (push order =
// parameter index). Stops at `)` (or end of input) and returns the position just past
// it. Bounds checks are nested `if`s because `&&` is strict; only i64/bool param types.
fn scan_params(mem: string, pos: i64, len: i64, ps: Scope) -> PpR =
  let sw: MI = skip_ws(mem, pos, len) in
  if (if sw.i < len then to_i64(string_get(sw.mem, sw.i)) == 41 else true) then
    (let r: PpR = { mem: sw.mem, pos: sw.i + 1, ps: ps } in r)
  else
    // param name [ns, ne)
    let ns: i64 = sw.i in
    let nm: MI = scan_ident(sw.mem, ns, len) in
    let ne: i64 = nm.i in
    // `:` then the type identifier [ts, te)
    let c1: MI = skip_ws(nm.mem, ne, len) in
    let c2: MI = skip_ws(c1.mem, c1.i + 1, len) in
    let ts: i64 = c2.i in
    let ty: MI = scan_ident(c2.mem, ts, len) in
    let te: i64 = ty.i in
    let tc: TC = type_code_of(ty.mem, ts, te) in
    let btyc: i64 = tc.code in
    let ps2: Scope = push_scope(ps, ns, ne, btyc) in
    // skip ws; consume a `,` (byte 44) if present (else the `)` will end the list)
    let c3: MI = skip_ws(tc.mem, te, len) in
    let nextpos: i64 = if (if c3.i < len then to_i64(string_get(c3.mem, c3.i)) == 44 else false) then c3.i + 1 else c3.i in
    scan_params(c3.mem, nextpos, len, ps2)

// Re-derive a function's parameter scope from source: find the `(` past the name (which ends at
// `ne`) and scan the parameter list. The returned scope has rgord = -1 (callers that need a
// recursion-group ordinal rebuild the scope with their `ord`). `mem` threaded back via PpR.
fn derive_params(mem: string, ne: i64, len: i64) -> PpR =
  let op: MI = find_byte(mem, ne, len, 40) in
  let seed: Scope = { ids: [0x0; 12], n: 0, rgord: 0 - 1, aord: 0 } in
  scan_params(op.mem, op.i, len, seed)

// ---------------------------------------------------------------------------
// the object builders (canonical payloads)
// ---------------------------------------------------------------------------

fn build_type_i64() -> string effects[alloc, state] =
  let p: string = push_lit(string_with_capacity(64), b"{\"type_kind\":\"I64\"}") in
  hash_object(b"Type", 1, p)

fn build_type_bool() -> string effects[alloc, state] =
  let p: string = push_lit(string_with_capacity(64), b"{\"type_kind\":\"Bool\"}") in
  hash_object(b"Type", 1, p)

// The Type-object hash for a type code. Codes: 0 = i64, 1 = bool, 2 = u8, 3 = u16,
// 4 = u32, 5 = u64, 6 = i8, 7 = i16, 8 = i32. The else (including 0) is i64.
fn type_hash(tyc: i64) -> string effects[alloc, state] =
  if tyc == 1 then build_type_bool()
  else if tyc == 2 then hash_object(b"Type", 1, push_lit(string_with_capacity(64), b"{\"type_kind\":\"U8\"}"))
  else if tyc == 3 then hash_object(b"Type", 1, push_lit(string_with_capacity(64), b"{\"type_kind\":\"U16\"}"))
  else if tyc == 4 then hash_object(b"Type", 1, push_lit(string_with_capacity(64), b"{\"type_kind\":\"U32\"}"))
  else if tyc == 5 then hash_object(b"Type", 1, push_lit(string_with_capacity(64), b"{\"type_kind\":\"U64\"}"))
  else if tyc == 6 then hash_object(b"Type", 1, push_lit(string_with_capacity(64), b"{\"type_kind\":\"I8\"}"))
  else if tyc == 7 then hash_object(b"Type", 1, push_lit(string_with_capacity(64), b"{\"type_kind\":\"I16\"}"))
  else if tyc == 8 then hash_object(b"Type", 1, push_lit(string_with_capacity(64), b"{\"type_kind\":\"I32\"}"))
  else build_type_i64()

// Resolve an expected type code against a fallback: a concrete expectation (>= 0) wins,
// otherwise (NONE, the sentinel -1) fall back to the bottom-up `lt`. Used by the
// arithmetic levels to type operands/results (expected if set, else the left operand's).
fn eff(etyc: i64, lt: i64) -> i64 = if etyc >= 0 then etyc else lt

// Append a type code's source NAME (i64/bool/u8/.../i32) to `out`. The migration
// operation (and the function_source_matches postcondition) serialize the return type as
// a raw type NAME string, NOT a Type-object hash (the dual serialization), so this is the
// raw counterpart of type_hash. Codes match type_hash: 0 = i64, 1 = bool, 2 = u8, 3 = u16,
// 4 = u32, 5 = u64, 6 = i8, 7 = i16, 8 = i32.
fn push_type_name(out: string, rtc: i64) -> string effects[state] =
  if rtc == 1 then push_lit(out, b"bool")
  else if rtc == 2 then push_lit(out, b"u8")
  else if rtc == 3 then push_lit(out, b"u16")
  else if rtc == 4 then push_lit(out, b"u32")
  else if rtc == 5 then push_lit(out, b"u64")
  else if rtc == 6 then push_lit(out, b"i8")
  else if rtc == 7 then push_lit(out, b"i16")
  else if rtc == 8 then push_lit(out, b"i32")
  else push_lit(out, b"i64")

// Classify a type-name identifier `mem`[ts,te) into a type code (the inverse of the
// type_kind in type_hash); threads `mem` back. Recognizes i8/i16/i32/i64 and u8/u16/u32/
// u64 and bool; anything else (or an unknown name) reads as i64 (code 0).
fn type_code_of(mem: string, ts: i64, te: i64) -> TC =
  let n: i64 = te - ts in
  let c: i64 =
    if n == 2 then
      (let b0: i64 = to_i64(string_get(mem, ts)) in
       if b0 == 117 then 2 else if b0 == 105 then 6 else 0)
    else if n == 3 then
      (let b0: i64 = to_i64(string_get(mem, ts)) in
       let b1: i64 = to_i64(string_get(mem, ts + 1)) in
       if b0 == 105 then (if b1 == 54 then 0 else if b1 == 51 then 8 else if b1 == 49 then 7 else 0)
       else if b0 == 117 then (if b1 == 51 then 4 else if b1 == 54 then 5 else if b1 == 49 then 3 else 0)
       else 0)
    else if n == 4 then
      (if to_i64(string_get(mem, ts)) == 98 then 1 else 0)
    else 0
  in
  let res: TC = { code: c, mem: mem } in res

// Emit the params array body (the Type hashes of params [i, n), comma-separated and
// JSON-quoted) onto `out`, recursively so the move-only buffer threads without a loop
// accumulator. Each param's type hash is its btyc's Type object (i64 or bool).
fn push_sig_params_at(out: string, params: Scope, i: i64) -> string effects[alloc, state] =
  if i >= params.n then out
  else
    let pre: string = if i == 0 then out else push_byte(out, to_u8(44)) in
    let q1: string = push_byte(pre, to_u8(34)) in
    let q2: string = push_str(q1, type_hash(params.ids[i] % 16)) in
    let q3: string = push_byte(q2, to_u8(34)) in
    push_sig_params_at(q3, params, i + 1)

// Emit the WL static-sig `params` array body: the param TYPE NAMES, quoted + comma-separated
// (`"i64","i64"`) — NOT type hashes (this feeds the recursion-order colour, src/lib.rs
// recursion_member_static_sigs maps each param to its type name). Tail-recursion like push_sig_params_at.
fn push_ptypes_at(out: string, params: Scope, i: i64) -> string effects[state] =
  if i >= params.n then out
  else
    let pre: string = if i == 0 then out else push_byte(out, to_u8(44)) in
    let q1: string = push_byte(pre, to_u8(34)) in
    let q2: string = push_type_name(q1, params.ids[i] % 16) in
    let q3: string = push_byte(q2, to_u8(34)) in
    push_ptypes_at(q3, params, i + 1)

fn build_sig(rettyc: i64, params: Scope) -> string effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(1024), b"{\"abi\":\"codedb-v0-internal\",\"effects\":[],\"params\":[") in
  let p1: string = push_sig_params_at(p0, params, 0) in
  let p2: string = push_lit(p1, b"],\"return\":\"") in
  let p3: string = push_str(p2, type_hash(rettyc)) in
  let p4: string = push_lit(p3, b"\"}") in
  hash_object(b"FunctionSignature", 1, p4)

fn build_sym() -> string effects[alloc, state] =
  let p: string = push_lit(string_with_capacity(160), b"{\"birth_history_hash\":\"genesis\",\"local_nonce\":\"import:main:main:0\",\"symbol_kind\":\"function\"}") in
  hash_object(b"SymbolBirth", 1, p)

// The empty-program ProgramRoot — the genesis root that seeds the migration chain (the
// input_root of the first migration). Building it (rather than hard-coding the hash)
// exercises the same ProgramRoot framing the rest of the importer uses.
fn build_genesis_root() -> string effects[alloc, state] =
  let p: string = push_lit(string_with_capacity(80), b"{\"metadata\":{},\"names\":[],\"param_names\":[],\"symbols\":[]}") in
  hash_object(b"ProgramRoot", 1, p)

// Build a SymbolBirth for the function named mem[sl.ns, sl.ne) with birth history `bh`
// (the literal "genesis" for the first symbol, else the running history hash) and the
// given creation `ordv`: local_nonce = "import:main:<name>:<ordv>". Returns the content
// hash with `mem` threaded back; `bh` is consumed.
fn build_sym_at(bh: string, mem: string, sl: Sl, ordv: i64) -> MH effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(256), b"{\"birth_history_hash\":\"") in
  let p1: string = push_str(p0, bh) in
  let p2: string = push_lit(p1, b"\",\"local_nonce\":\"import:main:") in
  let pr: PRR = push_range(p2, mem, sl.ns, sl.ne) in
  let p3: string = pr.out in
  let m1: string = pr.mem in
  let p4: string = push_byte(p3, to_u8(58)) in
  let p5: string = push_dec(p4, ordv) in
  let p6: string = push_lit(p5, b"\",\"symbol_kind\":\"function\"}") in
  let h: string = hash_object(b"SymbolBirth", 1, p6) in
  let r: MH = { mem: m1, hash: h } in r

// A recursion-group MEMBER's SymbolBirth: birth genesis, local_nonce "recursion_group:<ord>"
// (the member's ordinal in canonical order, NOT its name — unlike a create_function symbol).
// `mem` is just threaded through (the nonce needs no source slice).
fn build_sym_rg_mh(mem: string, ord: i64) -> MH effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(160), b"{\"birth_history_hash\":\"genesis\",\"local_nonce\":\"recursion_group:") in
  let p1: string = push_dec(p0, ord) in
  let p2: string = push_lit(p1, b"\",\"symbol_kind\":\"function\"}") in
  let h: string = hash_object(b"SymbolBirth", 1, p2) in
  let r: MH = { mem: mem, hash: h } in r

// A non-recursive CALLEE's symbol (the cross-symbol-call case): genesis birth, nonce
// import:main:<mem[p,e)>:0 (the canonical-first function of a two-function DAG). Wraps
// build_sym_at so resolve_call_symbol can pick between this and the recursion-group form
// as two whole function calls (a conditional of calls is safe; string-building inside a
// record-returning conditional is the v0 SIGTRAP, so keep it out of the `if`).
fn build_sym_fn_mh(mem: string, p: i64, e: i64) -> MH effects[alloc, state] =
  let gstr: string = push_lit(string_with_capacity(16), b"genesis") in
  let csl: Sl = { ns: p, ne: e, bs: 0, rtc: 0 } in
  build_sym_at(gstr, mem, csl, 0)

// Resolve a call's callee symbol: in a recursion-group context (`rgord >= 0`) the callee resolves
// to the `recursion_group:<ord>` symbol — `ord` is the CALLEE's ordinal (its alphabetical rank
// among the group's members, from clique_rank), NOT the caller's `rgord`. In a single-member group
// the only call is the self-call so ord == rgord == 0, but in a mutual-recursion clique a member's
// call to ANOTHER member resolves to that member's distinct ordinal. Outside a group it resolves to
// the create_function symbol named by the call. A conditional of two whole calls — no string-building
// inside the `if` (the v0 SIGTRAP), so `ord` is computed by the caller and passed in.
fn resolve_call_symbol(rgord: i64, ord: i64, mem: string, p: i64, e: i64) -> MH effects[alloc, state] =
  if rgord >= 0 then build_sym_rg_mh(mem, ord)
  else build_sym_fn_mh(mem, p, e)

// Extra-callee resolution (the n-function DAG case). build_sym_fn_mh resolves a callee to the
// GENESIS / ordinal-0 symbol, which is correct only when the callee is the canonical-first
// function. In a DAG a later function (canonical ordinal k) may call ANY earlier ordinal 1..k-1,
// whose symbol was born at a running history (not genesis). Re-running the chain inside the parser
// is intractable; instead the already-computed symbols of ordinals 1..k-1 are appended to the
// source as an extra-callee TABLE — for each, `name` + `\0` + the 71-char symbol — past the parse
// bound `len` (so the table is invisible to the parser at large; only build_fn_objs_xc parses an
// augmented buffer, signalled by string_len(mem) > len). Calls to ordinal 0 still take the genesis
// default. The table is built by build_augN and scanned linearly here.

// Scan the extra-callee table (present iff string_len(mem) > len) for an entry whose name equals
// the call name mem[p, e). Each entry is `name` + `\0` + a 71-char symbol; the `\0` ends the name
// and the symbol is the next 71 bytes, after which the next entry begins. Returns hit + the
// matched symbol's offset (a pure scan, no string building, so the caller picks the symbol as a
// conditional of two whole calls — the v0 aggregate-return rule). Threads `mem`.
fn xc_scan(mem: string, p: i64, e: i64, len: i64) -> XC effects[state] =
  let full: i64 = string_len(mem) in
  let clen: i64 = e - p in
  let seed: XC = { hit: false, off: 0, pos: len, mem: mem } in
  let done: XC =
    loop a = seed while (if a.hit then false else a.pos < full) do
      let cur: XC = a in
      // find_byte returns the index JUST PAST the `\0`, so the `\0` is at fb.i - 1: the name is
      // [cur.pos, fb.i - 1) and the 71-char symbol starts at fb.i (right after the `\0`).
      let fb: MI = find_byte(cur.mem, cur.pos, full, 0) in
      let symoff: i64 = fb.i in
      let namelen: i64 = fb.i - 1 - cur.pos in
      let cmp: REq = if clen == namelen then range_eq(fb.mem, p, cur.pos, namelen) else (let rr: REq = { eq: false, mem: fb.mem } in rr) in
      if cmp.eq then (let r: XC = { hit: true, off: symoff, pos: full, mem: cmp.mem } in r)
      else (let r: XC = { hit: false, off: 0, pos: symoff + 71, mem: cmp.mem } in r)
  in
  let res: XC = { hit: done.hit, off: done.off, pos: done.pos, mem: done.mem } in res

// The matched extra-callee symbol: the 71-char hash stored at mem[off, off + 71) (built earlier
// in the chain at its real birth history and ordinal). A straight-line extractor.
fn build_sym_xc(mem: string, off: i64) -> MH effects[alloc, state] =
  let pr: PRR = push_range(string_with_capacity(80), mem, off, off + 71) in
  let r: MH = { mem: pr.mem, hash: pr.out } in r

fn build_def(sig: string, sym: string, e: string) -> DH effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(320), b"{\"function_sig_hash\":\"") in
  let k1: OS = push_kept(p0, sig) in
  let p1: string = k1.out in
  let sig2: string = k1.s in
  let p2: string = push_lit(p1, b"\",\"symbol\":\"") in
  let k2: OS = push_kept(p2, sym) in
  let p3: string = k2.out in
  let sym2: string = k2.s in
  let p4: string = push_lit(p3, b"\",\"typed_body_expr_hash\":\"") in
  let p5: string = push_str(p4, e) in
  let p6: string = push_lit(p5, b"\"}") in
  let d: string = hash_object(b"FunctionDef", 1, p6) in
  let res: DH = { h: d, sig: sig2, sym: sym2 } in res

// Emit the param-names array body (the source names of params [i, n), comma-separated
// and JSON-quoted) onto `out`, recursively so both move-only buffers thread without a
// loop accumulator; the names are copied from `mem`'s byte ranges, so `mem` is threaded
// back alongside the built string.
fn push_pnames_at(out: string, mem: string, params: Scope, i: i64) -> PRR effects[state] =
  if i >= params.n then (let r: PRR = { out: out, mem: mem } in r)
  else
    let pre: string = if i == 0 then out else push_byte(out, to_u8(44)) in
    let q1: string = push_byte(pre, to_u8(34)) in
    let code: i64 = params.ids[i] in
    let rest: i64 = code / 16 in
    let ne: i64 = rest % 2000000 in
    let ns: i64 = rest / 2000000 in
    let pv: PRR = push_range(q1, mem, ns, ne) in
    let q2: string = push_byte(pv.out, to_u8(34)) in
    push_pnames_at(q2, pv.mem, params, i + 1)

// Emit a create_function operation's `params` array body: {"name":"<source name>","type":
// "<type NAME>"} comma-separated (name = source slice, type = the raw type NAME — the dual
// serialization, like return_type). Recursive (move-only buffer threads without a loop); mem
// threaded back. The scope entry packs (start*2000000+end)*16 + btyc — same decode as push_pnames_at.
fn push_op_params_at(out: string, mem: string, params: Scope, i: i64) -> PRR effects[state] =
  if i >= params.n then (let r: PRR = { out: out, mem: mem } in r)
  else
    let pre: string = if i == 0 then out else push_byte(out, to_u8(44)) in
    let q0: string = push_lit(pre, b"{\"name\":\"") in
    let code: i64 = params.ids[i] in
    let rest: i64 = code / 16 in
    let ne: i64 = rest % 2000000 in
    let ns: i64 = rest / 2000000 in
    let pv: PRR = push_range(q0, mem, ns, ne) in
    let q1: string = push_lit(pv.out, b"\",\"type\":\"") in
    let q2: string = push_type_name(q1, code % 16) in
    let q3: string = push_lit(q2, b"\"}") in
    push_op_params_at(q3, pv.mem, params, i + 1)

fn build_root_obj(sym: string, def: string, sig: string, mem: string, params: Scope) -> string effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(2048), b"{\"metadata\":{},\"names\":[{\"display_name\":\"main\",\"is_preferred\":true,\"module\":\"main\",\"symbol\":\"") in
  let k1: OS = push_kept(p0, sym) in
  let p1: string = k1.out in
  let sym1: string = k1.s in
  let p2a: string = push_lit(p1, b"\"}],\"param_names\":[{\"names\":[") in
  let pn: PRR = push_pnames_at(p2a, mem, params, 0) in
  let pnout: string = pn.out in
  let pnmem: string = pn.mem in
  let p2: string = push_lit(pnout, b"],\"symbol\":\"") in
  let k2: OS = push_kept(p2, sym1) in
  let p3: string = k2.out in
  let sym2: string = k2.s in
  let p4: string = push_lit(p3, b"\"}],\"symbols\":[{\"definition\":\"") in
  let p5: string = push_str(p4, def) in
  let p6: string = push_lit(p5, b"\",\"signature\":\"") in
  let p7: string = push_str(p6, sig) in
  let p8: string = push_lit(p7, b"\",\"symbol\":\"") in
  let p9: string = push_str(p8, sym2) in
  let p10: string = push_lit(p9, b"\"}]}") in
  hash_object(b"ProgramRoot", 1, p10)

// Build a RecursionGroup object over a single member: {"members":[{"definition","signature",
// "symbol"}],"module":"main"}. The member's def/sig/symbol are KEPT (they also appear in the
// ProgramRoot's symbols/recursion_groups arrays) and threaded back via the `RGc` carrier.
fn build_recursion_group(def: string, sig: string, sym: string) -> RGc effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(320), b"{\"members\":[{\"definition\":\"") in
  let k0: OS = push_kept(p0, def) in
  let p1: string = k0.out in
  let def1: string = k0.s in
  let p2: string = push_lit(p1, b"\",\"signature\":\"") in
  let k1: OS = push_kept(p2, sig) in
  let p3: string = k1.out in
  let sig1: string = k1.s in
  let p4: string = push_lit(p3, b"\",\"symbol\":\"") in
  let k2: OS = push_kept(p4, sym) in
  let p5: string = k2.out in
  let sym1: string = k2.s in
  let p6: string = push_lit(p5, b"\"}],\"module\":\"main\"}") in
  let h: string = hash_object(b"RecursionGroup", 1, p6) in
  let r: RGc = { hash: h, def: def1, sig: sig1, sym: sym1 } in r

// Build the ProgramRoot for a single-member recursion group: like build_root1 but with a
// `recursion_groups` array (key order metadata, names, param_names, recursion_groups,
// symbols — alphabetical). The member's display name is mem[ns,ne); its symbol appears in
// names/param_names/symbols (threaded via push_kept), the RecursionGroup hash in recursion_groups.
fn build_rg_root_obj(mem: string, ns: i64, ne: i64, rgc: RGc, pnf: string) -> string effects[alloc, state] =
  let sym: string = rgc.sym in
  let def: string = rgc.def in
  let sig: string = rgc.sig in
  let rg: string = rgc.hash in
  let p0: string = push_lit(string_with_capacity(1024), b"{\"metadata\":{},\"names\":[{\"display_name\":\"") in
  let nb: PRR = push_range(p0, mem, ns, ne) in
  let p1: string = push_lit(nb.out, b"\",\"is_preferred\":true,\"module\":\"main\",\"symbol\":\"") in
  let k0: OS = push_kept(p1, sym) in
  let p2a: string = push_lit(k0.out, b"\"}],\"param_names\":[{\"names\":[") in
  let p2b: string = push_str(p2a, pnf) in
  let p2: string = push_lit(p2b, b"],\"symbol\":\"") in
  let k1: OS = push_kept(p2, k0.s) in
  let p3: string = push_lit(k1.out, b"\"}],\"recursion_groups\":[\"") in
  let p4: string = push_str(p3, rg) in
  let p5: string = push_lit(p4, b"\"],\"symbols\":[{\"definition\":\"") in
  let p6: string = push_str(p5, def) in
  let p7: string = push_lit(p6, b"\",\"signature\":\"") in
  let p8: string = push_str(p7, sig) in
  let p9: string = push_lit(p8, b"\",\"symbol\":\"") in
  let p10: string = push_str(p9, k1.s) in
  let p11: string = push_lit(p10, b"\"}]}") in
  hash_object(b"ProgramRoot", 1, p11)

// Build the ProgramRoot for a single SELF-RECURSIVE function `fn <name>() -> <rettyc> = <body>`
// (mem[ns,ne) the name, `bodypos` the body start). A self-recursive function is a one-member
// recursion group: its symbol is `recursion_group:0` (genesis birth), its body is RE-PARSED
// with the scope marked `rgord = 0` so the self-call resolves to that symbol, and the
// ProgramRoot carries a RecursionGroup object. No migration/history chain is needed for the
// root (the birth is genesis). No-param (a no-arg self-call requires a no-param function).
fn build_rg_root(mem: string, ns: i64, ne: i64, bodypos: i64, rettyc: i64, len: i64) -> string effects[alloc, state] =
  let s: MH = build_sym_rg_mh(mem, 0) in
  let m1: string = s.mem in
  let symf: string = s.hash in
  let pr: PpR = derive_params(m1, ne, len) in
  let params: Scope = pr.ps in
  let np: i64 = params.n in
  let sc: Scope = { ids: params.ids, n: np, rgord: 0, aord: 0 } in
  let e: Pr = parse_bitor(pr.mem, bodypos, len, sc, np, rettyc) in
  let m2: string = e.mem in
  let bodyh: string = e.hash in
  let sig: string = build_sig(rettyc, params) in
  let d: DH = build_def(sig, symf, bodyh) in
  let rgc: RGc = build_recursion_group(d.h, d.sig, d.sym) in
  let pnr: PRR = push_pnames_at(string_with_capacity(bodypos - ne + 16), m2, params, 0) in
  build_rg_root_obj(pnr.mem, ns, ne, rgc, pnr.out)

// Build one member of a MULTI-member recursion group (the mutual-recursion case): its SymbolBirth
// (genesis, `recursion_group:<ord>` — `ord` is the member's WL canonical ordinal), its body
// Expression (RE-PARSED from `sl.bs` with the scope marked `rgord = ord`, `aord` = the clique's
// alpha-first WL ordinal, so calls resolve to each callee's WL ordinal — a self-call to `ord`, a
// cross-member call to the OTHER member's WL ordinal), its FunctionSignature, combined into a
// FunctionDef. Returns the def/sig/symbol hashes with `mem` threaded back (FObj, like
// build_fn_objs). No-param (a no-arg call requires a no-param callee).
fn build_rg_member(mem: string, sl: Sl, ord: i64, aord: i64, len: i64) -> FObj effects[alloc, state] =
  let s: MH = build_sym_rg_mh(mem, ord) in
  let m1: string = s.mem in
  let symf: string = s.hash in
  // re-derive the member's params; mark the body scope rgord = ord (so self/cross-member calls
  // resolve to the right ordinal) and aord (the alpha-first member's WL ordinal).
  let pr: PpR = derive_params(m1, sl.ne, len) in
  let mp: string = pr.mem in
  let params: Scope = pr.ps in
  let np: i64 = params.n in
  let sc: Scope = { ids: params.ids, n: np, rgord: ord, aord: aord } in
  let e: Pr = parse_bitor(mp, sl.bs, len, sc, np, sl.rtc) in
  let m2: string = e.mem in
  let bodyh: string = e.hash in
  let sig: string = build_sig(sl.rtc, params) in
  let d: DH = build_def(sig, symf, bodyh) in
  let pnr: PRR = push_pnames_at(string_with_capacity(sl.bs - sl.ne + 16), m2, params, 0) in
  let r: FObj = { mem: pnr.mem, sym: d.sym, def: d.h, sig: d.sig, pn: pnr.out } in r

// A TWO-member RecursionGroup object: {"members":[{def,sig,sym}_0,{def,sig,sym}_1],"module":"main"}
// (members in ordinal/canonical order; member key order definition,signature,symbol — alphabetical).
// All six member hashes are KEPT (they reappear in the ProgramRoot's symbols array) and threaded
// back via RG2 alongside the group hash. Mirrors build_recursion_group (single member, doubled).
fn build_recursion_group2(def0: string, sig0: string, sym0: string, def1: string, sig1: string, sym1: string) -> RG2 effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(640), b"{\"members\":[{\"definition\":\"") in
  let k0: OS = push_kept(p0, def0) in
  let p1: string = push_lit(k0.out, b"\",\"signature\":\"") in
  let k1: OS = push_kept(p1, sig0) in
  let p2: string = push_lit(k1.out, b"\",\"symbol\":\"") in
  let k2: OS = push_kept(p2, sym0) in
  let p3: string = push_lit(k2.out, b"\"},{\"definition\":\"") in
  let k3: OS = push_kept(p3, def1) in
  let p4: string = push_lit(k3.out, b"\",\"signature\":\"") in
  let k4: OS = push_kept(p4, sig1) in
  let p5: string = push_lit(k4.out, b"\",\"symbol\":\"") in
  let k5: OS = push_kept(p5, sym1) in
  let p6: string = push_lit(k5.out, b"\"}],\"module\":\"main\"}") in
  let h: string = hash_object(b"RecursionGroup", 1, p6) in
  let r: RG2 = { rg: h, d0: k0.s, g0: k1.s, s0: k2.s, d1: k3.s, g1: k4.s, s1: k5.s } in r

// The param_names, recursion_groups and symbols arrays (and the closing brace) of a two-member
// recursion-group ProgramRoot, taking the partial buffer (metadata + names already emitted) and the
// member triples in `c` (RG2). For a two-member group the symbol-hash order coincides with the
// ordinal order (ord 0's symbol always hash-sorts before ord 1's) which is the display-name order,
// so all three arrays emit member 0 then member 1 — no reordering (unlike build_root2_tail). Split
// from the head for the v0 frame budget.
fn build_mutrec_tail(buf: string, c: RG2, pp: PP) -> string effects[alloc, state] =
  let hp0: string = pp.p0 in
  let hp1: string = pp.p1 in
  let u0a: string = push_lit(buf, b",\"param_names\":[{\"names\":[") in
  let u0b: string = push_str(u0a, hp0) in
  let u0: string = push_lit(u0b, b"],\"symbol\":\"") in
  let k0: OS = push_kept(u0, c.s0) in
  let u1a: string = push_lit(k0.out, b"\"},{\"names\":[") in
  let u1b: string = push_str(u1a, hp1) in
  let u1: string = push_lit(u1b, b"],\"symbol\":\"") in
  let k1: OS = push_kept(u1, c.s1) in
  let u2: string = push_lit(k1.out, b"\"}],\"recursion_groups\":[\"") in
  let u3: string = push_str(u2, c.rg) in
  let u4: string = push_lit(u3, b"\"],\"symbols\":[{\"definition\":\"") in
  let t0: string = push_str(u4, c.d0) in
  let t1: string = push_lit(t0, b"\",\"signature\":\"") in
  let t2: string = push_str(t1, c.g0) in
  let t3: string = push_lit(t2, b"\",\"symbol\":\"") in
  let t4: string = push_str(t3, k0.s) in
  let t5: string = push_lit(t4, b"\"},{\"definition\":\"") in
  let t6: string = push_str(t5, c.d1) in
  let t7: string = push_lit(t6, b"\",\"signature\":\"") in
  let t8: string = push_str(t7, c.g1) in
  let t9: string = push_lit(t8, b"\",\"symbol\":\"") in
  let t10: string = push_str(t9, k1.s) in
  let t11: string = push_lit(t10, b"\"}]}") in
  hash_object(b"ProgramRoot", 1, t11)

// Emit the recursion-group ProgramRoot's `names` array (DISPLAY-name order, the triples already so
// ordered in `dsix`), then re-order the same (sym, def, sig) triples by SYMBOL HASH and hand off to
// build_mutrec_tail for param_names/recursion_groups/symbols. Mirrors build_root2_names (the
// two-function root) — `names` is display-name-ordered but param_names/symbols are symbol-hash-ordered
// (src/model.rs normalize_root); they diverge once the WL ordinal != alphabetical (asymmetric clique).
fn build_mutrec_names(mem: string, nr: NR, dsix: Six, rghash: string, pp: PP) -> string effects[alloc, state] =
  let lns: i64 = nr.lns in
  let lne: i64 = nr.lne in
  let hns: i64 = nr.hns in
  let hne: i64 = nr.hne in
  let ds0: string = dsix.s0 in
  let dd0: string = dsix.d0 in
  let dg0: string = dsix.g0 in
  let ds1: string = dsix.s1 in
  let dd1: string = dsix.d1 in
  let dg1: string = dsix.g1 in
  let p0: string = push_lit(string_with_capacity(2048), b"{\"metadata\":{},\"names\":[{\"display_name\":\"") in
  let na: PRR = push_range(p0, mem, lns, lne) in
  let p1: string = push_lit(na.out, b"\",\"is_preferred\":true,\"module\":\"main\",\"symbol\":\"") in
  let k0: OS = push_kept(p1, ds0) in
  let p2: string = push_lit(k0.out, b"\"},{\"display_name\":\"") in
  let nb: PRR = push_range(p2, na.mem, hns, hne) in
  let p3: string = push_lit(nb.out, b"\",\"is_preferred\":true,\"module\":\"main\",\"symbol\":\"") in
  let k1: OS = push_kept(p3, ds1) in
  let p6: string = push_lit(k1.out, b"\"}]") in
  let s0k: string = k0.s in
  let s1k: string = k1.s in
  let cmp: CmpS = sym_le(s0k, s1k) in
  let le: bool = cmp.le in
  let sA2: string = cmp.a in
  let sB2: string = cmp.b in
  let six: Six = order_triples(le, sA2, dd0, dg0, sB2, dd1, dg1) in
  let c: RG2 = { rg: rghash, d0: six.d0, g0: six.g0, s0: six.s0, d1: six.d1, g1: six.g1, s1: six.s1 } in
  // `pp` is in ordinal order; for a two-member group hash order == ordinal order (ord 0's symbol
  // always hash-sorts first), so the fragments already pair with the tail's hash-ordered symbols.
  build_mutrec_tail(p6, c, pp)

// Build the ProgramRoot for a two-member recursion group: key order metadata, names, param_names,
// recursion_groups, symbols (alphabetical; recursion_groups skip-if-empty so non-group roots are
// unchanged). `m0`/`m1` are the members in WL-ordinal order (ord 0, ord 1). `names` is DISPLAY-name
// order while param_names/symbols are SYMBOL-HASH (= ordinal, since ord 0's symbol always hash-sorts
// first) order — these DIVERGE for asymmetric cliques (WL ordinal != alphabetical), so order the
// (sym,def,sig) triples in display order here (order_triples — pure moves, no SIGTRAP) and emit names
// in build_mutrec_names, which re-orders by hash for the tail.
fn build_mutrec_root_obj(mem: string, m0: Sl, m1: Sl, rg: RG2, pp: PP) -> string effects[alloc, state] =
  let alc: REq = name_le(mem, m0.ns, m0.ne, m1.ns, m1.ne) in
  let mm: string = alc.mem in
  let nle: bool = alc.eq in
  let dsix: Six = order_triples(nle, rg.s0, rg.d0, rg.g0, rg.s1, rg.d1, rg.g1) in
  let lns: i64 = if nle then m0.ns else m1.ns in
  let lne: i64 = if nle then m0.ne else m1.ne in
  let hns: i64 = if nle then m1.ns else m0.ns in
  let hne: i64 = if nle then m1.ne else m0.ne in
  let nr: NR = { lns: lns, lne: lne, hns: hns, hne: hne } in
  build_mutrec_names(mm, nr, dsix, rg.rg, pp)

// ---------------------------------------------------------------------------
// Canonical recursion-group member ordering (the WL refinement, src/lib.rs
// canonical_clique_order). A mutual-recursion clique's members are NOT ordered
// alphabetically: their order is a 2-round Weisfeiler-Leman colour refinement, where
// member i's colour = sha256("codedb/recursion-order/v1\0" | static_sig_i | erased_body_i)
// and the erased body recolours each peer call `<name>` to `@recursion-peer:<peer colour>`.
// Symmetric cliques (equal round-1 colours) tie-break by name (alphabetical); asymmetric
// cliques sort by the converged (round-2) colours. Reproduced here for the two-member case.
// ---------------------------------------------------------------------------

// Copy a source byte range mem[s,e) into a fresh standalone string (the member name, read
// repeatedly by recolor for call-name matching), threading mem back.
fn slice_to_str(mem: string, s: i64, e: i64) -> PRR effects[alloc, state] =
  let buf: string = string_with_capacity(e - s + 8) in
  push_range(buf, mem, s, e)

// Pack a colour string into Copy bytes (recursively, so the move-only `s` threads without a
// loop accumulator). A WL colour is "sha256:"+64hex (71 bytes) or empty (round 1); both fit 72.
fn fill_color(s: string, b: array<u8, 72>, k: i64, n: i64) -> array<u8, 72> effects[state] =
  if k >= n then b
  else
    let byte: u8 = string_get(s, k) in
    fill_color(s, array_set(b, k, byte), k + 1, n)

fn to_color(s: string) -> Color effects[state] =
  let n: i64 = string_len(s) in
  let bytes: array<u8, 72> = fill_color(s, [0x0; 72], 0, n) in
  let r: Color = { b: bytes, n: n } in r

// Append a Copy colour's bytes to `out` (recursively — `out` is move-only, so a loop returning
// it risks the v0 accumulator-return SIGTRAP; recursion sidesteps it).
fn push_color(out: string, c: Color, k: i64) -> string effects[state] =
  if k >= c.n then out
  else push_color(push_byte(out, c.b[k]), c, k + 1)

// Recolour a raw body RECURSIVELY (one char / one call node per step): every call node's name is
// rewritten to `@recursion-peer:<colour of X>` (c0 if X equals member-0's name `name0`, else c1 — a
// branch-free Copy select; in a two-function clique every call is a peer, so the else branch is the
// other member). All other bytes copy verbatim. Recursion (NOT a loop) so the move-only output
// accumulator avoids the v0 loop-accumulator-return SIGTRAP (a loop form crashed natively here).
// `raw`/`name0` are borrowed for the scans (string_get) then threaded down/back via RErase; `out`
// accumulates. Depth = body length (small). The call-node marker is `"kind":"call"` (13 bytes,
// args-INDEPENDENT — a call may now carry arguments, so the old empty-`"args":[]` marker no longer
// identifies one; the args, emitted char-by-char before the marker, are recoloured by the same logic
// if they nest a peer call); `,"name":"` follows it, so the name begins at i+22. NOTE: a cast
// (`"kind":"call"`, name `to_*`) in a recursion-member body would be mis-recoloured — out of scope
// (a two-function clique body calls only its peers; no recursion fixture casts).
fn recolor_at(raw: string, name0: string, c0: Color, c1: Color, i: i64, rawlen: i64, out: string) -> RErase effects[state] =
  if i >= rawlen then (let r: RErase = { erased: out, name0: name0 } in r)
  else
    let iscall: bool =
      if i + 22 <= rawlen then
        (to_i64(string_get(raw, i)) == 34 && to_i64(string_get(raw, i + 1)) == 107
         && to_i64(string_get(raw, i + 2)) == 105 && to_i64(string_get(raw, i + 3)) == 110
         && to_i64(string_get(raw, i + 4)) == 100 && to_i64(string_get(raw, i + 5)) == 34
         && to_i64(string_get(raw, i + 6)) == 58 && to_i64(string_get(raw, i + 7)) == 34
         && to_i64(string_get(raw, i + 8)) == 99 && to_i64(string_get(raw, i + 9)) == 97
         && to_i64(string_get(raw, i + 10)) == 108 && to_i64(string_get(raw, i + 11)) == 108
         && to_i64(string_get(raw, i + 12)) == 34)
      else false
    in
    if iscall then
      // name at [i+22, jq); jq = the next `"` (past `"kind":"call","name":"`).
      let fq: Lc =
        loop k = { j: i + 22, c: 2 } while k.c == 2 do
          if k.j >= rawlen then (let s: Lc = { j: k.j, c: 0 } in s)
          else if to_i64(string_get(raw, k.j)) == 34 then (let s: Lc = { j: k.j, c: 1 } in s)
          else (let s: Lc = { j: k.j + 1, c: 2 } in s)
      in
      let jq: i64 = fq.j in
      let len0: i64 = string_len(name0) in
      // does raw[i+22, jq) equal name0?
      let nmseed: Lc = { j: 0, c: 2 } in
      let nm: Lc =
        if jq - (i + 22) == len0 then
          (loop k = nmseed while k.c == 2 do
             if k.j >= len0 then (let s: Lc = { j: k.j, c: 1 } in s)
             else if to_i64(string_get(raw, i + 22 + k.j)) == to_i64(string_get(name0, k.j)) then (let s: Lc = { j: k.j + 1, c: 2 } in s)
             else (let s: Lc = { j: k.j, c: 0 } in s))
        else (let s: Lc = { j: 0, c: 0 } in s)
      in
      let o1: string = push_lit(out, b"\"kind\":\"call\",\"name\":\"@recursion-peer:") in
      let cc: Color = if nm.c == 1 then c0 else c1 in
      let o2: string = push_color(o1, cc, 0) in
      recolor_at(raw, name0, c0, c1, jq, rawlen, o2)
    else
      let byte: u8 = string_get(raw, i) in
      recolor_at(raw, name0, c0, c1, i + 1, rawlen, push_byte(out, byte))

fn recolor(raw: string, name0: string, c0: Color, c1: Color) -> RErase effects[alloc, state] =
  let rawlen: i64 = string_len(raw) in
  // Generous: round-2 rewrites each member call's name to `@recursion-peer:`+a 71-byte colour
  // (~+86 per call); a fixed margin would TRAP on a many-call body. rawlen*4 bounds the worst case.
  let out: string = string_with_capacity(rawlen * 4 + 256) in
  recolor_at(raw, name0, c0, c1, 0, rawlen, out)

// The WL static sig `{"effects":[],"params":[<type names>],"regions":[],"return":"<typeNAME>"}`
// (src/lib.rs recursion_member_static_sigs). The `params` array is the member's parameter TYPE
// NAMES (NOT type hashes) — so the recursion-order colour depends on the member's parameter types.
fn build_rec_sig(rtc: i64, params: Scope) -> string effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(params.n * 8 + 96), b"{\"effects\":[],\"params\":[") in
  let pp: string = push_ptypes_at(p0, params, 0) in
  let p0b: string = push_lit(pp, b"],\"regions\":[],\"return\":\"") in
  let p1: string = push_type_name(p0b, rtc) in
  let p2: string = push_lit(p1, b"\"}") in
  p2

// One WL colour: hash("codedb/recursion-order/v1\0" | static_sig | erased body) where the body is
// the member's raw AST (raw_bitor) recoloured with the given peer colours (c0 for the member-0
// callee, c1 for the member-1 callee). `name0` is member-0's name (for the recolour match) threaded
// back; mem threaded back. Round 1 passes empty colours; round 2 passes the round-1 colours.
fn member_color(mem: string, sl: Sl, name0: string, c0: Color, c1: Color, len: i64) -> MCol effects[alloc, state] =
  let rb: Rr = raw_bitor(mem, sl.bs, len) in
  let pr: PpR = derive_params(rb.mem, sl.ne, len) in
  let mp: string = pr.mem in
  let er: RErase = recolor(rb.raw, name0, c0, c1) in
  let sig: string = build_rec_sig(sl.rtc, pr.ps) in
  // payload = sig | erased, in a FRESH buffer sized to fit (appending onto sig's fixed-capacity
  // buffer would overflow it — string_with_capacity TRAPS past its capacity; the erased body is
  // unbounded, growing with the colour bytes in round 2).
  let siglen: i64 = string_len(sig) in
  let erlen: i64 = string_len(er.erased) in
  let p0: string = string_with_capacity(siglen + erlen + 8) in
  let p1: string = push_str(p0, sig) in
  let p2: string = push_byte(p1, to_u8(124)) in
  let p3: string = push_str(p2, er.erased) in
  let h: string = hash_domain(b"codedb/recursion-order/v1\0", p3) in
  let r: MCol = { mem: mp, name0: er.name0, color: h } in r

// Compare two 71-char colour-hash strings for equality, threading both back.
fn streq71(a: string, b: string) -> Eq2 =
  let done: Lc =
    loop k = { j: 0, c: 2 } while k.c == 2 do
      if k.j >= 71 then (let s: Lc = { j: k.j, c: 1 } in s)
      else if to_i64(string_get(a, k.j)) == to_i64(string_get(b, k.j)) then (let s: Lc = { j: k.j + 1, c: 2 } in s)
      else (let s: Lc = { j: k.j, c: 0 } in s)
  in
  let r: Eq2 = { a: a, b: b, eq: done.c == 1 } in r

// Round 2 of the refinement (only when round 1 did NOT discretize — i.e. the clique is asymmetric):
// recolour each member's body with the round-1 colours c0/c1, hash, and order f0 first iff its
// round-2 colour <= f1's. `aord` (the alpha-first member's WL ordinal) follows from f0first and
// which of f0/f1 is alphabetically first. mem/name0 threaded through.
fn order_round2(mem: string, f0: Sl, f1: Sl, name0: string, c0s: string, c1s: string, len: i64) -> OClq effects[alloc, state] =
  let col0: Color = to_color(c0s) in
  let col1: Color = to_color(c1s) in
  let r2a: MCol = member_color(mem, f0, name0, col0, col1, len) in
  let d0: string = r2a.color in
  let m3: string = r2a.mem in
  let n3: string = r2a.name0 in
  let r2b: MCol = member_color(m3, f1, n3, col0, col1, len) in
  let d1: string = r2b.color in
  let m4: string = r2b.mem in
  let cmp: CmpS = sym_le(d0, d1) in
  let f0first: bool = cmp.le in
  let alc: REq = name_le(m4, f0.ns, f0.ne, f1.ns, f1.ne) in
  let f0le: bool = alc.eq in
  // a0 = the alpha-first member's WL ordinal; pack the alpha-rank -> ordinal map as base 4
  // (o0 + o1*4, with o1 = 1 - o0 for two members) — parse_call's general decode reads bits [2r,2r+1).
  let a0: i64 = if f0le then (if f0first then 0 else 1) else (if f0first then 1 else 0) in
  let aord: i64 = a0 + (1 - a0) * 4 in
  let r: OClq = { mem: alc.mem, f0first: f0first, aord: aord } in r

// Determine the canonical (WL) ordering of a two-member mutual-recursion clique {f0, f1} (f0 the
// FIRST source function). Round 1: each member's colour with EMPTY peer colours. If the two round-1
// colours are equal the clique is symmetric (automorphic) -> tie-break by name (alphabetical),
// aord = 0. Otherwise it is asymmetric -> round 2 decides (order_round2). Returns f0first (whether
// f0 is WL ordinal 0) and aord (the alpha-first member's WL ordinal). mem threaded back.
fn order_clique(mem: string, f0: Sl, f1: Sl, len: i64) -> OClq effects[alloc, state] =
  let nx: PRR = slice_to_str(mem, f0.ns, f0.ne) in
  let name0: string = nx.out in
  let m0: string = nx.mem in
  let empty: Color = { b: [0x0; 72], n: 0 } in
  let r1a: MCol = member_color(m0, f0, name0, empty, empty, len) in
  let c0: string = r1a.color in
  let m1: string = r1a.mem in
  let n1: string = r1a.name0 in
  let r1b: MCol = member_color(m1, f1, n1, empty, empty, len) in
  let c1: string = r1b.color in
  let m2: string = r1b.mem in
  let n2: string = r1b.name0 in
  let eqr: Eq2 = streq71(c0, c1) in
  let c0b: string = eqr.a in
  let c1b: string = eqr.b in
  if eqr.eq then
    // symmetric: WL order == alphabetical (alpha0 -> ord 0, alpha1 -> ord 1), so the packed
    // alpha-rank -> ordinal map is 0 + 1*4 = 4 (the two-member identity permutation).
    let alc: REq = name_le(m2, f0.ns, f0.ne, f1.ns, f1.ne) in
    let r: OClq = { mem: alc.mem, f0first: alc.eq, aord: 4 } in r
  else order_round2(m2, f0, f1, n2, c0b, c1b, len)

// Build the ProgramRoot for a MUTUAL-RECURSION clique (a two-member recursion group), the importer's
// output root. `f0`/`f1` are the two functions in SOURCE order; order_clique determines their WL
// canonical ordinals (NOT alphabetical for asymmetric cliques). Each member's objects are built in
// WL-ordinal order (symbol recursion_group:<ord>, body re-parsed with that rgord + the clique's aord
// so cross-member calls resolve to each callee's WL ordinal), then the RecursionGroup object, then
// the ProgramRoot. No migration/history chain is needed — both members' births are genesis (one
// create_recursion_group migration), so the root is reproduced from objects alone.
fn build_mutrec_root(mem: string, f0: Sl, f1: Sl, len: i64) -> string effects[alloc, state] =
  let oc: OClq = order_clique(mem, f0, f1, len) in
  let mo: string = oc.mem in
  let f0first: bool = oc.f0first in
  let aord: i64 = oc.aord in
  let m0: Sl = if f0first then f0 else f1 in
  let m1: Sl = if f0first then f1 else f0 in
  let fa: FObj = build_rg_member(mo, m0, 0, aord, len) in
  let m0m: string = fa.mem in
  let sym0: string = fa.sym in
  let def0: string = fa.def in
  let sig0: string = fa.sig in
  let pn0: string = fa.pn in
  let fb: FObj = build_rg_member(m0m, m1, 1, aord, len) in
  let m1m: string = fb.mem in
  let sym1: string = fb.sym in
  let def1: string = fb.def in
  let sig1: string = fb.sig in
  let pn1: string = fb.pn in
  let rg: RG2 = build_recursion_group2(def0, sig0, sym0, def1, sig1, sym1) in
  // param-name fragments in ORDINAL order (ord 0, ord 1); for a two-member group the symbol-hash
  // order coincides with the ordinal order, so they pair with the hash-ordered param_names tail.
  let pp: PP = { p0: pn0, p1: pn1 } in
  build_mutrec_root_obj(m1m, m0, m1, rg, pp)

// ===========================================================================
// Inc 2: the THREE-member DISCRETIZING recursion clique. Generalizes the
// two-member WL ordering (member_color/recolor/order_clique above) to n = 3:
// an n-round 1-WL colour refinement (src/lib.rs canonical_clique_order /
// refine_clique_colors) over a SINGLE three-member SCC. If 1-WL discretizes
// (all three colours distinct) the members sort by colour string -> their
// recursion-group ordinals. Non-discretizing (symmetric) cliques and mixed
// SCCs are detected and DEFERRED (Inc 4). The two-member path is untouched.
// ===========================================================================

// Pack a name STRING into Copy bytes (recursively, threading the move-only `s` without a loop
// accumulator), mirroring to_color/fill_color but in a 24-byte buffer (function names are short).
fn fill_name(s: string, b: array<u8, 24>, k: i64, n: i64) -> array<u8, 24> effects[state] =
  if k >= n then b
  else
    let byte: u8 = string_get(s, k) in
    fill_name(s, array_set(b, k, byte), k + 1, n)

fn to_name(s: string) -> Name effects[state] =
  let n: i64 = string_len(s) in
  let bytes: array<u8, 24> = fill_name(s, [0x0; 24], 0, n) in
  let r: Name = { b: bytes, n: n } in r

// Does the byte range raw[start, start+nm.n) equal the packed name `nm`? Recursive (no loop
// accumulator); `raw` is borrowed (string_get, which needs an OWNED string) and threaded back via
// MatchR so the recolour walk keeps it. nm (a Copy Name) carries the name bytes + length.
fn name_eq_at(raw: string, start: i64, nm: Name, k: i64) -> MatchR effects[state] =
  if k >= nm.n then (let r: MatchR = { hit: true, raw: raw } in r)
  else if to_i64(string_get(raw, start + k)) == to_i64(nm.b[k]) then name_eq_at(raw, start, nm, k + 1)
  else (let r: MatchR = { hit: false, raw: raw } in r)

fn match_name(raw: string, start: i64, endd: i64, nm: Name) -> MatchR effects[state] =
  if endd - start == nm.n then name_eq_at(raw, start, nm, 0)
  else (let r: MatchR = { hit: false, raw: raw } in r)

// Lexicographic Copy-colour comparison (shorter-is-smaller on a prefix; all converged colours are
// 71-byte hashes, so equal length in practice). -1 = a<b, 0 = equal, 1 = a>b. color_lt for sorting.
fn color_cmp_at(a: Color, b: Color, k: i64) -> i64 effects[state] =
  let ad: bool = k >= a.n in
  let bd: bool = k >= b.n in
  if ad then (if bd then 0 else (0 - 1))
  else if bd then 1
  else
    let x: i64 = to_i64(a.b[k]) in
    let y: i64 = to_i64(b.b[k]) in
    if x < y then (0 - 1) else if x > y then 1 else color_cmp_at(a, b, k + 1)

fn color_lt(a: Color, b: Color) -> bool effects[state] =
  color_cmp_at(a, b, 0) < 0

// Copy-colour equality (same length and bytes); recursive, no threading (Color is Copy).
fn color_eq_at(a: Color, b: Color, k: i64) -> bool effects[state] =
  if k >= a.n then true
  else if to_i64(a.b[k]) == to_i64(b.b[k]) then color_eq_at(a, b, k + 1)
  else false

fn color_eq(a: Color, b: Color) -> bool effects[state] =
  if a.n == b.n then color_eq_at(a, b, 0) else false

// Distinct-colour count of three Copy colours: 1 (all equal), 2 (exactly one pair), or 3 (all
// distinct). With three elements two equal pairs force the third, so there is no "2 pairs" case.
fn distinct3(c0: Color, c1: Color, c2: Color) -> i64 effects[state] =
  let e01: bool = color_eq(c0, c1) in
  let e02: bool = color_eq(c0, c2) in
  let e12: bool = color_eq(c1, c2) in
  if e01 && e12 then 1
  else if e01 || e02 || e12 then 2
  else 3

// Recolour a raw body RECURSIVELY for the THREE-member case: each peer call `<name>` is rewritten
// to `@recursion-peer:<colour of that member>` (cols.c0 if the name equals member 0's name, c1 if
// member 1's, else member 2's — every call in a pure 3-clique body is a peer). Generalizes the
// two-member recolor_at: the three names ride as a Copy Names3 bundle (branch-free match) and the
// three current colours as a Copy Cols3 (branch-free select), so only `out`/`raw` are move-only.
// The call-node marker is `"kind":"call"` (13 bytes, arg-independent); `,"name":"` follows, so the
// name begins at i+22. mirrors recolor_at's char-by-char copy + next-`"` scan.
fn recolor_at3(raw: string, names: Names3, cols: Cols3, i: i64, rawlen: i64, out: string) -> string effects[state] =
  if i >= rawlen then out
  else
    let iscall: bool =
      if i + 22 <= rawlen then
        (to_i64(string_get(raw, i)) == 34 && to_i64(string_get(raw, i + 1)) == 107
         && to_i64(string_get(raw, i + 2)) == 105 && to_i64(string_get(raw, i + 3)) == 110
         && to_i64(string_get(raw, i + 4)) == 100 && to_i64(string_get(raw, i + 5)) == 34
         && to_i64(string_get(raw, i + 6)) == 58 && to_i64(string_get(raw, i + 7)) == 34
         && to_i64(string_get(raw, i + 8)) == 99 && to_i64(string_get(raw, i + 9)) == 97
         && to_i64(string_get(raw, i + 10)) == 108 && to_i64(string_get(raw, i + 11)) == 108
         && to_i64(string_get(raw, i + 12)) == 34)
      else false
    in
    if iscall then
      // name at [i+22, jq); jq = the next `"` (past `"kind":"call","name":"`).
      let fq: Lc =
        loop k = { j: i + 22, c: 2 } while k.c == 2 do
          if k.j >= rawlen then (let s: Lc = { j: k.j, c: 0 } in s)
          else if to_i64(string_get(raw, k.j)) == 34 then (let s: Lc = { j: k.j, c: 1 } in s)
          else (let s: Lc = { j: k.j + 1, c: 2 } in s)
      in
      let jq: i64 = fq.j in
      let mm0: MatchR = match_name(raw, i + 22, jq, names.n0) in
      let mm1: MatchR = match_name(mm0.raw, i + 22, jq, names.n1) in
      let raw2: string = mm1.raw in
      let cc: Color = if mm0.hit then cols.c0 else if mm1.hit then cols.c1 else cols.c2 in
      let o1: string = push_lit(out, b"\"kind\":\"call\",\"name\":\"@recursion-peer:") in
      let o2: string = push_color(o1, cc, 0) in
      recolor_at3(raw2, names, cols, jq, rawlen, o2)
    else
      let byte: u8 = string_get(raw, i) in
      recolor_at3(raw, names, cols, i + 1, rawlen, push_byte(out, byte))

fn recolor3(raw: string, names: Names3, cols: Cols3) -> string effects[alloc, state] =
  let rawlen: i64 = string_len(raw) in
  // round-2/3 each rewrite a call name to `@recursion-peer:`+a 71-byte colour; rawlen*4 bounds it.
  let out: string = string_with_capacity(rawlen * 4 + 256) in
  recolor_at3(raw, names, cols, 0, rawlen, out)

// One member's WL colour as Copy bytes: hash("codedb/recursion-order/v1\0" | static_sig | erased
// body) where the erased body recolours peer calls with the given current colours. Generalizes
// member_color (two-member). mem threaded back; the payload is built in a FRESH sized buffer
// (appending onto build_rec_sig's fixed buffer would overflow it).
fn member_color3(mem: string, sl: Sl, names: Names3, cols: Cols3, len: i64) -> MC3 effects[alloc, state] =
  let rb: Rr = raw_bitor(mem, sl.bs, len) in
  let pr: PpR = derive_params(rb.mem, sl.ne, len) in
  let mp: string = pr.mem in
  let er: string = recolor3(rb.raw, names, cols) in
  let sig: string = build_rec_sig(sl.rtc, pr.ps) in
  let siglen: i64 = string_len(sig) in
  let erlen: i64 = string_len(er) in
  let p0: string = string_with_capacity(siglen + erlen + 8) in
  let p1: string = push_str(p0, sig) in
  let p2: string = push_byte(p1, to_u8(124)) in
  let p3: string = push_str(p2, er) in
  let h: string = hash_domain(b"codedb/recursion-order/v1\0", p3) in
  let col: Color = to_color(h) in
  let r: MC3 = { mem: mp, col: col } in r

// One WL refinement round: the three members' colours (source order spans[0..2]) given the current
// peer colours `cols`. mem threaded through the three member_color3 calls.
fn three_colours(mem: string, spans: array<i64, 32>, names: Names3, cols: Cols3, len: i64) -> ThreeC effects[alloc, state] =
  let a: MC3 = member_color3(mem, sl_at(spans, 0), names, cols, len) in
  let b: MC3 = member_color3(a.mem, sl_at(spans, 1), names, cols, len) in
  let c: MC3 = member_color3(b.mem, sl_at(spans, 2), names, cols, len) in
  let r: ThreeC = { mem: c.mem, q0: a.col, q1: b.col, q2: c.col } in r

// One WL refinement round, returning the three colours as a Copy Cols3 + their distinct count +
// mem (a RoundR). The move-only ThreeC stays in this frame, so clique3_colours holds only RoundRs.
fn wl_round(mem: string, spans: array<i64, 32>, names: Names3, peer: Cols3, len: i64) -> RoundR effects[alloc, state] =
  let t: ThreeC = three_colours(mem, spans, names, peer, len) in
  let cols: Cols3 = { c0: t.q0, c1: t.q1, c2: t.q2 } in
  let m: string = t.mem in
  let nc: i64 = distinct3(cols.c0, cols.c1, cols.c2) in
  let r: RoundR = { mem: m, cols: cols, nc: nc } in r

// The optional THIRD round: if the distinct-colour count grew from round 1 to round 2 (need3),
// refine once more (the n = 3 loop limit); otherwise the round-2 colours `peer` (count `prevnc`)
// have converged, so pass them through unchanged. A conditional of a whole call vs a let-bound
// record literal (no string building in the branch — the v0 aggregate-return rule).
fn wl_round3(need3: bool, prevnc: i64, mem: string, spans: array<i64, 32>, names: Names3, peer: Cols3, len: i64) -> RoundR effects[alloc, state] =
  if need3 then wl_round(mem, spans, names, peer, len)
  else (let r: RoundR = { mem: mem, cols: peer, nc: prevnc } in r)

// Pack the three clique member names (source order) into a Copy Names3, threading mem back — in its
// own frame so the slice_to_str/to_name temporaries do not inflate clique3_colours.
fn build_names3(mem: string, spans: array<i64, 32>) -> NamesR effects[alloc, state] =
  let sl0: Sl = sl_at(spans, 0) in
  let sl1: Sl = sl_at(spans, 1) in
  let sl2: Sl = sl_at(spans, 2) in
  let na: PRR = slice_to_str(mem, sl0.ns, sl0.ne) in
  let nm0: Name = to_name(na.out) in
  let nb: PRR = slice_to_str(na.mem, sl1.ns, sl1.ne) in
  let nm1: Name = to_name(nb.out) in
  let ncc: PRR = slice_to_str(nb.mem, sl2.ns, sl2.ne) in
  let nm2: Name = to_name(ncc.out) in
  let names: Names3 = { n0: nm0, n1: nm1, n2: nm2 } in
  let r: NamesR = { mem: ncc.mem, names: names } in r

// Rounds 1 and 2 of the refinement (round 1 with empty peer colours, round 2 with the round-1
// colours), returning round 2's colours + count + whether the count grew (-> a third round is
// needed). Holds the two RoundRs in its frame so clique3_colours stays small.
fn wl_two(mem: string, spans: array<i64, 32>, names: Names3, len: i64) -> TwoR effects[alloc, state] =
  let empty: Color = { b: [0x0; 72], n: 0 } in
  let ec: Cols3 = { c0: empty, c1: empty, c2: empty } in
  let r1: RoundR = wl_round(mem, spans, names, ec, len) in
  let r2: RoundR = wl_round(r1.mem, spans, names, r1.cols, len) in
  let need3: bool = r2.nc != r1.nc in
  let r: TwoR = { mem: r2.mem, cols: r2.cols, nc: r2.nc, need3: need3 } in r

// Run the 1-WL refinement (unrolled: rounds 1+2 in wl_two, an optional round 3 — at most n = 3
// rounds, matching refine_clique_colors' "break when the distinct-colour count stabilizes").
// Returns the three converged colours (source order), whether they discretize the clique, and mem.
// Unrolled (not a loop) so the move-only colour threading never forms a loop accumulator (the
// v0-hazardous construct the de-risk flagged); the heavy per-round work lives in wl_two/wl_round.
fn clique3_colours(mem: string, spans: array<i64, 32>, len: i64) -> ColRes effects[alloc, state] =
  let nr: NamesR = build_names3(mem, spans) in
  let names: Names3 = nr.names in
  let nmem: string = nr.mem in
  let tw: TwoR = wl_two(nmem, spans, names, len) in
  let fin: RoundR = wl_round3(tw.need3, tw.nc, tw.mem, spans, names, tw.cols, len) in
  let fc: Cols3 = fin.cols in
  let fmem: string = fin.mem in
  let nd: i64 = fin.nc in
  let r: ColRes = { mem: fmem, disc: nd == 3, q0: fc.c0, q1: fc.c1, q2: fc.c2 } in r

// Given the three converged colours (source order), derive the recursion-group ordinals and the
// packed alpha-rank -> ordinal map. ordinal(i) = #{ j : colour_j < colour_i }; s0/s1/s2 = the
// SOURCE index at ordinal 0/1/2. The packed `aord` (base 4: ord(alpha0) + ord(alpha1)*4 +
// ord(alpha2)*16) lets parse_call map a callee's alphabetical rank (clique_rank) to its ordinal —
// the n-member generalization of the two-member aord. Three name_le comparisons give the alpha order.
fn clique3_ordinals(mem: string, spans: array<i64, 32>, q0: Color, q1: Color, q2: Color) -> Clq3 effects[alloc, state] =
  let sl0: Sl = sl_at(spans, 0) in
  let sl1: Sl = sl_at(spans, 1) in
  let sl2: Sl = sl_at(spans, 2) in
  let o0: i64 = (if color_lt(q1, q0) then 1 else 0) + (if color_lt(q2, q0) then 1 else 0) in
  let o1: i64 = (if color_lt(q0, q1) then 1 else 0) + (if color_lt(q2, q1) then 1 else 0) in
  let o2: i64 = (if color_lt(q0, q2) then 1 else 0) + (if color_lt(q1, q2) then 1 else 0) in
  let s0: i64 = if o0 == 0 then 0 else if o1 == 0 then 1 else 2 in
  let s1: i64 = if o0 == 1 then 0 else if o1 == 1 then 1 else 2 in
  let s2: i64 = if o0 == 2 then 0 else if o1 == 2 then 1 else 2 in
  let a01r: REq = name_le(mem, sl0.ns, sl0.ne, sl1.ns, sl1.ne) in
  let a01: bool = a01r.eq in
  let a02r: REq = name_le(a01r.mem, sl0.ns, sl0.ne, sl2.ns, sl2.ne) in
  let a02: bool = a02r.eq in
  let a12r: REq = name_le(a02r.mem, sl1.ns, sl1.ne, sl2.ns, sl2.ne) in
  let a12: bool = a12r.eq in
  let mg: string = a12r.mem in
  let ar0: i64 = (if a01 then 0 else 1) + (if a02 then 0 else 1) in
  let ar1: i64 = (if a01 then 1 else 0) + (if a12 then 0 else 1) in
  let ar2: i64 = (if a02 then 1 else 0) + (if a12 then 1 else 0) in
  let as0: i64 = if ar0 == 0 then 0 else if ar1 == 0 then 1 else 2 in
  let as1: i64 = if ar0 == 1 then 0 else if ar1 == 1 then 1 else 2 in
  let as2: i64 = if ar0 == 2 then 0 else if ar1 == 2 then 1 else 2 in
  let oas0: i64 = if as0 == 0 then o0 else if as0 == 1 then o1 else o2 in
  let oas1: i64 = if as1 == 0 then o0 else if as1 == 1 then o1 else o2 in
  let oas2: i64 = if as2 == 0 then o0 else if as2 == 1 then o1 else o2 in
  let aord: i64 = oas0 + oas1 * 4 + oas2 * 16 in
  let r: Clq3 = { mem: mg, disc: true, s0: s0, s1: s1, s2: s2, aord: aord } in r

// Determine the canonical (WL) ordering of a three-member clique: refine, and if discretizing
// derive the ordinals + packed aord; otherwise return disc = false (a symmetric/non-discretizing
// clique -> clique_label_search, deferred to Inc 4). mem threaded back.
fn clique3_order(mem: string, spans: array<i64, 32>, len: i64) -> Clq3 effects[alloc, state] =
  let cr: ColRes = clique3_colours(mem, spans, len) in
  if cr.disc then clique3_ordinals(cr.mem, spans, cr.q0, cr.q1, cr.q2)
  else (let r: Clq3 = { mem: cr.mem, disc: false, s0: 0, s1: 0, s2: 0, aord: 0 } in r)

// A THREE-member RecursionGroup object {"members":[{def,sig,sym}_0,_1,_2],"module":"main"} (members
// in ordinal/canonical order; member key order definition,signature,symbol). Reads each member's
// 71-char hashes as slices of the concatenated ordinal-order accumulators (defs/sigs/syms),
// threading them back (they reappear in the ProgramRoot's symbols array). Generalizes
// build_recursion_group2 (two members) to three.
fn build_recursion_group3(defs: string, sigs: string, syms: string) -> RG3 effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(960), b"{\"members\":[{\"definition\":\"") in
  let a0: PRR = push_range(p0, defs, 0, 71) in
  let p1: string = push_lit(a0.out, b"\",\"signature\":\"") in
  let b0: PRR = push_range(p1, sigs, 0, 71) in
  let p2: string = push_lit(b0.out, b"\",\"symbol\":\"") in
  let c0: PRR = push_range(p2, syms, 0, 71) in
  let p3: string = push_lit(c0.out, b"\"},{\"definition\":\"") in
  let a1: PRR = push_range(p3, a0.mem, 71, 142) in
  let p4: string = push_lit(a1.out, b"\",\"signature\":\"") in
  let b1: PRR = push_range(p4, b0.mem, 71, 142) in
  let p5: string = push_lit(b1.out, b"\",\"symbol\":\"") in
  let c1: PRR = push_range(p5, c0.mem, 71, 142) in
  let p6: string = push_lit(c1.out, b"\"},{\"definition\":\"") in
  let a2: PRR = push_range(p6, a1.mem, 142, 213) in
  let p7: string = push_lit(a2.out, b"\",\"signature\":\"") in
  let b2: PRR = push_range(p7, b1.mem, 142, 213) in
  let p8: string = push_lit(b2.out, b"\",\"symbol\":\"") in
  let c2: PRR = push_range(p8, c1.mem, 142, 213) in
  let p9: string = push_lit(c2.out, b"\"}],\"module\":\"main\"}") in
  let h: string = hash_object(b"RecursionGroup", 1, p9) in
  let r: RG3 = { rg: h, defs: a2.mem, sigs: b2.mem, syms: c2.mem } in r

// Concatenate three move-only strings into a fresh buffer (consuming all three).
fn concat3(a: string, b: string, c: string) -> string effects[alloc, state] =
  concat2(concat2(a, b), c)

// Build the ordinal-position permutation array (perm[k] = source index of WL ordinal k) and the
// param-name cumulative-offset table, each in its own frame so the chained array writes stay off
// build_clique3_root's stack (set_span's lesson).
fn perm3(s0: i64, s1: i64, s2: i64) -> array<i64, 8> =
  array_set(array_set(array_set([0x0; 8], 0, s0), 1, s1), 2, s2)

fn pnoff3(l0: i64, l1: i64, l2: i64) -> array<i64, 9> =
  array_set(array_set(array_set([0x0; 9], 1, l0), 2, l0 + l1), 3, l0 + l1 + l2)

// Build the three members' objects in WL-ordinal order (symbol recursion_group:<ord>, body
// re-parsed with rgord = ord + the packed aord so cross-member calls resolve to each callee's
// ordinal), concatenate the four ordinal-order accumulators, and build the RecursionGroup object —
// returning the pieces the root assembler needs. Factored out of build_clique3_root so the three
// FObj + concat temporaries live in THIS frame, not the root builder's (the v0 budget).
fn build_clique3_members(mem: string, cspans: array<i64, 32>, aord: i64, len: i64) -> Clq3M effects[alloc, state] =
  let fa: FObj = build_rg_member(mem, sl_at(cspans, 0), 0, aord, len) in
  let fb: FObj = build_rg_member(fa.mem, sl_at(cspans, 1), 1, aord, len) in
  let fc: FObj = build_rg_member(fb.mem, sl_at(cspans, 2), 2, aord, len) in
  let l0: i64 = string_len(fa.pn) in
  let l1: i64 = string_len(fb.pn) in
  let l2: i64 = string_len(fc.pn) in
  let pnoff: array<i64, 9> = pnoff3(l0, l1, l2) in
  let syms: string = concat3(fa.sym, fb.sym, fc.sym) in
  let defs: string = concat3(fa.def, fb.def, fc.def) in
  let sigs: string = concat3(fa.sig, fb.sig, fc.sig) in
  let pns: string = concat3(fa.pn, fb.pn, fc.pn) in
  let rg: RG3 = build_recursion_group3(defs, sigs, syms) in
  let r: Clq3M = { mem: fc.mem, syms: rg.syms, defs: rg.defs, sigs: rg.sigs, pns: pns, rg: rg.rg, pnoff: pnoff } in r

// Build the ProgramRoot for a three-member DISCRETIZING recursion clique (the importer's output
// root). order the members by the WL refinement (clique3_order); if it does NOT discretize, the
// clique is symmetric (clique_label_search territory) -> DEFER to import_one_or_two (a defined
// no-crash fallback, not a correct build). Otherwise build the members (build_clique3_members), then
// assemble the root (names display-order, param_names/symbols hash-order via the shared
// assemble_clique_root). Both births are genesis (one create_recursion_group migration), so the
// root is reproduced from objects alone — no migration/history chain.
fn build_clique3_root(mem: string, spans: array<i64, 32>, len: i64) -> string effects[alloc, state] =
  let co: Clq3 = clique3_order(mem, spans, len) in
  if co.disc then
    let cspans: array<i64, 32> = reorder_spans(spans, perm3(co.s0, co.s1, co.s2), 3) in
    let cm: Clq3M = build_clique3_members(co.mem, cspans, co.aord, len) in
    let rin: RootStr = { mem: cm.mem, syms: cm.syms, defs: cm.defs, sigs: cm.sigs, pns: cm.pns } in
    assemble_clique_root(rin, cspans, cm.pnoff, 3, cm.rg)
  else
    import_one_or_two(co.mem, len)

// Build the three content hashes for one no-param `fn <name>() -> <rtc> = <body>`: its
// SymbolBirth (birth history `bh`, ordinal `ordv`), its body Expression (RE-PARSED from the
// source span `sl.bs` with the typed parser, expecting the return type `sl.rtc` — bodies may
// be any expression now, not just a literal), and its FunctionSignature (return `sl.rtc`),
// combined into a FunctionDef. Returns the SymbolBirth/FunctionDef/FunctionSignature hashes
// (plus the param-name fragment `pn` for the ProgramRoot's param_names) with `mem` threaded
// back. Rebuilt (deterministic) rather than threaded across the two ProgramRoots that consume
// it. The parameter scope is RE-DERIVED from source (find the `(` past the name, scan_params),
// so the body resolves param_refs and the signature/param_names carry the parameters; rgord =
// -1 (a create_function, not a recursion member).
fn build_fn_objs(mem: string, sl: Sl, bh: string, ordv: i64) -> FObj effects[alloc, state] =
  let s: MH = build_sym_at(bh, mem, sl, ordv) in
  let m1: string = s.mem in
  let symh: string = s.hash in
  let len: i64 = string_len(m1) in
  let op: MI = find_byte(m1, sl.ne, len, 40) in
  let seed: Scope = { ids: [0x0; 12], n: 0, rgord: 0 - 1, aord: 0 } in
  let pr: PpR = scan_params(op.mem, op.i, len, seed) in
  let mp: string = pr.mem in
  let params: Scope = pr.ps in
  let np: i64 = params.n in
  let e: Pr = parse_bitor(mp, sl.bs, len, params, np, sl.rtc) in
  let m2: string = e.mem in
  let exprh: string = e.hash in
  let sig: string = build_sig(sl.rtc, params) in
  let pnr: PRR = push_pnames_at(string_with_capacity(sl.bs - op.i + 16), m2, params, 0) in
  let m3: string = pnr.mem in
  let d: DH = build_def(sig, symh, exprh) in
  let r: FObj = { mem: m3, sym: d.sym, def: d.h, sig: d.sig, pn: pnr.out } in r

// Like build_fn_objs but for a function whose body may reference an EXTRA callee (a non-first
// canonical function in a DAG). `aug` is the source with a small extra-callee table appended
// (sym1 + ord1 name); `slen` is the SOURCE length, used as the parse bound everywhere (so the
// parser never reads the table — only parse_call peeks past `slen` via string_len(aug) > slen).
// Identical to build_fn_objs except `len` is the passed `slen` rather than string_len(aug).
fn build_fn_objs_xc(aug: string, slen: i64, sl: Sl, bh: string, ordv: i64) -> FObj effects[alloc, state] =
  let s: MH = build_sym_at(bh, aug, sl, ordv) in
  let m1: string = s.mem in
  let symh: string = s.hash in
  let len: i64 = slen in
  let op: MI = find_byte(m1, sl.ne, len, 40) in
  let seed: Scope = { ids: [0x0; 12], n: 0, rgord: 0 - 1, aord: 0 } in
  let pr: PpR = scan_params(op.mem, op.i, len, seed) in
  let mp: string = pr.mem in
  let params: Scope = pr.ps in
  let np: i64 = params.n in
  let e: Pr = parse_bitor(mp, sl.bs, len, params, np, sl.rtc) in
  let m2: string = e.mem in
  let exprh: string = e.hash in
  let sig: string = build_sig(sl.rtc, params) in
  let pnr: PRR = push_pnames_at(string_with_capacity(sl.bs - op.i + 16), m2, params, 0) in
  let m3: string = pnr.mem in
  let d: DH = build_def(sig, symh, exprh) in
  let r: FObj = { mem: m3, sym: d.sym, def: d.h, sig: d.sig, pn: pnr.out } in r

// Build a ProgramRoot over a single function `sl` (the first migration's output_root):
// one names/param_names/symbols entry each. The symbol hash appears three times, so it
// is threaded via push_kept. Returns the root hash with `mem` threaded back.
fn build_root1(mem: string, sl: Sl) -> MH effects[alloc, state] =
  let gstr: string = push_lit(string_with_capacity(16), b"genesis") in
  let fo: FObj = build_fn_objs(mem, sl, gstr, 0) in
  let m1: string = fo.mem in
  let sym: string = fo.sym in
  let def: string = fo.def in
  let sig: string = fo.sig in
  let pnf: string = fo.pn in
  let p0: string = push_lit(string_with_capacity(1024), b"{\"metadata\":{},\"names\":[{\"display_name\":\"") in
  let pn: PRR = push_range(p0, m1, sl.ns, sl.ne) in
  let p1: string = pn.out in
  let m2: string = pn.mem in
  let p2: string = push_lit(p1, b"\",\"is_preferred\":true,\"module\":\"main\",\"symbol\":\"") in
  let k1: OS = push_kept(p2, sym) in
  let p3: string = k1.out in
  let sym1: string = k1.s in
  let p4a: string = push_lit(p3, b"\"}],\"param_names\":[{\"names\":[") in
  let p4b: string = push_str(p4a, pnf) in
  let p4: string = push_lit(p4b, b"],\"symbol\":\"") in
  let k2: OS = push_kept(p4, sym1) in
  let p5: string = k2.out in
  let sym2: string = k2.s in
  let p6: string = push_lit(p5, b"\"}],\"symbols\":[{\"definition\":\"") in
  let p7: string = push_str(p6, def) in
  let p8: string = push_lit(p7, b"\",\"signature\":\"") in
  let p9: string = push_str(p8, sig) in
  let p10: string = push_lit(p9, b"\",\"symbol\":\"") in
  let p11: string = push_str(p10, sym2) in
  let p12: string = push_lit(p11, b"\"}]}") in
  let h: string = hash_object(b"ProgramRoot", 1, p12) in
  let r: MH = { mem: m2, hash: h } in r

// Lexicographically compare two symbol-hash strings `a`, `b` (each "sha256:" + 64 hex,
// length 71); return le = true iff a <= b, with both operands threaded back out. Used to
// order the ProgramRoot's symbol-hash-sorted arrays.
fn sym_le(a: string, b: string) -> CmpS =
  let done: Lc =
    loop k = { j: 0, c: 2 } while k.c == 2 do
      if k.j >= 71 then (let s: Lc = { j: k.j, c: 3 } in s)
      else
        let ca: i64 = to_i64(string_get(a, k.j)) in
        let cb: i64 = to_i64(string_get(b, k.j)) in
        if ca < cb then (let s: Lc = { j: k.j, c: 0 } in s)
        else if ca > cb then (let s: Lc = { j: k.j, c: 1 } in s)
        else (let s: Lc = { j: k.j + 1, c: 2 } in s)
  in
  let le: bool = done.c != 1 in
  let r: CmpS = { le: le, a: a, b: b } in r

// Order two functions' (sym, def, sig) triples by symbol hash: if `le` (symbol A <= B)
// keep A first, else swap. Both branches consume all six strings into the result record.
fn order_triples(le: bool, sA: string, dA: string, gA: string, sB: string, dB: string, gB: string) -> Six =
  if le then (let r: Six = { s0: sA, d0: dA, g0: gA, s1: sB, d1: dB, g1: gB } in r)
  else (let r: Six = { s0: sB, d0: dB, g0: gB, s1: sA, d1: dA, g1: gA } in r)

// Route two (move-only) param-name fragments through ONE conditional in parallel with the
// (sym, def, sig) triple ordering, so each fragment stays paired with its function's symbol
// across a swap (a plain `if le then a else b` would move `a` in one branch and leave it
// dangling in the other — both must be consumed exactly once, hence the single conditional).
fn order_pp(le: bool, a: string, b: string) -> PP =
  if le then (let r: PP = { p0: a, p1: b } in r)
  else (let r: PP = { p0: b, p1: a } in r)

// Build the final ProgramRoot over the two functions in canonical order (`first`,
// `second`), the importer's output root. Each function's objects are rebuilt here (first
// with birth history "genesis"/ordinal 0, second with `hh1`/ordinal 1); each symbol hash
// appears three times (names, param_names, symbols) and is threaded via push_kept. The TWO
// arrays use DIFFERENT sort keys (src/model.rs normalize_root): `names` is ordered by display
// name (via r2_names), while `param_names`/`symbols` are ordered by SYMBOL HASH (via sym_le +
// order_triples). The two coincide only when canonical order matches alphabetical order, so
// with cross-symbol calls (toposort ≠ alphabetical) they must be sorted independently. The
// assembly is split into a head (names) and a tail (param_names + symbols) for the frame budget.
fn build_root2(mem: string, first: Sl, second: Sl, hh1: string) -> string effects[alloc, state] =
  let gstr: string = push_lit(string_with_capacity(16), b"genesis") in
  let foA: FObj = build_fn_objs(mem, first, gstr, 0) in
  let mA: string = foA.mem in
  let symA: string = foA.sym in
  let defA: string = foA.def in
  let sigA: string = foA.sig in
  let pnA: string = foA.pn in
  let foB: FObj = build_fn_objs(mA, second, hh1, 1) in
  let mB: string = foB.mem in
  let symB: string = foB.sym in
  let defB: string = foB.def in
  let sigB: string = foB.sig in
  let pnB: string = foB.pn in
  // The `names` array is display-name-ordered, but param_names/symbols are symbol-hash-ordered
  // (src/model.rs normalize_root) — they differ once canonical order (toposort) ≠ alphabetical.
  // Reuse order_triples (the proven move-into-record helper) to put the (sym,def,sig) triples in
  // DISPLAY order, emit the names array UNCONDITIONALLY in that order (string-building inside a
  // record-returning conditional miscompiles to a v0 SIGTRAP — keep conditionals to pure moves),
  // then re-order the same triples by symbol hash for the tail. Name ranges are Copy, so they are
  // selected with plain `if`; the display-low name pairs with the display-low triple's symbol. The
  // param-name fragments ride along in DISPLAY order too (order_pp, paralleling order_triples), to
  // be re-sorted by symbol hash with the triples in the tail (param_names is hash-ordered).
  let nlec: REq = name_le(mB, first.ns, first.ne, second.ns, second.ne) in
  let mC: string = nlec.mem in
  let nle: bool = nlec.eq in
  let dsix: Six = order_triples(nle, symA, defA, sigA, symB, defB, sigB) in
  let dpp: PP = order_pp(nle, pnA, pnB) in
  // display-low name pairs with dsix.s0, display-high with dsix.s1 (Copy selects).
  let lns: i64 = if nle then first.ns else second.ns in
  let lne: i64 = if nle then first.ne else second.ne in
  let hns: i64 = if nle then second.ns else first.ns in
  let hne: i64 = if nle then second.ne else first.ne in
  // emit names + the hash-ordered tail in a helper (off build_root2's stack frame).
  build_root2_names(mC, lns, lne, hns, hne, dsix, dpp)

// Emit the two-function ProgramRoot's `names` array (DISPLAY order, the triples already so
// ordered in `dsix`), then re-order the same (sym, def, sig) triples by SYMBOL HASH and hand
// off to the tail for param_names/symbols. Split from build_root2 for the v0 frame budget; the
// `names` emission is UNCONDITIONAL (the display ordering already happened, purely, in dsix).
fn build_root2_names(mem: string, lns: i64, lne: i64, hns: i64, hne: i64, dsix: Six, dpp: PP) -> string effects[alloc, state] =
  let ds0: string = dsix.s0 in
  let dd0: string = dsix.d0 in
  let dg0: string = dsix.g0 in
  let ds1: string = dsix.s1 in
  let dd1: string = dsix.d1 in
  let dg1: string = dsix.g1 in
  let dp0: string = dpp.p0 in
  let dp1: string = dpp.p1 in
  let p0: string = push_lit(string_with_capacity(2048), b"{\"metadata\":{},\"names\":[{\"display_name\":\"") in
  let na: PRR = push_range(p0, mem, lns, lne) in
  let p1: string = push_lit(na.out, b"\",\"is_preferred\":true,\"module\":\"main\",\"symbol\":\"") in
  let k0: OS = push_kept(p1, ds0) in
  let p2: string = push_lit(k0.out, b"\"},{\"display_name\":\"") in
  let nb: PRR = push_range(p2, na.mem, hns, hne) in
  let p3: string = push_lit(nb.out, b"\",\"is_preferred\":true,\"module\":\"main\",\"symbol\":\"") in
  let k1: OS = push_kept(p3, ds1) in
  let p6: string = push_lit(k1.out, b"\"}]") in
  let s0k: string = k0.s in
  let s1k: string = k1.s in
  let cmp: CmpS = sym_le(s0k, s1k) in
  let le: bool = cmp.le in
  let sA2: string = cmp.a in
  let sB2: string = cmp.b in
  let six: Six = order_triples(le, sA2, dd0, dg0, sB2, dd1, dg1) in
  // re-order the param-name fragments by symbol hash too (same `le`), so each pairs with its
  // hash-ordered symbol in the tail's param_names array.
  let hpp: PP = order_pp(le, dp0, dp1) in
  build_root2_tail(p6, six, hpp)

// The param_names and symbols arrays (and the closing brace) of the two-function
// ProgramRoot, taking the partial buffer (names already closed), the (sym, def, sig)
// triples PRE-ORDERED by symbol hash, and the matching hash-ordered param-name fragments
// (`hpp`). Split from the head to stay under the frame budget.
fn build_root2_tail(buf: string, six: Six, hpp: PP) -> string effects[alloc, state] =
  let s0: string = six.s0 in
  let d0: string = six.d0 in
  let g0: string = six.g0 in
  let s1: string = six.s1 in
  let d1: string = six.d1 in
  let g1: string = six.g1 in
  let hp0: string = hpp.p0 in
  let hp1: string = hpp.p1 in
  let u0a: string = push_lit(buf, b",\"param_names\":[{\"names\":[") in
  let u0b: string = push_str(u0a, hp0) in
  let u0: string = push_lit(u0b, b"],\"symbol\":\"") in
  let k0: OS = push_kept(u0, s0) in
  let u1: string = k0.out in
  let s0a: string = k0.s in
  let u2a: string = push_lit(u1, b"\"},{\"names\":[") in
  let u2b: string = push_str(u2a, hp1) in
  let u2: string = push_lit(u2b, b"],\"symbol\":\"") in
  let k1: OS = push_kept(u2, s1) in
  let u3: string = k1.out in
  let s1a: string = k1.s in
  let u4: string = push_lit(u3, b"\"}],\"symbols\":[{\"definition\":\"") in
  let t0: string = push_str(u4, d0) in
  let t1: string = push_lit(t0, b"\",\"signature\":\"") in
  let t2: string = push_str(t1, g0) in
  let t3: string = push_lit(t2, b"\",\"symbol\":\"") in
  let t4: string = push_str(t3, s0a) in
  let t5: string = push_lit(t4, b"\"},{\"definition\":\"") in
  let t6: string = push_str(t5, d1) in
  let t7: string = push_lit(t6, b"\",\"signature\":\"") in
  let t8: string = push_str(t7, g1) in
  let t9: string = push_lit(t8, b"\",\"symbol\":\"") in
  let t10: string = push_str(t9, s1a) in
  let t11: string = push_lit(t10, b"\"}]}") in
  hash_object(b"ProgramRoot", 1, t11)

// Selection sort of [0, m) by the 71-char `syms`-slice ascending -> the HASH-order
// permutation (for the symbols/param_names arrays). Copy accumulators throughout; `syms`
// is owned and read by `string_get` (never moved) and threaded back out.
fn hash_perm(syms: string, m: i64) -> PermS effects[alloc, state] =
  let oseed: SortA = { perm: [0x0; 8], used: 0, p: 0 } in
  let done: SortA =
    loop o = oseed while o.p < m do
      let cur: SortA = o in
      let bseed: BestA = { best: 0 - 1, i: 0 } in
      let br: BestA =
        loop a = bseed while a.i < m do
          let inner: BestA = a in
          let isused: bool = ((cur.used >> inner.i) & 1) == 1 in
          if isused then (let r: BestA = { best: inner.best, i: inner.i + 1 } in r)
          else if inner.best < 0 then (let r: BestA = { best: inner.i, i: inner.i + 1 } in r)
          else
            let aoff: i64 = inner.i * 71 in
            let boff: i64 = inner.best * 71 in
            let cseed: Lc = { j: 0, c: 2 } in
            let cmp: Lc =
              loop c = cseed while c.c == 2 do
                if c.j >= 71 then (let s: Lc = { j: c.j, c: 3 } in s)
                else
                  let ca: i64 = to_i64(string_get(syms, aoff + c.j)) in
                  let cb: i64 = to_i64(string_get(syms, boff + c.j)) in
                  if ca < cb then (let s: Lc = { j: c.j, c: 0 } in s)
                  else if ca > cb then (let s: Lc = { j: c.j, c: 1 } in s)
                  else (let s: Lc = { j: c.j + 1, c: 2 } in s)
            in
            let nb: i64 = if cmp.c == 0 then inner.i else inner.best in
            (let r: BestA = { best: nb, i: inner.i + 1 } in r)
      in
      let np: array<i64, 8> = array_set(cur.perm, cur.p, br.best) in
      let nu: i64 = cur.used | (1 << br.best) in
      (let r: SortA = { perm: np, used: nu, p: cur.p + 1 } in r)
  in
  let res: PermS = { perm: done.perm, s: syms } in res

// Selection sort of [0, m) by display name `mem`[ns, ne) ascending -> the DISPLAY-order
// permutation (for the names array). Same shape as hash_perm; the compare is name_le's
// (prefix-is-smaller). `spans` packs (ns, ne, bs, rtc) for index k at spans[4k..4k+3].
fn disp_perm(mem: string, spans: array<i64, 32>, m: i64) -> PermM effects[alloc, state] =
  let oseed: DOut = { perm: [0x0; 8], used: 0, p: 0, mem: mem } in
  let done: DOut =
    loop o = oseed while o.p < m do
      let cur: DOut = o in
      let iseed: DMin = { best: 0 - 1, i: 0, mem: cur.mem } in
      let br: DMin =
        loop a = iseed while a.i < m do
          let inner: DMin = a in
          let isused: bool = ((cur.used >> inner.i) & 1) == 1 in
          if isused then (let r: DMin = { best: inner.best, i: inner.i + 1, mem: inner.mem } in r)
          else if inner.best < 0 then (let r: DMin = { best: inner.i, i: inner.i + 1, mem: inner.mem } in r)
          else
            // reuse name_le (prefix-is-smaller, threads mem) so the byte-compare frame lives
            // in name_le, not here; le = (name[i] <= name[best]) keeps the smaller index.
            let ab: i64 = inner.i * 4 in
            let bb: i64 = inner.best * 4 in
            let le: REq = name_le(inner.mem, spans[ab], spans[ab + 1], spans[bb], spans[bb + 1]) in
            let nb: i64 = if le.eq then inner.i else inner.best in
            (let r: DMin = { best: nb, i: inner.i + 1, mem: le.mem } in r)
      in
      let np: array<i64, 8> = array_set(cur.perm, cur.p, br.best) in
      let nu: i64 = cur.used | (1 << br.best) in
      (let r: DOut = { perm: np, used: nu, p: cur.p + 1, mem: br.mem } in r)
  in
  let res: PermM = { perm: done.perm, mem: done.mem } in res

// Emit the `names` array entries (DISPLAY order via `dperm`) into `buf` (which already holds
// the `{"metadata":{},"names":[` prefix). Each entry is {"display_name":"<mem[ns,ne)>",
// "is_preferred":true,"module":"main","symbol":"<71-char syms slice>"}, comma-separated.
// Inner byte loops copy the name / symbol bytes from the OWNED mem / syms via string_get
// (never moving them); mem and syms thread back out for the later arrays.
fn emit_names(buf: string, mem: string, syms: string, spans: array<i64, 32>, dperm: array<i64, 8>, m: i64) -> EmitN effects[alloc, state] =
  let oseed: PBi = { p: buf, i: 0 } in
  let done: PBi =
    loop o = oseed while o.i < m do
      let cur: PBi = o in
      let idx: i64 = dperm[cur.i] in
      let base: i64 = idx * 4 in
      let ns: i64 = spans[base] in
      let ne: i64 = spans[base + 1] in
      let b0: string = if cur.i > 0 then push_byte(cur.p, to_u8(44)) else cur.p in
      let b1: string = push_lit(b0, b"{\"display_name\":\"") in
      let nseed: PBi = { p: b1, i: ns } in
      let nd: PBi =
        loop nn = nseed while nn.i < ne do
          let nc: PBi = nn in
          let np: string = push_byte(nc.p, string_get(mem, nc.i)) in
          (let r: PBi = { p: np, i: nc.i + 1 } in r)
      in
      let b2: string = push_lit(nd.p, b"\",\"is_preferred\":true,\"module\":\"main\",\"symbol\":\"") in
      let soff: i64 = idx * 71 in
      let sseed: PBi = { p: b2, i: 0 } in
      let sd: PBi =
        loop ss = sseed while ss.i < 71 do
          let sc: PBi = ss in
          let np: string = push_byte(sc.p, string_get(syms, soff + sc.i)) in
          (let r: PBi = { p: np, i: sc.i + 1 } in r)
      in
      let b3: string = push_lit(sd.p, b"\"}") in
      (let r: PBi = { p: b3, i: cur.i + 1 } in r)
  in
  let res: EmitN = { buf: done.p, mem: mem, syms: syms } in res

// Emit the `param_names` array entries (HASH order via `hperm`) into `buf` (which holds
// `...],"param_names":[`). Each entry is {"names":[<frag>],"symbol":"<sym>"}, the fragment
// `pns`[pnoff[idx], pnoff[idx+1]). pns and syms thread back out.
fn emit_pnames(buf: string, syms: string, pns: string, pnoff: array<i64, 9>, hperm: array<i64, 8>, m: i64) -> EmitP effects[alloc, state] =
  let oseed: PBi = { p: buf, i: 0 } in
  let done: PBi =
    loop o = oseed while o.i < m do
      let cur: PBi = o in
      let idx: i64 = hperm[cur.i] in
      let fs: i64 = pnoff[idx] in
      let fe: i64 = pnoff[idx + 1] in
      let b0: string = if cur.i > 0 then push_byte(cur.p, to_u8(44)) else cur.p in
      let b1: string = push_lit(b0, b"{\"names\":[") in
      let fseed: PBi = { p: b1, i: fs } in
      let fd: PBi =
        loop ff = fseed while ff.i < fe do
          let fc: PBi = ff in
          let np: string = push_byte(fc.p, string_get(pns, fc.i)) in
          (let r: PBi = { p: np, i: fc.i + 1 } in r)
      in
      let b2: string = push_lit(fd.p, b"],\"symbol\":\"") in
      let soff: i64 = idx * 71 in
      let sseed: PBi = { p: b2, i: 0 } in
      let sd: PBi =
        loop ss = sseed while ss.i < 71 do
          let sc: PBi = ss in
          let np: string = push_byte(sc.p, string_get(syms, soff + sc.i)) in
          (let r: PBi = { p: np, i: sc.i + 1 } in r)
      in
      let b3: string = push_lit(sd.p, b"\"}") in
      (let r: PBi = { p: b3, i: cur.i + 1 } in r)
  in
  let res: EmitP = { buf: done.p, syms: syms, pns: pns } in res

// Emit the `symbols` array entries (HASH order via `hperm`) into `buf` (which holds
// `...],"symbols":[`) and close with `]}`. Each entry is {"definition":"<def>",
// "signature":"<sig>","symbol":"<sym>"}. syms/defs/sigs thread back out.
fn emit_symbols(buf: string, syms: string, defs: string, sigs: string, hperm: array<i64, 8>, m: i64) -> EmitS effects[alloc, state] =
  let oseed: PBi = { p: buf, i: 0 } in
  let done: PBi =
    loop o = oseed while o.i < m do
      let cur: PBi = o in
      let idx: i64 = hperm[cur.i] in
      let off: i64 = idx * 71 in
      let b0: string = if cur.i > 0 then push_byte(cur.p, to_u8(44)) else cur.p in
      let b1: string = push_lit(b0, b"{\"definition\":\"") in
      let dseed: PBi = { p: b1, i: 0 } in
      let dd: PBi =
        loop d = dseed while d.i < 71 do
          let dc: PBi = d in
          let np: string = push_byte(dc.p, string_get(defs, off + dc.i)) in
          (let r: PBi = { p: np, i: dc.i + 1 } in r)
      in
      let b2: string = push_lit(dd.p, b"\",\"signature\":\"") in
      let gseed: PBi = { p: b2, i: 0 } in
      let gd: PBi =
        loop g = gseed while g.i < 71 do
          let gc: PBi = g in
          let np: string = push_byte(gc.p, string_get(sigs, off + gc.i)) in
          (let r: PBi = { p: np, i: gc.i + 1 } in r)
      in
      let b3: string = push_lit(gd.p, b"\",\"symbol\":\"") in
      let sseed: PBi = { p: b3, i: 0 } in
      let sd: PBi =
        loop s = sseed while s.i < 71 do
          let sc: PBi = s in
          let np: string = push_byte(sc.p, string_get(syms, off + sc.i)) in
          (let r: PBi = { p: np, i: sc.i + 1 } in r)
      in
      let b4: string = push_lit(sd.p, b"\"}") in
      (let r: PBi = { p: b4, i: cur.i + 1 } in r)
  in
  let res: EmitS = { buf: done.p, syms: syms, defs: defs, sigs: sigs } in res

// Build the m-symbol ProgramRoot from the m functions' concatenated 71-char hashes
// (canonical order) + source spans: names DISPLAY-ordered, param_names/symbols
// SYMBOL-HASH-ordered. Every move-only buffer threads back out (AsmOut) so the chain can
// keep accumulating across the m = 1, 2, 3 intermediate roots. Capacity sized from m.
fn assemble_root(rin: RootStr, spans: array<i64, 32>, pnoff: array<i64, 9>, m: i64) -> AsmOut effects[alloc, state] =
  let dp: PermM = disp_perm(rin.mem, spans, m) in
  let hp: PermS = hash_perm(rin.syms, m) in
  let cap: i64 = m * 700 + 512 in
  let buf0: string = push_lit(string_with_capacity(cap), b"{\"metadata\":{},\"names\":[") in
  let en: EmitN = emit_names(buf0, dp.mem, hp.s, spans, dp.perm, m) in
  let buf1: string = push_lit(en.buf, b"],\"param_names\":[") in
  let ep: EmitP = emit_pnames(buf1, en.syms, rin.pns, pnoff, hp.perm, m) in
  let buf2: string = push_lit(ep.buf, b"],\"symbols\":[") in
  let es: EmitS = emit_symbols(buf2, ep.syms, rin.defs, rin.sigs, hp.perm, m) in
  let buf3: string = push_lit(es.buf, b"]}") in
  let h: string = hash_object(b"ProgramRoot", 1, buf3) in
  let r: AsmOut = { hash: h, mem: en.mem, syms: es.syms, defs: es.defs, sigs: es.sigs, pns: ep.pns } in r

// Assemble an m-symbol RECURSION-GROUP ProgramRoot: like assemble_root but with a `recursion_groups`
// array (one entry, `rghash`) inserted between param_names and symbols (key order metadata, names,
// param_names, recursion_groups, symbols). Reuses the SAME display/hash selection sorts + byte-copy
// emitters — names DISPLAY-ordered, param_names/symbols SYMBOL-HASH-ordered (for n = 3 the hash
// order coincides with the ordinal order, but hash_perm does the real sort so this is general).
// Used by build_clique3_root; the root hash is final (no AsmOut threading — a clique root is the
// whole program, built from objects alone with no migration chain).
fn assemble_clique_root(rin: RootStr, spans: array<i64, 32>, pnoff: array<i64, 9>, m: i64, rghash: string) -> string effects[alloc, state] =
  let dp: PermM = disp_perm(rin.mem, spans, m) in
  let hp: PermS = hash_perm(rin.syms, m) in
  let cap: i64 = m * 700 + 640 in
  let buf0: string = push_lit(string_with_capacity(cap), b"{\"metadata\":{},\"names\":[") in
  let en: EmitN = emit_names(buf0, dp.mem, hp.s, spans, dp.perm, m) in
  let buf1: string = push_lit(en.buf, b"],\"param_names\":[") in
  let ep: EmitP = emit_pnames(buf1, en.syms, rin.pns, pnoff, hp.perm, m) in
  let buf2a: string = push_lit(ep.buf, b"],\"recursion_groups\":[\"") in
  let buf2b: string = push_str(buf2a, rghash) in
  let buf2: string = push_lit(buf2b, b"\"],\"symbols\":[") in
  let es: EmitS = emit_symbols(buf2, ep.syms, rin.defs, rin.sigs, hp.perm, m) in
  let buf3: string = push_lit(es.buf, b"]}") in
  hash_object(b"ProgramRoot", 1, buf3)

// Build a `literal_i64` Expression over the (decimal or hex) digits `mem`[start, end)
// with type code `tyc` (an integer type, from the expected type or i64 by default),
// returning its content hash with the memory threaded back. The canonical `value` is
// the raw source slice.
fn build_literal(mem: string, start: i64, endd: i64, tyc: i64) -> Pr effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(512), b"{\"expr_kind\":\"literal_i64\",\"type\":\"") in
  let p1: string = push_str(p0, type_hash(tyc)) in
  let p2: string = push_lit(p1, b"\",\"value\":\"") in
  let pv: PRR = push_range(p2, mem, start, endd) in
  let p3: string = pv.out in
  let m3: string = pv.mem in
  let p4: string = push_lit(p3, b"\"}") in
  let h: string = hash_object(b"Expression", 1, p4) in
  let res: Pr = { mem: m3, hash: h, tyc: tyc, next: endd } in res

// Build a `binary` Expression from the child hashes `lh`/`rh`, the operator bytes
// `ob1` (and `ob2`, or 0 for a single-char operator), and the result type code
// `rtyc` (0 = i64 for arithmetic/bitwise/shift; 1 = bool for comparisons).
fn build_binary(lh: string, ob1: i64, ob2: i64, rh: string, rtyc: i64) -> string effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(512), b"{\"expr_kind\":\"binary\",\"left\":\"") in
  let p1: string = push_str(p0, lh) in
  let p2: string = push_lit(p1, b"\",\"op\":\"") in
  let p3: string = push_byte(p2, to_u8(ob1)) in
  let p3b: string = if ob2 == 0 then p3 else push_byte(p3, to_u8(ob2)) in
  let p4: string = push_lit(p3b, b"\",\"right\":\"") in
  let p5: string = push_str(p4, rh) in
  let p6: string = push_lit(p5, b"\",\"type\":\"") in
  let p7: string = push_str(p6, type_hash(rtyc)) in
  let p8: string = push_lit(p7, b"\"}") in
  hash_object(b"Expression", 1, p8)

// Build a `unary` Expression (prefix `-`/`~` -> i64; `!` -> bool) over child hash
// `eh`, with the result type code `rtyc`.
fn build_unary(opb: i64, eh: string, rtyc: i64) -> string effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(512), b"{\"expr\":\"") in
  let p1: string = push_str(p0, eh) in
  let p2: string = push_lit(p1, b"\",\"expr_kind\":\"unary\",\"op\":\"") in
  let p3: string = push_byte(p2, to_u8(opb)) in
  let p4: string = push_lit(p3, b"\",\"type\":\"") in
  let p5: string = push_str(p4, type_hash(rtyc)) in
  let p6: string = push_lit(p5, b"\"}") in
  hash_object(b"Expression", 1, p6)

// Build a `literal_bool` Expression for the keyword `mem`[start, end) (`true` or
// `false`, distinguished by the first byte: 't' = true). The JSON `value` is a bare
// boolean, not a quoted string. Type code 1 (bool); memory threaded back.
fn build_bool_atom(mem: string, start: i64, endd: i64) -> Pr effects[alloc, state] =
  let v: bool = to_i64(string_get(mem, start)) == 116 in
  let p0: string = push_lit(string_with_capacity(256), b"{\"expr_kind\":\"literal_bool\",\"type\":\"") in
  let p1: string = push_str(p0, build_type_bool()) in
  let p2: string = push_lit(p1, b"\",\"value\":") in
  let p3: string = if v then push_lit(p2, b"true") else push_lit(p2, b"false") in
  let p4: string = push_lit(p3, b"}") in
  let h: string = hash_object(b"Expression", 1, p4) in
  let res: Pr = { mem: mem, hash: h, tyc: 1, next: endd } in res

// Build an `if` Expression from the child hashes; the result type is the then/else
// branch type (`rtyc`). Canonical key order is cond, else, expr_kind, then, type.
fn build_if(condh: string, thenh: string, elseh: string, rtyc: i64) -> string effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(512), b"{\"cond\":\"") in
  let p1: string = push_str(p0, condh) in
  let p2: string = push_lit(p1, b"\",\"else\":\"") in
  let p3: string = push_str(p2, elseh) in
  let p4: string = push_lit(p3, b"\",\"expr_kind\":\"if\",\"then\":\"") in
  let p5: string = push_str(p4, thenh) in
  let p6: string = push_lit(p5, b"\",\"type\":\"") in
  let p7: string = push_str(p6, type_hash(rtyc)) in
  let p8: string = push_lit(p7, b"\"}") in
  hash_object(b"Expression", 1, p8)

// Build a `let` Expression: the binding name is the raw identifier `mem`[ns,ne); its
// declared type is `btyc`; `valh`/`bodyh` are the value/body child hashes; the let's
// own type is the body's type `bodytyc`. Canonical key order: binding_name,
// binding_type, body, expr_kind, type, value. Threads `mem` back (for the name copy);
// the caller assembles the Pr (tyc = bodytyc, cursor = the body's).
fn build_let(mem: string, ns: i64, ne: i64, btyc: i64, valh: string, bodyh: string, bodytyc: i64) -> MH effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(1024), b"{\"binding_name\":\"") in
  let pv: PRR = push_range(p0, mem, ns, ne) in
  let p1: string = pv.out in
  let m1: string = pv.mem in
  let p2: string = push_lit(p1, b"\",\"binding_type\":\"") in
  let p3: string = push_str(p2, type_hash(btyc)) in
  let p4: string = push_lit(p3, b"\",\"body\":\"") in
  let p5: string = push_str(p4, bodyh) in
  let p6: string = push_lit(p5, b"\",\"expr_kind\":\"let\",\"type\":\"") in
  let p7: string = push_str(p6, type_hash(bodytyc)) in
  let p8: string = push_lit(p7, b"\",\"value\":\"") in
  let p9: string = push_str(p8, valh) in
  let p10: string = push_lit(p9, b"\"}") in
  let h: string = hash_object(b"Expression", 1, p10) in
  let res: MH = { mem: m1, hash: h } in res

// Build a `local_ref` Expression: the bare-integer de-Bruijn `depth` and the variable's
// type `tyc`. Canonical key order: depth, expr_kind, type.
fn build_local_ref(depth: i64, tyc: i64) -> string effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(256), b"{\"depth\":") in
  let p1: string = push_dec(p0, depth) in
  let p2: string = push_lit(p1, b",\"expr_kind\":\"local_ref\",\"type\":\"") in
  let p3: string = push_str(p2, type_hash(tyc)) in
  let p4: string = push_lit(p3, b"\"}") in
  hash_object(b"Expression", 1, p4)

// Build a `param_ref` Expression: the bare-integer parameter `index` and the param's
// type `tyc`. Canonical key order: expr_kind, index, type.
fn build_param_ref(index: i64, tyc: i64) -> string effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(256), b"{\"expr_kind\":\"param_ref\",\"index\":") in
  let p1: string = push_dec(p0, index) in
  let p2: string = push_lit(p1, b",\"type\":\"") in
  let p3: string = push_str(p2, type_hash(tyc)) in
  let p4: string = push_lit(p3, b"\"}") in
  hash_object(b"Expression", 1, p4)

// Build an `int_cast` Expression (a `to_<type>(...)` builtin): the value being cast
// (`valh`), its `source_type` (`srctyc`), and the target `type` (`tgttyc`, from the cast
// name). Canonical key order: expr_kind, source_type, type, value.
fn build_int_cast(srctyc: i64, tgttyc: i64, valh: string) -> string effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(512), b"{\"expr_kind\":\"int_cast\",\"source_type\":\"") in
  let p1: string = push_str(p0, type_hash(srctyc)) in
  let p2: string = push_lit(p1, b"\",\"type\":\"") in
  let p3: string = push_str(p2, type_hash(tgttyc)) in
  let p4: string = push_lit(p3, b"\",\"value\":\"") in
  let p5: string = push_str(p4, valh) in
  let p6: string = push_lit(p5, b"\"}") in
  hash_object(b"Expression", 1, p6)

// Build a (no-argument) `call` Expression to a user function: the callee's `symbol` hash
// and the call's `type` (the callee's return type `crtc`). Canonical key order: args,
// expr_kind, symbol, type. `symh` is consumed.
// `argsfrag` is the comma-separated quoted-hash args list (empty for a no-arg call) built by
// parse_args; the buffer is sized from it (it embeds the args inline). args/expr_kind/symbol/type.
fn build_call(symh: string, crtc: i64, argsfrag: string) -> string effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(string_len(argsfrag) + 256), b"{\"args\":[") in
  let pa: string = push_str(p0, argsfrag) in
  let p1: string = push_lit(pa, b"],\"expr_kind\":\"call\",\"symbol\":\"") in
  let p2: string = push_str(p1, symh) in
  let p3: string = push_lit(p2, b"\",\"type\":\"") in
  let p4: string = push_str(p3, type_hash(crtc)) in
  let p5: string = push_lit(p4, b"\"}") in
  hash_object(b"Expression", 1, p5)

// ---------------------------------------------------------------------------
// raw-AST node builders (the dual serialization for the migration body)
//
// Unlike the typed Expression objects above (which reference their children by content
// HASH — a fixed 71-byte string — so each node payload is bounded), a raw-AST node embeds
// its children's full JSON INLINE, so the serialized size grows with the subtree. Each
// builder therefore sizes its buffer DYNAMICALLY from the child lengths (string_with_
// capacity TRAPS if the capacity is exceeded — see the keystone gotchas), never a fixed
// constant. The raw AST is type-free: every integer literal (decimal, hex, or sized) is a
// `literal_i64` with the raw source text; refs (let-locals or params) are `param_name` by
// name; casts are `call` nodes. Keys are emitted in canonical (alphabetical) order. The
// child raw strings are CONSUMED (each used once); `string_len` borrows them first.
// ---------------------------------------------------------------------------

// {"kind":"literal_i64","value":"<raw source slice>"} — the raw text of mem[start,end)
// (decimal "42" or hex "0xff"); sized literals use this too (type-free). Threads mem back.
fn raw_literal_node(mem: string, start: i64, endd: i64) -> Rr effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(endd - start + 48), b"{\"kind\":\"literal_i64\",\"value\":\"") in
  let pv: PRR = push_range(p0, mem, start, endd) in
  let p1: string = pv.out in
  let m1: string = pv.mem in
  let p2: string = push_lit(p1, b"\"}") in
  let r: Rr = { mem: m1, raw: p2, next: endd } in r

// {"kind":"literal_bool","value":true|false} — the value is a BARE JSON boolean (not a
// quoted string), selected by the first byte of the keyword ('t' = 116 = true). Threads mem.
fn raw_bool_node(mem: string, start: i64, endd: i64) -> Rr effects[alloc, state] =
  let v: bool = to_i64(string_get(mem, start)) == 116 in
  let p0: string = push_lit(string_with_capacity(64), b"{\"kind\":\"literal_bool\",\"value\":") in
  let p1: string = if v then push_lit(p0, b"true") else push_lit(p0, b"false") in
  let p2: string = push_lit(p1, b"}") in
  let r: Rr = { mem: mem, raw: p2, next: endd } in r

// {"kind":"param_name","name":"<n>"} — a reference (let-local OR parameter) by NAME (the
// raw AST has no scope/de-Bruijn/index). The name is mem[start,end); threads mem back.
fn raw_ref_node(mem: string, start: i64, endd: i64) -> Rr effects[alloc, state] =
  let p0: string = push_lit(string_with_capacity(endd - start + 48), b"{\"kind\":\"param_name\",\"name\":\"") in
  let pv: PRR = push_range(p0, mem, start, endd) in
  let p1: string = pv.out in
  let m1: string = pv.mem in
  let p2: string = push_lit(p1, b"\"}") in
  let r: Rr = { mem: m1, raw: p2, next: endd } in r

// {"kind":"binary","left":<lraw>,"op":"<op>","right":<rraw>} — the op is its source
// spelling (`ob1` plus `ob2`, or `ob2 = 0` for a single-char op). Children embedded inline.
fn raw_binary_node(lraw: string, ob1: i64, ob2: i64, rraw: string) -> string effects[alloc, state] =
  let cap: i64 = string_len(lraw) + string_len(rraw) + 64 in
  let p0: string = push_lit(string_with_capacity(cap), b"{\"kind\":\"binary\",\"left\":") in
  let p1: string = push_str(p0, lraw) in
  let p2: string = push_lit(p1, b",\"op\":\"") in
  let p3: string = push_byte(p2, to_u8(ob1)) in
  let p3b: string = if ob2 == 0 then p3 else push_byte(p3, to_u8(ob2)) in
  let p4: string = push_lit(p3b, b"\",\"right\":") in
  let p5: string = push_str(p4, rraw) in
  push_lit(p5, b"}")

// {"expr":<eraw>,"kind":"unary","op":"<op>"} — prefix `- ! ~` (single byte `opb`).
fn raw_unary_node(opb: i64, eraw: string) -> string effects[alloc, state] =
  let cap: i64 = string_len(eraw) + 48 in
  let p0: string = push_lit(string_with_capacity(cap), b"{\"expr\":") in
  let p1: string = push_str(p0, eraw) in
  let p2: string = push_lit(p1, b",\"kind\":\"unary\",\"op\":\"") in
  let p3: string = push_byte(p2, to_u8(opb)) in
  push_lit(p3, b"\"}")

// {"cond":<craw>,"else":<eraw>,"kind":"if","then":<traw>} — note canonical key order puts
// `else` before `then`. All three children embedded inline.
fn raw_if_node(craw: string, traw: string, eraw: string) -> string effects[alloc, state] =
  let cap: i64 = string_len(craw) + string_len(traw) + string_len(eraw) + 48 in
  let p0: string = push_lit(string_with_capacity(cap), b"{\"cond\":") in
  let p1: string = push_str(p0, craw) in
  let p2: string = push_lit(p1, b",\"else\":") in
  let p3: string = push_str(p2, eraw) in
  let p4: string = push_lit(p3, b",\"kind\":\"if\",\"then\":") in
  let p5: string = push_str(p4, traw) in
  push_lit(p5, b"}")

// {"body":<braw>,"kind":"let","name":"<n>","type":"<typename>","value":<vraw>} — the
// binding name is mem[ns,ne) and the type is the raw type NAME slice mem[ts,te) (copied
// straight from the source, e.g. "i64"/"u8"); body/value embedded inline. Threads mem back.
fn raw_let_node(mem: string, ns: i64, ne: i64, ts: i64, te: i64, vraw: string, braw: string) -> Rr effects[alloc, state] =
  let cap: i64 = string_len(braw) + string_len(vraw) + (ne - ns) + (te - ts) + 64 in
  let p0: string = push_lit(string_with_capacity(cap), b"{\"body\":") in
  let p1: string = push_str(p0, braw) in
  let p2: string = push_lit(p1, b",\"kind\":\"let\",\"name\":\"") in
  let nb: PRR = push_range(p2, mem, ns, ne) in
  let p3: string = nb.out in
  let m1: string = nb.mem in
  let p4: string = push_lit(p3, b"\",\"type\":\"") in
  let tb: PRR = push_range(p4, m1, ts, te) in
  let p5: string = tb.out in
  let m2: string = tb.mem in
  let p6: string = push_lit(p5, b"\",\"value\":") in
  let p7: string = push_str(p6, vraw) in
  let p8: string = push_lit(p7, b"}") in
  let r: Rr = { mem: m2, raw: p8, next: 0 } in r

// {"args":[<araw>],"kind":"call","name":"<to_xxx>"} — a `to_<type>(...)` cast serializes
// as a `call` node; the call name is the full source slice mem[p,e) ("to_u8"). One arg.
fn raw_cast_node(mem: string, p: i64, e: i64, araw: string) -> Rr effects[alloc, state] =
  let cap: i64 = string_len(araw) + (e - p) + 64 in
  let p0: string = push_lit(string_with_capacity(cap), b"{\"args\":[") in
  let p1: string = push_str(p0, araw) in
  let p2: string = push_lit(p1, b"],\"kind\":\"call\",\"name\":\"") in
  let nb: PRR = push_range(p2, mem, p, e) in
  let p3: string = nb.out in
  let m1: string = nb.mem in
  let p4: string = push_lit(p3, b"\"}") in
  let r: Rr = { mem: m1, raw: p4, next: 0 } in r

// ---------------------------------------------------------------------------
// the parser: precedence climbing, left-associative for the binary levels.
//   bitor `|` -> bitxor `^` -> bitand `&` -> equality `== !=` -> relational
//   `< > <= >=` -> shift `<< >>` -> add `+ -` -> mul `* / %` -> unary (prefix
//   `- ~`) -> atom (<decimal int>)
// Each binary level is the same loop: parse a tighter operand, then while the next
// significant bytes are an operator of this level, fold left. The comparison levels
// (equality, relational) yield bool (type code 1); the arithmetic/bitwise/shift
// levels yield i64 (type code 0); the logical levels (logor `||`, logand `&&`) and
// `!` yield bool. Each result type threads up through `Pr.tyc` so a node's `type`
// field and the function's return type are correct. `<<`/`>>` are distinguished from
// lone `<`/`>`, and `&&`/`||` from `&`/`|`. The atom level also handles `if cond then
// a else b` (an expression), whose sub-expressions recurse back to the top of the
// ladder — so parse_atom/parse_if and the binary levels form one mutual-recursion
// clique (codedb compiles it as a recursion group). The move-only loop result is
// rebuilt into a fresh record before return (see the v0-backend workaround on
// parse_mul).
// ---------------------------------------------------------------------------

// Classify the identifier `mem`[p,e) into a dispatch code: 1 = `if`, 2 = `let`,
// 3 = `true`/`false` (bool literal), 4 = a `to_<type>(` cast, 5 = a user-function call
// (`<name>(`), 0 = a plain variable. Each keyword test is length-gated by a nested `if` so
// the inner string_get reads stay in bounds (`&&` is strict). A cast is the `to_` prefix
// (t/o/_ = 116/111/95) followed by a `(` (byte 40) at `e`; a user call is any OTHER
// identifier immediately followed by `(`. Threads `mem` back, so these temporaries stay in
// this frame rather than inflating parse_atom's (which is near the v0 frame budget).
fn classify_kw(mem: string, p: i64, e: i64, len: i64) -> TC =
  let klen: i64 = e - p in
  let kw: i64 =
    if klen == 2 then (if (to_i64(string_get(mem, p)) == 105 && to_i64(string_get(mem, p + 1)) == 102) then 1 else 0)
    else if klen == 3 then (if (to_i64(string_get(mem, p)) == 108 && to_i64(string_get(mem, p + 1)) == 101 && to_i64(string_get(mem, p + 2)) == 116) then 2 else 0)
    else if klen == 4 then (if (to_i64(string_get(mem, p)) == 116 && to_i64(string_get(mem, p + 1)) == 114 && to_i64(string_get(mem, p + 2)) == 117 && to_i64(string_get(mem, p + 3)) == 101) then 3 else 0)
    else if klen == 5 then (if (to_i64(string_get(mem, p)) == 102 && to_i64(string_get(mem, p + 1)) == 97 && to_i64(string_get(mem, p + 2)) == 108 && to_i64(string_get(mem, p + 3)) == 115 && to_i64(string_get(mem, p + 4)) == 101) then 3 else 0)
    else 0
  in
  // an identifier immediately followed by `(` is a call; a `to_<type>(` is a cast (4), any
  // other name is a user-function call (5).
  let hasparen: bool = if e < len then to_i64(string_get(mem, e)) == 40 else false in
  let iscast: bool =
    if klen >= 5 then
      (if (to_i64(string_get(mem, p)) == 116 && to_i64(string_get(mem, p + 1)) == 111 && to_i64(string_get(mem, p + 2)) == 95) then hasparen else false)
    else false
  in
  let code: i64 = if kw != 0 then kw else (if iscast then 4 else (if hasparen then 5 else 0)) in
  let res: TC = { code: code, mem: mem } in res

// atom := <decimal int> (i64) | `true` | `false` (bool) | `if` ... ; ws-skipped.
fn parse_atom(mem: string, pos: i64, len: i64, scope: Scope, np: i64, etyc: i64) -> Pr effects[alloc, state] =
  let sw: MI = skip_ws(mem, pos, len) in
  let m1: string = sw.mem in
  let p: i64 = sw.i in
  // An integer literal's type is the expected type if one is set, else i64 (code 0).
  let ltyc: i64 = if etyc >= 0 then etyc else 0 in
  if p < len then
    (if is_digit_b(to_i64(string_get(m1, p))) then
       // A `0x`/`0X` prefix selects a hex literal; otherwise decimal. The literal's
       // canonical `value` is the raw source slice either way (e.g. "0xff", "42").
       (if (if to_i64(string_get(m1, p)) == 48 then (if p + 1 < len then (let b1: i64 = to_i64(string_get(m1, p + 1)) in b1 == 120 || b1 == 88) else false) else false) then
          let sh: MI = scan_hex(m1, p + 2, len) in
          build_literal(sh.mem, p, sh.i, ltyc)
        else
          let sd: MI = scan_digits(m1, p, len) in
          build_literal(sd.mem, p, sd.i, ltyc))
     else
       // An identifier: a keyword (`if`/`let`/`true`/`false`), a `to_<type>(` cast, a
       // user-function call (`<name>(`), or a variable. classify_kw returns the dispatch
       // code (kept in a helper so its byte-test temporaries do not inflate parse_atom's
       // near-budget stack frame); a variable (code 0) resolves to a local_ref / param_ref.
       let se: MI = scan_ident(m1, p, len) in
       let e: i64 = se.i in
       let cl: TC = classify_kw(se.mem, p, e, len) in
       let m2: string = cl.mem in
       let kw: i64 = cl.code in
       (if kw == 1 then parse_if(m2, e, len, scope, np, etyc)
        else if kw == 2 then parse_let(m2, e, len, scope, np, etyc)
        else if kw == 3 then build_bool_atom(m2, p, e)
        else if kw == 4 then parse_cast(m2, p, e, len, scope, np)
        else if kw == 5 then parse_call(m2, p, e, len, scope, np)
        else resolve_ident(scope, np, m2, p, e)))
  else build_literal(m1, p, p, ltyc)

// if := `if` expr `then` expr `else` expr  (the `then`/`else` keyword tokens are
// skipped; the result type is the then-branch's type). The cond/then/else are full
// expressions, so this recurses to parse_bitor (the top of the ladder).
// NOTE: treating `if` as an atom is more permissive than the Rust grammar, which
// only allows `if` at an expression-start position (e.g. `1 + if ...` is a Rust
// parse error). This never diverges on a Rust-valid program, so root-hash equality
// holds; matching Rust's exact rejection is a later grammar-tightening.
fn parse_if(mem: string, pos: i64, len: i64, scope: Scope, np: i64, etyc: i64) -> Pr effects[alloc, state] =
  // cond expects bool; the branches receive NO expectation (the outer expected type is
  // not propagated into `if` branches — Rust does not either, so e.g.
  // `-> u32 = if c then 1 else 2` is a type error and out of scope). The if's type is
  // the then-branch's type.
  let cond: Pr = parse_bitor(mem, pos, len, scope, np, 1) in
  let sw1: MI = skip_ws(cond.mem, cond.next, len) in
  let tk: MI = scan_ident(sw1.mem, sw1.i, len) in
  let thn: Pr = parse_bitor(tk.mem, tk.i, len, scope, np, 0 - 1) in
  let sw2: MI = skip_ws(thn.mem, thn.next, len) in
  let ek: MI = scan_ident(sw2.mem, sw2.i, len) in
  let els: Pr = parse_bitor(ek.mem, ek.i, len, scope, np, 0 - 1) in
  let h: string = build_if(cond.hash, thn.hash, els.hash, thn.tyc) in
  let res: Pr = { mem: els.mem, hash: h, tyc: thn.tyc, next: els.next } in res

// let := `let` IDENT `:` TYPE `=` expr `in` expr. At entry `pos` is just past the
// `let` keyword. The value is parsed in the CURRENT scope with the binding's declared
// type as its expected type; the body in `scope` extended with this binding (so a body
// identifier matching it resolves to depth 0) with the OUTER expected type. The let's
// type is the body's type.
fn parse_let(mem: string, pos: i64, len: i64, scope: Scope, np: i64, etyc: i64) -> Pr effects[alloc, state] =
  // the binding name [ns, ne)
  let sw1: MI = skip_ws(mem, pos, len) in
  let ns: i64 = sw1.i in
  let nm: MI = scan_ident(sw1.mem, ns, len) in
  let ne: i64 = nm.i in
  // `:` then the declared type identifier [ts, te) -> binding type code
  let sw2: MI = skip_ws(nm.mem, ne, len) in
  let sw3: MI = skip_ws(sw2.mem, sw2.i + 1, len) in
  let ts: i64 = sw3.i in
  let ty: MI = scan_ident(sw3.mem, ts, len) in
  let te: i64 = ty.i in
  let tc: TC = type_code_of(ty.mem, ts, te) in
  let btyc: i64 = tc.code in
  // `=` then the value expression (current scope), expecting the binding type
  let sw4: MI = skip_ws(tc.mem, te, len) in
  let val: Pr = parse_bitor(sw4.mem, sw4.i + 1, len, scope, np, btyc) in
  // the `in` keyword, then the body expression (extended scope), expecting `etyc`
  let sw5: MI = skip_ws(val.mem, val.next, len) in
  let ink: MI = scan_ident(sw5.mem, sw5.i, len) in
  let scope2: Scope = push_scope(scope, ns, ne, btyc) in
  let body: Pr = parse_bitor(ink.mem, ink.i, len, scope2, np, etyc) in
  let lb: MH = build_let(body.mem, ns, ne, btyc, val.hash, body.hash, body.tyc) in
  let res: Pr = { mem: lb.mem, hash: lb.hash, tyc: body.tyc, next: body.next } in res

// cast := `to_<type>` `(` expr `)`. At entry the cast identifier is `mem`[p,e) (its
// `to_` prefix and the `(` at `e` were confirmed by the caller). The target type is
// `mem`[p+3,e); the argument is a full expression parsed with NO expectation (it keeps
// its own type), recorded as the cast's `source_type`. The result type is the target,
// fixed by the cast name regardless of the surrounding expectation.
fn parse_cast(mem: string, p: i64, e: i64, len: i64, scope: Scope, np: i64) -> Pr effects[alloc, state] =
  let tc: TC = type_code_of(mem, p + 3, e) in
  let target: i64 = tc.code in
  let arg: Pr = parse_bitor(tc.mem, e + 1, len, scope, np, 0 - 1) in
  let sw: MI = skip_ws(arg.mem, arg.next, len) in
  let h: string = build_int_cast(arg.tyc, target, arg.hash) in
  let res: Pr = { mem: sw.mem, hash: h, tyc: target, next: sw.i + 1 } in res

// call := `<name>` `(` `)`  (no-argument call). At entry the call identifier is `mem`[p,e)
// (the `(` at `e` was confirmed by the caller). The callee's return type is found by re-scanning
// the source (find_callee_rtc) — the result type and the call node's `type`. The callee SYMBOL
// is resolved by `resolve_call_symbol` against the scope's `rgord`: a self-call inside a
// recursion-group member (rgord >= 0) resolves to `recursion_group:<rgord>`; otherwise (a
// Parse a call's argument list starting just past `(` (at `pos`); returns the args JSON
// fragment (quoted typed-Expression hashes, comma-separated — `"h0","h1"`; empty for no args),
// the position past the matching `)`, and the threaded memory. Each argument is a full
// expression (parse_bitor) in the CALLER's scope (`scope`, `np`) with NO expected type (-1): an
// i64/bool argument takes its own type, matching the callee's i64/bool parameter (a sized-param
// argument would need the callee's parameter type pushed down — deferred, like the documented
// axis-1 unification gaps). Repetition is a LOOP (NOT self-recursion — a recursive parser that
// both self-calls AND calls the clique-member parse_bitor through an aggregate return miscompiles
// to a v0 SIGTRAP at depth >= 2): the accumulator carries the running fragment, each iteration
// parses one argument, appends `,`?"hash" into a FRESH dynamically-sized buffer, and rebuilds a
// fresh record (`let nx = {…} in nx`, the proven parse_add/raw_add shape); the final return is a
// fresh record too (returning the loop accumulator directly miscompiles). The loop stops at the
// `)`; a `,` between arguments is consumed by advancing `next` past it.
fn parse_args(mem: string, pos: i64, len: i64, scope: Scope, np: i64) -> ArgsR effects[alloc, state] =
  let sw0: MI = skip_ws(mem, pos, len) in
  let seed: ArgsR = { mem: sw0.mem, frag: string_with_capacity(1), next: sw0.i } in
  let done: ArgsR =
    loop a = seed while (if a.next < len then to_i64(string_get(a.mem, a.next)) != 41 else false) do
      let cur: ArgsR = a in
      let arg: Pr = parse_bitor(cur.mem, cur.next, len, scope, np, 0 - 1) in
      let cap: i64 = string_len(cur.frag) + string_len(arg.hash) + 8 in
      let base: string = push_str(string_with_capacity(cap), cur.frag) in
      let s0: string = if string_len(base) == 0 then base else push_byte(base, to_u8(44)) in
      let s1: string = push_byte(s0, to_u8(34)) in
      let s2: string = push_str(s1, arg.hash) in
      let s3: string = push_byte(s2, to_u8(34)) in
      let sw: MI = skip_ws(arg.mem, arg.next, len) in
      // consume a separating `,` so the next iteration starts at the next argument (or `)`).
      let nextpos: i64 = if (if sw.i < len then to_i64(string_get(sw.mem, sw.i)) == 44 else false) then sw.i + 1 else sw.i in
      let nx: ArgsR = { mem: sw.mem, frag: s3, next: nextpos } in nx
  in
  // done.next points at the `)`; advance past it.
  let r: ArgsR = { mem: done.mem, frag: done.frag, next: done.next + 1 } in r

// cross-symbol call in a two-function DAG) the callee is the canonical-first function, so its
// symbol is re-derived from the call name (genesis/0). No symbol table is threaded through the
// parser. The argument list (e points at `(`) is parsed in the caller's scope by parse_args.
fn parse_call(mem: string, p: i64, e: i64, len: i64, scope: Scope, np: i64) -> Pr effects[alloc, state] =
  let crc: TC = find_callee_rtc(mem, p, e, len) in
  let crtc: i64 = crc.code in
  let m0: string = crc.mem in
  // The callee's WL canonical ORDINAL within the recursion group (only meaningful when
  // scope.rgord >= 0; ignored otherwise). clique_rank gives the callee's ALPHABETICAL rank (0 =
  // alpha-first, 1 = alpha-second, 2 = alpha-third). The member ORDINAL is the WL canonical order
  // (order_clique / clique3_order), which differs from alphabetical for asymmetric cliques — so map
  // rank -> ordinal via scope.aord, a base-4 PACKED permutation: rank r's ordinal is bits [2r,2r+1)
  // (ord(alpha0) + ord(alpha1)*4 + ord(alpha2)*16). For a two-member clique aord = o0 + (1-o0)*4
  // reproduces the old `rank 0 -> o0, rank 1 -> 1-o0`; a single-member group has aord = 0. Computed
  // unconditionally so resolve_call_symbol stays a pure conditional of two whole calls.
  let rk: TC = clique_rank(m0, p, e, len) in
  let ord: i64 = if rk.code == 0 then (scope.aord & 3)
                 else if rk.code == 1 then ((scope.aord >> 2) & 3)
                 else ((scope.aord >> 4) & 3) in
  // A call to an augmented extra callee (a non-first canonical function in a DAG) takes its
  // precomputed symbol; otherwise resolve a recursion-group member or a genesis create_function.
  // A conditional of two whole calls (no string building inside the `if`) — the v0 SIGTRAP rule.
  let xs: XC = xc_scan(rk.mem, p, e, len) in
  let mxc: string = xs.mem in
  let s: MH = if xs.hit then build_sym_xc(mxc, xs.off) else resolve_call_symbol(scope.rgord, ord, mxc, p, e) in
  let m1: string = s.mem in
  let symh: string = s.hash in
  let ar: ArgsR = parse_args(m1, e + 1, len, scope, np) in
  let h: string = build_call(symh, crtc, ar.frag) in
  let res: Pr = { mem: ar.mem, hash: h, tyc: crtc, next: ar.next } in res

// unary := ('-'|'~'|'!') unary | atom   (prefix; `- ~` -> i64, `!` -> bool)
fn parse_unary(mem: string, pos: i64, len: i64, scope: Scope, np: i64, etyc: i64) -> Pr effects[alloc, state] =
  let sw: MI = skip_ws(mem, pos, len) in
  let m1: string = sw.mem in
  let p: i64 = sw.i in
  if p < len then
    (if is_unary_op(to_i64(string_get(m1, p))) then
       let opb: i64 = to_i64(string_get(m1, p)) in
       let isnot: bool = opb == 33 in
       let oe: i64 = if isnot then 1 else etyc in
       let inner: Pr = parse_unary(m1, p + 1, len, scope, np, oe) in
       let rtyc: i64 = if isnot then 1 else eff(etyc, inner.tyc) in
       let h: string = build_unary(opb, inner.hash, rtyc) in
       let res: Pr = { mem: inner.mem, hash: h, tyc: rtyc, next: inner.next } in res
     else parse_atom(m1, p, len, scope, np, etyc))
  else parse_atom(m1, p, len, scope, np, etyc)

// mul := unary (('*'|'/'|'%') unary)*   (i64)
fn parse_mul(mem: string, pos: i64, len: i64, scope: Scope, np: i64, etyc: i64) -> Pr effects[alloc, state] =
  let lft: Pr = parse_unary(mem, pos, len, scope, np, etyc) in
  let oe: i64 = eff(etyc, lft.tyc) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Pr = { mem: s0.mem, hash: lft.hash, tyc: lft.tyc, next: s0.i } in
  let done: Pr =
    loop a = seed while (if a.next < len then is_mulop(to_i64(string_get(a.mem, a.next))) else false) do
      let cur: Pr = a in
      let opb: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let rgt: Pr = parse_unary(cur.mem, cur.next + 1, len, scope, np, oe) in
      let bh: string = build_binary(cur.hash, opb, 0, rgt.hash, oe) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Pr = { mem: s1.mem, hash: bh, tyc: oe, next: s1.i } in nx
  in
  // BACKEND-BUG WORKAROUND: returning the move-only loop accumulator `done`
  // directly (`in done`) miscompiles to a native SIGTRAP when the loop body calls
  // an aggregate-returning function — a loop-accumulator/return-slot aliasing bug
  // in the v0 backend. Rebuilding into a fresh record decouples the slots; the
  // reference evaluator computes both identically (native-only). Applies to every
  // binary level below too.
  let r: Pr = { mem: done.mem, hash: done.hash, tyc: done.tyc, next: done.next } in r

// add := mul (('+'|'-') mul)*   (i64)
fn parse_add(mem: string, pos: i64, len: i64, scope: Scope, np: i64, etyc: i64) -> Pr effects[alloc, state] =
  let lft: Pr = parse_mul(mem, pos, len, scope, np, etyc) in
  let oe: i64 = eff(etyc, lft.tyc) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Pr = { mem: s0.mem, hash: lft.hash, tyc: lft.tyc, next: s0.i } in
  let done: Pr =
    loop a = seed while (if a.next < len then is_addop(to_i64(string_get(a.mem, a.next))) else false) do
      let cur: Pr = a in
      let opb: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let rgt: Pr = parse_mul(cur.mem, cur.next + 1, len, scope, np, oe) in
      let bh: string = build_binary(cur.hash, opb, 0, rgt.hash, oe) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Pr = { mem: s1.mem, hash: bh, tyc: oe, next: s1.i } in nx
  in
  let r: Pr = { mem: done.mem, hash: done.hash, tyc: done.tyc, next: done.next } in r

// shift := add (('<<'|'>>') add)*   (i64)
fn parse_shift(mem: string, pos: i64, len: i64, scope: Scope, np: i64, etyc: i64) -> Pr effects[alloc, state] =
  let lft: Pr = parse_add(mem, pos, len, scope, np, etyc) in
  let oe: i64 = eff(etyc, lft.tyc) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Pr = { mem: s0.mem, hash: lft.hash, tyc: lft.tyc, next: s0.i } in
  let done: Pr =
    loop a = seed while (if a.next + 1 < len then is_shift_op(to_i64(string_get(a.mem, a.next)), to_i64(string_get(a.mem, a.next + 1))) else false) do
      let cur: Pr = a in
      let ob1: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let ob2: i64 = to_i64(string_get(cur.mem, cur.next + 1)) in
      let rgt: Pr = parse_add(cur.mem, cur.next + 2, len, scope, np, oe) in
      let bh: string = build_binary(cur.hash, ob1, ob2, rgt.hash, oe) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Pr = { mem: s1.mem, hash: bh, tyc: oe, next: s1.i } in nx
  in
  let r: Pr = { mem: done.mem, hash: done.hash, tyc: done.tyc, next: done.next } in r

// relational := shift (('<'|'>'|'<='|'>=') shift)*   (result bool, type code 1)
fn parse_relational(mem: string, pos: i64, len: i64, scope: Scope, np: i64, etyc: i64) -> Pr effects[alloc, state] =
  let eop: i64 = if etyc >= 0 && etyc != 1 then etyc else 0 - 1 in
  let lft: Pr = parse_shift(mem, pos, len, scope, np, eop) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Pr = { mem: s0.mem, hash: lft.hash, tyc: lft.tyc, next: s0.i } in
  let done: Pr =
    loop a = seed while (if a.next < len then is_rel_start(to_i64(string_get(a.mem, a.next)), (if a.next + 1 < len then to_i64(string_get(a.mem, a.next + 1)) else 0)) else false) do
      let cur: Pr = a in
      let ob1: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let b2: i64 = if cur.next + 1 < len then to_i64(string_get(cur.mem, cur.next + 1)) else 0 in
      let two: bool = b2 == 61 in
      let ob2: i64 = if two then 61 else 0 in
      let oplen: i64 = if two then 2 else 1 in
      let rgt: Pr = parse_shift(cur.mem, cur.next + oplen, len, scope, np, cur.tyc) in
      let bh: string = build_binary(cur.hash, ob1, ob2, rgt.hash, 1) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Pr = { mem: s1.mem, hash: bh, tyc: 1, next: s1.i } in nx
  in
  let r: Pr = { mem: done.mem, hash: done.hash, tyc: done.tyc, next: done.next } in r

// equality := relational (('=='|'!=') relational)*   (result bool, type code 1)
fn parse_equality(mem: string, pos: i64, len: i64, scope: Scope, np: i64, etyc: i64) -> Pr effects[alloc, state] =
  let eop: i64 = if etyc >= 0 && etyc != 1 then etyc else 0 - 1 in
  let lft: Pr = parse_relational(mem, pos, len, scope, np, eop) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Pr = { mem: s0.mem, hash: lft.hash, tyc: lft.tyc, next: s0.i } in
  let done: Pr =
    loop a = seed while (if a.next + 1 < len then is_eq_start(to_i64(string_get(a.mem, a.next)), to_i64(string_get(a.mem, a.next + 1))) else false) do
      let cur: Pr = a in
      let ob1: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let ob2: i64 = to_i64(string_get(cur.mem, cur.next + 1)) in
      let rgt: Pr = parse_relational(cur.mem, cur.next + 2, len, scope, np, cur.tyc) in
      let bh: string = build_binary(cur.hash, ob1, ob2, rgt.hash, 1) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Pr = { mem: s1.mem, hash: bh, tyc: 1, next: s1.i } in nx
  in
  let r: Pr = { mem: done.mem, hash: done.hash, tyc: done.tyc, next: done.next } in r

// bitand := equality (('&' not '&&') equality)*   (i64)
fn parse_bitand(mem: string, pos: i64, len: i64, scope: Scope, np: i64, etyc: i64) -> Pr effects[alloc, state] =
  let lft: Pr = parse_equality(mem, pos, len, scope, np, etyc) in
  let oe: i64 = eff(etyc, lft.tyc) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Pr = { mem: s0.mem, hash: lft.hash, tyc: lft.tyc, next: s0.i } in
  let done: Pr =
    loop a = seed while (if a.next < len then is_and_op(to_i64(string_get(a.mem, a.next)), (if a.next + 1 < len then to_i64(string_get(a.mem, a.next + 1)) else 0)) else false) do
      let cur: Pr = a in
      let opb: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let rgt: Pr = parse_equality(cur.mem, cur.next + 1, len, scope, np, oe) in
      let bh: string = build_binary(cur.hash, opb, 0, rgt.hash, oe) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Pr = { mem: s1.mem, hash: bh, tyc: oe, next: s1.i } in nx
  in
  let r: Pr = { mem: done.mem, hash: done.hash, tyc: done.tyc, next: done.next } in r

// bitxor := bitand ('^' bitand)*   (i64)
fn parse_bitxor(mem: string, pos: i64, len: i64, scope: Scope, np: i64, etyc: i64) -> Pr effects[alloc, state] =
  let lft: Pr = parse_bitand(mem, pos, len, scope, np, etyc) in
  let oe: i64 = eff(etyc, lft.tyc) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Pr = { mem: s0.mem, hash: lft.hash, tyc: lft.tyc, next: s0.i } in
  let done: Pr =
    loop a = seed while (if a.next < len then is_xor_op(to_i64(string_get(a.mem, a.next))) else false) do
      let cur: Pr = a in
      let opb: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let rgt: Pr = parse_bitand(cur.mem, cur.next + 1, len, scope, np, oe) in
      let bh: string = build_binary(cur.hash, opb, 0, rgt.hash, oe) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Pr = { mem: s1.mem, hash: bh, tyc: oe, next: s1.i } in nx
  in
  let r: Pr = { mem: done.mem, hash: done.hash, tyc: done.tyc, next: done.next } in r

// logand := bitxor ('&&' bitxor)*   (result bool, type code 1)
fn parse_logand(mem: string, pos: i64, len: i64, scope: Scope, np: i64, etyc: i64) -> Pr effects[alloc, state] =
  let eop: i64 = if etyc >= 0 && etyc != 1 then etyc else 1 in
  let lft: Pr = parse_bitxor(mem, pos, len, scope, np, eop) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Pr = { mem: s0.mem, hash: lft.hash, tyc: lft.tyc, next: s0.i } in
  let done: Pr =
    loop a = seed while (if a.next + 1 < len then is_logand(to_i64(string_get(a.mem, a.next)), to_i64(string_get(a.mem, a.next + 1))) else false) do
      let cur: Pr = a in
      let rgt: Pr = parse_bitxor(cur.mem, cur.next + 2, len, scope, np, 1) in
      let bh: string = build_binary(cur.hash, 38, 38, rgt.hash, 1) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Pr = { mem: s1.mem, hash: bh, tyc: 1, next: s1.i } in nx
  in
  let r: Pr = { mem: done.mem, hash: done.hash, tyc: done.tyc, next: done.next } in r

// logor := logand ('||' logand)*   (result bool, type code 1)
fn parse_logor(mem: string, pos: i64, len: i64, scope: Scope, np: i64, etyc: i64) -> Pr effects[alloc, state] =
  let eop: i64 = if etyc >= 0 && etyc != 1 then etyc else 1 in
  let lft: Pr = parse_logand(mem, pos, len, scope, np, eop) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Pr = { mem: s0.mem, hash: lft.hash, tyc: lft.tyc, next: s0.i } in
  let done: Pr =
    loop a = seed while (if a.next + 1 < len then is_logor(to_i64(string_get(a.mem, a.next)), to_i64(string_get(a.mem, a.next + 1))) else false) do
      let cur: Pr = a in
      let rgt: Pr = parse_logand(cur.mem, cur.next + 2, len, scope, np, 1) in
      let bh: string = build_binary(cur.hash, 124, 124, rgt.hash, 1) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Pr = { mem: s1.mem, hash: bh, tyc: 1, next: s1.i } in nx
  in
  let r: Pr = { mem: done.mem, hash: done.hash, tyc: done.tyc, next: done.next } in r

// bitor := logor (('|' not '||') logor)*   (i64)
fn parse_bitor(mem: string, pos: i64, len: i64, scope: Scope, np: i64, etyc: i64) -> Pr effects[alloc, state] =
  let lft: Pr = parse_logor(mem, pos, len, scope, np, etyc) in
  let oe: i64 = eff(etyc, lft.tyc) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Pr = { mem: s0.mem, hash: lft.hash, tyc: lft.tyc, next: s0.i } in
  let done: Pr =
    loop a = seed while (if a.next < len then is_or_op(to_i64(string_get(a.mem, a.next)), (if a.next + 1 < len then to_i64(string_get(a.mem, a.next + 1)) else 0)) else false) do
      let cur: Pr = a in
      let opb: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let rgt: Pr = parse_logor(cur.mem, cur.next + 1, len, scope, np, oe) in
      let bh: string = build_binary(cur.hash, opb, 0, rgt.hash, oe) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Pr = { mem: s1.mem, hash: bh, tyc: oe, next: s1.i } in nx
  in
  let r: Pr = { mem: done.mem, hash: done.hash, tyc: done.tyc, next: done.next } in r

// ---------------------------------------------------------------------------
// the RAW parser: a SECOND, type-free recursive-descent parser producing the raw-AST
// JSON string (the migration `operation.body`). It mirrors the typed ladder's precedence
// and associativity EXACTLY (so the raw tree matches the typed tree), but is simpler:
// no expected-type, no scope, no type code — refs are by-name, literals are type-free.
// Each level returns an `Rr` (threaded mem + the raw JSON string + cursor); like the typed
// levels, the move-only loop accumulator is rebuilt into a fresh record before return (the
// v0-backend workaround). raw_atom/raw_if/raw_let/raw_cast and the binary ladder form one
// mutual-recursion clique (a second recursion group alongside the typed parser's).
// ---------------------------------------------------------------------------

// raw atom := <decimal|hex int> | `true`|`false` | `if` ... | `let` ... | to_<t>(...) | IDENT
fn raw_atom(mem: string, pos: i64, len: i64) -> Rr effects[alloc, state] =
  let sw: MI = skip_ws(mem, pos, len) in
  let m1: string = sw.mem in
  let p: i64 = sw.i in
  if p < len then
    (if is_digit_b(to_i64(string_get(m1, p))) then
       (if (if to_i64(string_get(m1, p)) == 48 then (if p + 1 < len then (let b1: i64 = to_i64(string_get(m1, p + 1)) in b1 == 120 || b1 == 88) else false) else false) then
          let sh: MI = scan_hex(m1, p + 2, len) in
          raw_literal_node(sh.mem, p, sh.i)
        else
          let sd: MI = scan_digits(m1, p, len) in
          raw_literal_node(sd.mem, p, sd.i))
     else
       let se: MI = scan_ident(m1, p, len) in
       let e: i64 = se.i in
       let cl: TC = classify_kw(se.mem, p, e, len) in
       let m2: string = cl.mem in
       let kw: i64 = cl.code in
       (if kw == 1 then raw_if(m2, e, len)
        else if kw == 2 then raw_let(m2, e, len)
        else if kw == 3 then raw_bool_node(m2, p, e)
        else if kw == 4 then raw_cast(m2, p, e, len)
        else if kw == 5 then raw_call(m2, p, e, len)
        else raw_ref_node(m2, p, e)))
  else raw_literal_node(m1, p, p)

// raw if := `if` expr `then` expr `else` expr (then/else keyword tokens skipped).
fn raw_if(mem: string, pos: i64, len: i64) -> Rr effects[alloc, state] =
  let cond: Rr = raw_bitor(mem, pos, len) in
  let sw1: MI = skip_ws(cond.mem, cond.next, len) in
  let tk: MI = scan_ident(sw1.mem, sw1.i, len) in
  let thn: Rr = raw_bitor(tk.mem, tk.i, len) in
  let sw2: MI = skip_ws(thn.mem, thn.next, len) in
  let ek: MI = scan_ident(sw2.mem, sw2.i, len) in
  let els: Rr = raw_bitor(ek.mem, ek.i, len) in
  let node: string = raw_if_node(cond.raw, thn.raw, els.raw) in
  let r: Rr = { mem: els.mem, raw: node, next: els.next } in r

// raw let := `let` IDENT `:` TYPE `=` expr `in` expr. The name [ns,ne) and type [ts,te)
// are copied straight from the source (the raw type field is the type NAME, type-free).
fn raw_let(mem: string, pos: i64, len: i64) -> Rr effects[alloc, state] =
  let sw1: MI = skip_ws(mem, pos, len) in
  let ns: i64 = sw1.i in
  let nm: MI = scan_ident(sw1.mem, ns, len) in
  let ne: i64 = nm.i in
  let sw2: MI = skip_ws(nm.mem, ne, len) in
  let sw3: MI = skip_ws(sw2.mem, sw2.i + 1, len) in
  let ts: i64 = sw3.i in
  let ty: MI = scan_ident(sw3.mem, ts, len) in
  let te: i64 = ty.i in
  let sw4: MI = skip_ws(ty.mem, te, len) in
  let val: Rr = raw_bitor(sw4.mem, sw4.i + 1, len) in
  let sw5: MI = skip_ws(val.mem, val.next, len) in
  let ink: MI = scan_ident(sw5.mem, sw5.i, len) in
  let body: Rr = raw_bitor(ink.mem, ink.i, len) in
  let node: Rr = raw_let_node(body.mem, ns, ne, ts, te, val.raw, body.raw) in
  let r: Rr = { mem: node.mem, raw: node.raw, next: body.next } in r

// raw cast := `to_<type>` `(` expr `)`. The cast identifier is mem[p,e) (the `(` is at e).
fn raw_cast(mem: string, p: i64, e: i64, len: i64) -> Rr effects[alloc, state] =
  let arg: Rr = raw_bitor(mem, e + 1, len) in
  let sw: MI = skip_ws(arg.mem, arg.next, len) in
  let node: Rr = raw_cast_node(sw.mem, p, e, arg.raw) in
  let r: Rr = { mem: node.mem, raw: node.raw, next: sw.i + 1 } in r

// Parse a call's argument list (raw serialization) starting just past `(`; returns the args
// fragment — the argument RAW nodes comma-separated (`<r0>,<r1>`; empty for no args) — the position
// past the `)`, and the threaded memory. The raw counterpart of parse_args: a LOOP (not
// self-recursion) with a fresh-record accumulator (the parse_add/raw_add shape), each iteration
// parsing one argument via raw_bitor and appending it into a fresh buffer.
fn raw_args(mem: string, pos: i64, len: i64) -> Rr effects[alloc, state] =
  let sw0: MI = skip_ws(mem, pos, len) in
  let seed: Rr = { mem: sw0.mem, raw: string_with_capacity(1), next: sw0.i } in
  let done: Rr =
    loop a = seed while (if a.next < len then to_i64(string_get(a.mem, a.next)) != 41 else false) do
      let cur: Rr = a in
      let arg: Rr = raw_bitor(cur.mem, cur.next, len) in
      let cap: i64 = string_len(cur.raw) + string_len(arg.raw) + 4 in
      let base: string = push_str(string_with_capacity(cap), cur.raw) in
      let s0: string = if string_len(base) == 0 then base else push_byte(base, to_u8(44)) in
      let s1: string = push_str(s0, arg.raw) in
      let sw: MI = skip_ws(arg.mem, arg.next, len) in
      let nextpos: i64 = if (if sw.i < len then to_i64(string_get(sw.mem, sw.i)) == 44 else false) then sw.i + 1 else sw.i in
      let nx: Rr = { mem: sw.mem, raw: s1, next: nextpos } in nx
  in
  let r: Rr = { mem: done.mem, raw: done.raw, next: done.next + 1 } in r

// raw call := `<name>` `(` args `)` -> {"args":[<raw arg nodes>],"kind":"call","name":"<name>"}.
// The argument raw nodes are embedded INLINE (the dual serialization). Exercised by mutual recursion:
// a clique member's body is raw-serialized for the WL ordering colour (member_color -> raw_bitor),
// so a cross-member/self call WITH arguments must serialize them or the colour (and member order)
// diverges from the Rust importer. (No migration is built for a recursion group, so this is the only
// path that reaches it; a two-function DAG's canonical-first never calls, so it is unexercised there.)
fn raw_call(mem: string, p: i64, e: i64, len: i64) -> Rr effects[alloc, state] =
  let ar: Rr = raw_args(mem, e + 1, len) in
  let argsfrag: string = ar.raw in
  let m1: string = ar.mem in
  let cap: i64 = string_len(argsfrag) + (e - p) + 48 in
  let p0: string = push_lit(string_with_capacity(cap), b"{\"args\":[") in
  let pa: string = push_str(p0, argsfrag) in
  let p1: string = push_lit(pa, b"],\"kind\":\"call\",\"name\":\"") in
  let nb: PRR = push_range(p1, m1, p, e) in
  let p2: string = push_lit(nb.out, b"\"}") in
  let r: Rr = { mem: nb.mem, raw: p2, next: ar.next } in r

// raw unary := ('-'|'~'|'!') unary | atom
fn raw_unary(mem: string, pos: i64, len: i64) -> Rr effects[alloc, state] =
  let sw: MI = skip_ws(mem, pos, len) in
  let m1: string = sw.mem in
  let p: i64 = sw.i in
  if p < len then
    (if is_unary_op(to_i64(string_get(m1, p))) then
       let opb: i64 = to_i64(string_get(m1, p)) in
       let inner: Rr = raw_unary(m1, p + 1, len) in
       let node: string = raw_unary_node(opb, inner.raw) in
       let r: Rr = { mem: inner.mem, raw: node, next: inner.next } in r
     else raw_atom(m1, p, len))
  else raw_atom(m1, p, len)

// raw mul := unary (('*'|'/'|'%') unary)*
fn raw_mul(mem: string, pos: i64, len: i64) -> Rr effects[alloc, state] =
  let lft: Rr = raw_unary(mem, pos, len) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Rr = { mem: s0.mem, raw: lft.raw, next: s0.i } in
  let done: Rr =
    loop a = seed while (if a.next < len then is_mulop(to_i64(string_get(a.mem, a.next))) else false) do
      let cur: Rr = a in
      let opb: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let rgt: Rr = raw_unary(cur.mem, cur.next + 1, len) in
      let node: string = raw_binary_node(cur.raw, opb, 0, rgt.raw) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Rr = { mem: s1.mem, raw: node, next: s1.i } in nx
  in
  let r: Rr = { mem: done.mem, raw: done.raw, next: done.next } in r

// raw add := mul (('+'|'-') mul)*
fn raw_add(mem: string, pos: i64, len: i64) -> Rr effects[alloc, state] =
  let lft: Rr = raw_mul(mem, pos, len) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Rr = { mem: s0.mem, raw: lft.raw, next: s0.i } in
  let done: Rr =
    loop a = seed while (if a.next < len then is_addop(to_i64(string_get(a.mem, a.next))) else false) do
      let cur: Rr = a in
      let opb: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let rgt: Rr = raw_mul(cur.mem, cur.next + 1, len) in
      let node: string = raw_binary_node(cur.raw, opb, 0, rgt.raw) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Rr = { mem: s1.mem, raw: node, next: s1.i } in nx
  in
  let r: Rr = { mem: done.mem, raw: done.raw, next: done.next } in r

// raw shift := add (('<<'|'>>') add)*
fn raw_shift(mem: string, pos: i64, len: i64) -> Rr effects[alloc, state] =
  let lft: Rr = raw_add(mem, pos, len) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Rr = { mem: s0.mem, raw: lft.raw, next: s0.i } in
  let done: Rr =
    loop a = seed while (if a.next + 1 < len then is_shift_op(to_i64(string_get(a.mem, a.next)), to_i64(string_get(a.mem, a.next + 1))) else false) do
      let cur: Rr = a in
      let ob1: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let ob2: i64 = to_i64(string_get(cur.mem, cur.next + 1)) in
      let rgt: Rr = raw_add(cur.mem, cur.next + 2, len) in
      let node: string = raw_binary_node(cur.raw, ob1, ob2, rgt.raw) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Rr = { mem: s1.mem, raw: node, next: s1.i } in nx
  in
  let r: Rr = { mem: done.mem, raw: done.raw, next: done.next } in r

// raw relational := shift (('<'|'>'|'<='|'>=') shift)*   (`<=`/`>=` are two-char)
fn raw_relational(mem: string, pos: i64, len: i64) -> Rr effects[alloc, state] =
  let lft: Rr = raw_shift(mem, pos, len) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Rr = { mem: s0.mem, raw: lft.raw, next: s0.i } in
  let done: Rr =
    loop a = seed while (if a.next < len then is_rel_start(to_i64(string_get(a.mem, a.next)), (if a.next + 1 < len then to_i64(string_get(a.mem, a.next + 1)) else 0)) else false) do
      let cur: Rr = a in
      let ob1: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let b2: i64 = if cur.next + 1 < len then to_i64(string_get(cur.mem, cur.next + 1)) else 0 in
      let two: bool = b2 == 61 in
      let ob2: i64 = if two then 61 else 0 in
      let oplen: i64 = if two then 2 else 1 in
      let rgt: Rr = raw_shift(cur.mem, cur.next + oplen, len) in
      let node: string = raw_binary_node(cur.raw, ob1, ob2, rgt.raw) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Rr = { mem: s1.mem, raw: node, next: s1.i } in nx
  in
  let r: Rr = { mem: done.mem, raw: done.raw, next: done.next } in r

// raw equality := relational (('=='|'!=') relational)*
fn raw_equality(mem: string, pos: i64, len: i64) -> Rr effects[alloc, state] =
  let lft: Rr = raw_relational(mem, pos, len) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Rr = { mem: s0.mem, raw: lft.raw, next: s0.i } in
  let done: Rr =
    loop a = seed while (if a.next + 1 < len then is_eq_start(to_i64(string_get(a.mem, a.next)), to_i64(string_get(a.mem, a.next + 1))) else false) do
      let cur: Rr = a in
      let ob1: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let ob2: i64 = to_i64(string_get(cur.mem, cur.next + 1)) in
      let rgt: Rr = raw_relational(cur.mem, cur.next + 2, len) in
      let node: string = raw_binary_node(cur.raw, ob1, ob2, rgt.raw) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Rr = { mem: s1.mem, raw: node, next: s1.i } in nx
  in
  let r: Rr = { mem: done.mem, raw: done.raw, next: done.next } in r

// raw bitand := equality (('&' not '&&') equality)*
fn raw_bitand(mem: string, pos: i64, len: i64) -> Rr effects[alloc, state] =
  let lft: Rr = raw_equality(mem, pos, len) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Rr = { mem: s0.mem, raw: lft.raw, next: s0.i } in
  let done: Rr =
    loop a = seed while (if a.next < len then is_and_op(to_i64(string_get(a.mem, a.next)), (if a.next + 1 < len then to_i64(string_get(a.mem, a.next + 1)) else 0)) else false) do
      let cur: Rr = a in
      let opb: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let rgt: Rr = raw_equality(cur.mem, cur.next + 1, len) in
      let node: string = raw_binary_node(cur.raw, opb, 0, rgt.raw) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Rr = { mem: s1.mem, raw: node, next: s1.i } in nx
  in
  let r: Rr = { mem: done.mem, raw: done.raw, next: done.next } in r

// raw bitxor := bitand ('^' bitand)*
fn raw_bitxor(mem: string, pos: i64, len: i64) -> Rr effects[alloc, state] =
  let lft: Rr = raw_bitand(mem, pos, len) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Rr = { mem: s0.mem, raw: lft.raw, next: s0.i } in
  let done: Rr =
    loop a = seed while (if a.next < len then is_xor_op(to_i64(string_get(a.mem, a.next))) else false) do
      let cur: Rr = a in
      let opb: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let rgt: Rr = raw_bitand(cur.mem, cur.next + 1, len) in
      let node: string = raw_binary_node(cur.raw, opb, 0, rgt.raw) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Rr = { mem: s1.mem, raw: node, next: s1.i } in nx
  in
  let r: Rr = { mem: done.mem, raw: done.raw, next: done.next } in r

// raw logand := bitxor ('&&' bitxor)*   (op string is the two source bytes "&&")
fn raw_logand(mem: string, pos: i64, len: i64) -> Rr effects[alloc, state] =
  let lft: Rr = raw_bitxor(mem, pos, len) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Rr = { mem: s0.mem, raw: lft.raw, next: s0.i } in
  let done: Rr =
    loop a = seed while (if a.next + 1 < len then is_logand(to_i64(string_get(a.mem, a.next)), to_i64(string_get(a.mem, a.next + 1))) else false) do
      let cur: Rr = a in
      let rgt: Rr = raw_bitxor(cur.mem, cur.next + 2, len) in
      let node: string = raw_binary_node(cur.raw, 38, 38, rgt.raw) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Rr = { mem: s1.mem, raw: node, next: s1.i } in nx
  in
  let r: Rr = { mem: done.mem, raw: done.raw, next: done.next } in r

// raw logor := logand ('||' logand)*   (op string is the two source bytes "||")
fn raw_logor(mem: string, pos: i64, len: i64) -> Rr effects[alloc, state] =
  let lft: Rr = raw_logand(mem, pos, len) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Rr = { mem: s0.mem, raw: lft.raw, next: s0.i } in
  let done: Rr =
    loop a = seed while (if a.next + 1 < len then is_logor(to_i64(string_get(a.mem, a.next)), to_i64(string_get(a.mem, a.next + 1))) else false) do
      let cur: Rr = a in
      let rgt: Rr = raw_logand(cur.mem, cur.next + 2, len) in
      let node: string = raw_binary_node(cur.raw, 124, 124, rgt.raw) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Rr = { mem: s1.mem, raw: node, next: s1.i } in nx
  in
  let r: Rr = { mem: done.mem, raw: done.raw, next: done.next } in r

// raw bitor := logor (('|' not '||') logor)*   (the raw serializer's entry point)
fn raw_bitor(mem: string, pos: i64, len: i64) -> Rr effects[alloc, state] =
  let lft: Rr = raw_logor(mem, pos, len) in
  let s0: MI = skip_ws(lft.mem, lft.next, len) in
  let seed: Rr = { mem: s0.mem, raw: lft.raw, next: s0.i } in
  let done: Rr =
    loop a = seed while (if a.next < len then is_or_op(to_i64(string_get(a.mem, a.next)), (if a.next + 1 < len then to_i64(string_get(a.mem, a.next + 1)) else 0)) else false) do
      let cur: Rr = a in
      let opb: i64 = to_i64(string_get(cur.mem, cur.next)) in
      let rgt: Rr = raw_logor(cur.mem, cur.next + 1, len) in
      let node: string = raw_binary_node(cur.raw, opb, 0, rgt.raw) in
      let s1: MI = skip_ws(rgt.mem, rgt.next, len) in
      let nx: Rr = { mem: s1.mem, raw: node, next: s1.i } in nx
  in
  let r: Rr = { mem: done.mem, raw: done.raw, next: done.next } in r

// ---------------------------------------------------------------------------
// axis 2: the migration/history chain for a multi-function program
// ---------------------------------------------------------------------------

// Build the create_function operation's `params` array fragment for function `sl` by RE-DERIVING
// its parameter scope from source (find `(` past the name, scan_params) and serializing it with
// push_op_params_at. Factored out so the parameter Scope lives in THIS frame, not build_mig1's
// (which is already tight). Returns the fragment in `out` with `mem` threaded back.
fn build_op_params(mem: string, sl: Sl, len: i64) -> PRR effects[alloc, state] =
  let op: MI = find_byte(mem, sl.ne, len, 40) in
  let seed: Scope = { ids: [0x0; 12], n: 0, rgord: 0 - 1, aord: 0 } in
  let pr: PpR = scan_params(op.mem, op.i, len, seed) in
  // Size from the OUTPUT, not the source span: each parameter expands `<name>: <type>` (a few
  // source bytes) into `{"name":"<name>","type":"<type>"}` (a ~21-byte envelope + name + type),
  // so a source-span cap UNDER-sizes and string_with_capacity TRAPS once enough params accrue.
  let cap: i64 = (sl.bs - op.i) + pr.ps.n * 48 + 64 in
  push_op_params_at(string_with_capacity(cap), pr.mem, pr.ps, 0)

// Build the first migration's history hash for function `sl` (the first in canonical
// order, ordinal 0, parent history = genesis). Assembles the canonical migration JSON
// (operation = create_function with the RAW-AST body and the parameter list, plus the
// root_is_current/name_is_available preconditions and root_exists/function_source_matches
// postconditions), hashes it under MIGRATION_DOMAIN, then folds that into the history hash under
// HISTORY_DOMAIN (preimage: "" + \0 + migration_hash + \0 + output_root). `genesis` and
// `out1` are consumed; `mem` is threaded back. The result feeds the SECOND symbol's birth.
// The payload assembly is split across two helpers (mig1_pay_a/_b) for the frame budget.
// Build the migration that creates function `sl` (canonical ordinal `ord`) and fold it into
// the running history hash. `input_root` is the root BEFORE this migration (the genesis root
// for ordinal 0, else the previous output root); `parent` is the parent HISTORY hash (the
// EMPTY string for the genesis migration — serialized as JSON `null` and contributing nothing
// to the history preimage — else the previous migration's history hash). `out1` is this
// migration's output root. Assembles the canonical migration JSON (operation = create_function
// with the RAW-AST body + parameter list, plus the root_is_current/name_is_available
// preconditions and root_exists/function_source_matches postconditions), hashes it under
// MIGRATION_DOMAIN, then folds that into the history hash under HISTORY_DOMAIN (preimage:
// parent + \0 + migration_hash + \0 + output_root). The result feeds the NEXT symbol's birth.
// Generalized from the two-function case (where it only ran for ordinal 0 / parent = genesis):
// the parent-history field value is built here (threading the raw parent back for the preimage)
// and the ordinal is rendered into the birth_seed, so a multi-function chain can call it per step.
// The parent_history_hash field + preimage parent for the GENESIS migration: JSON `null` and
// an empty preimage prefix. Straight-line (no conditional), so safe to return a record after
// building the literal.
fn null_field() -> MigPar effects[alloc, state] =
  let r: MigPar = { field: push_lit(string_with_capacity(8), b"null"), par: string_with_capacity(0) } in r

// The parent_history_hash field + preimage parent for a NON-genesis migration: the parent hash
// quoted (`"<hash>"`) for the field, and the raw hash threaded back as `par`. Straight-line (a
// helper, NOT a branch), so the string-building does not miscompile — building the quoted field
// inside build_mig1's old record-returning conditional did (the aggregate-return v0 SIGTRAP).
fn quote_field(parent: string) -> MigPar effects[alloc, state] =
  let q0: string = push_lit(string_with_capacity(80), b"\"") in
  let kq: OS = push_kept(q0, parent) in
  let q1: string = push_lit(kq.out, b"\"") in
  let r: MigPar = { field: q1, par: kq.s } in r

// `field` is the pre-built parent_history_hash JSON field value (the literal `null` for the
// genesis migration, else the quoted parent hash) and `par` the raw parent history hash (empty
// for genesis) for the history preimage. They are built by the CALLER, NOT chosen here by a
// conditional: building the quoted field inside a record-returning `if` (the non-genesis branch)
// miscompiles to a v0 SIGTRAP (the aggregate-return bug — keep conditionals to pure moves), and
// the caller's site is straight-line. `field` and `par` derive from the same parent hash there.
fn build_mig1(input_root: string, field: string, par: string, out1: string, mem: string, sl: Sl, ord: i64) -> MH effects[alloc, state] =
  // Serialize the first function's body to the RAW AST (the migration body) and its parameter
  // list (the operation `params`) once, here, so the parse's stack frame is raw_bitor's /
  // build_op_params's, not the already-tight payload builders'.
  let len: i64 = string_len(mem) in
  let opr: PRR = build_op_params(mem, sl, len) in
  let opfrag: string = opr.out in
  let memo: string = opr.mem in
  let bodyr: Rr = raw_bitor(memo, sl.bs, len) in
  let rawBody: string = bodyr.raw in
  let mem1: string = bodyr.mem in
  let ctx: MigCtx = { field: field, ord: ord } in
  let c: Pc = mig1_pay_a(input_root, out1, mem1, sl, rawBody, opfrag, ctx) in
  let b: MigB = mig1_pay_b(c) in
  let pay: string = b.pay in
  let o1: string = b.o1 in
  let m2: string = b.mem in
  let mig1: string = hash_domain(b"codedb/migration/v1\0", pay) in
  // history preimage: parent + \0 + migration_hash + \0 + output_root. Sized for a NON-empty
  // parent (71) + the two hashes (71 each) + separators = up to ~215; the 2-fn case had an empty
  // parent (~144) so 192 sufficed, but a 2nd+ migration's parent is a full hash and overflowed.
  let h0: string = push_str(string_with_capacity(256), par) in
  let h0b: string = push_byte(h0, to_u8(0)) in
  let h1: string = push_str(h0b, mig1) in
  let h2: string = push_byte(h1, to_u8(0)) in
  let h3: string = push_str(h2, o1) in
  let hh1: string = hash_domain(b"codedb/history/v1\0", h3) in
  let r: MH = { mem: m2, hash: hh1 } in r

// First half of the migration payload: input_root_hash + operation + output_root_hash +
// parent_history_hash. The operation `body` is the raw-AST JSON `rawBody` (built by the
// caller, embedded inline and KEPT for the postcondition); `return_type` is the type NAME.
// Extracts the owned name copy and carries it (plus genesis, out1, the kept rawBody, and the
// return type code) forward via `Pc`. The buffer is sized from `rawBody` (it appears here AND
// in the postcondition half, so the full payload is ~2*len(rawBody) + the envelope).
fn mig1_pay_a(input_root: string, out1: string, mem: string, sl: Sl, rawBody: string, opparams: string, ctx: MigCtx) -> Pc effects[alloc, state] =
  let nb: PRR = push_range(string_with_capacity(64), mem, sl.ns, sl.ne) in
  let nameStr: string = nb.out in
  let m2: string = nb.mem in
  // rawBody and opparams each appear TWICE (operation + function_source_matches postcondition,
  // both built into this same continuation buffer), so size for two copies of each.
  let cap: i64 = string_len(rawBody) * 2 + string_len(opparams) * 2 + 1024 in
  let a0: string = push_lit(string_with_capacity(cap), b"{\"input_root_hash\":\"") in
  let kg1: OS = push_kept(a0, input_root) in
  let a1: string = kg1.out in
  let g1: string = kg1.s in
  let a2: string = push_lit(a1, b"\",\"operation\":{\"birth_seed\":\"import:main:") in
  let kn1: OS = push_kept(a2, nameStr) in
  let a3: string = kn1.out in
  let n1: string = kn1.s in
  // birth_seed ends `:<ordinal>` (the canonical ordinal, was hard-coded 0 in the 2-fn case).
  let a3c: string = push_byte(a3, to_u8(58)) in
  let a3d: string = push_dec(a3c, ctx.ord) in
  let a4: string = push_lit(a3d, b"\",\"body\":") in
  let kb1: OS = push_kept(a4, rawBody) in
  let a5: string = kb1.out in
  let body1: string = kb1.s in
  let a6: string = push_lit(a5, b",\"effects\":[],\"kind\":\"create_function\",\"module\":\"main\",\"name\":\"") in
  // Hand off to the continuation (the operation name onward) — split for the v0 frame budget,
  // which the ordinal/parent-history parameterization pushed `mig1_pay_a` over.
  let mid: PayMid = { buf: a6, mem: m2, name: n1, gen: g1, body: body1 } in
  mig1_pay_a2(mid, out1, opparams, sl, ctx)

// The continuation of the operation payload: the (second) name occurrence, params,
// region_params, return_type, output_root_hash, and the parent_history_hash field — finishing
// the `Pc` carrier for mig1_pay_b. `mid` carries the partial buffer plus the threaded name /
// input-root / body that the postconditions reuse.
fn mig1_pay_a2(mid: PayMid, out1: string, opparams: string, sl: Sl, ctx: MigCtx) -> Pc effects[alloc, state] =
  let kn2: OS = push_kept(mid.buf, mid.name) in
  let a7: string = kn2.out in
  let n2: string = kn2.s in
  let a7p0: string = push_lit(a7, b"\",\"params\":[") in
  let kop: OS = push_kept(a7p0, opparams) in
  let a7p1: string = kop.out in
  let opp1: string = kop.s in
  let a7r: string = push_lit(a7p1, b"],\"region_params\":[],\"return_type\":\"") in
  let a7t: string = push_type_name(a7r, sl.rtc) in
  let a8: string = push_lit(a7t, b"\"},\"output_root_hash\":\"") in
  let ko1: OS = push_kept(a8, out1) in
  let a9: string = ko1.out in
  let o1: string = ko1.s in
  // parent_history_hash: the pre-built field value (JSON `null`, or the quoted parent hash).
  let a9p: string = push_lit(a9, b"\",\"parent_history_hash\":") in
  let a9f: string = push_str(a9p, ctx.field) in
  let a10: string = push_lit(a9f, b",") in
  let r: Pc = { out: a10, mem: mid.mem, name: n2, gen: mid.gen, o1: o1, body: mid.body, opparams: opp1, rtc: sl.rtc } in r

// Second half of the migration payload: postconditions + preconditions. Returns the full
// payload, out1 (kept for the history preimage), and the threaded memory.
fn mig1_pay_b(c: Pc) -> MigB effects[alloc, state] =
  let buf: string = c.out in
  let mem: string = c.mem in
  let name: string = c.name in
  let gen: string = c.gen in
  let o1in: string = c.o1 in
  let body: string = c.body in
  let opparams: string = c.opparams in
  let rtc: i64 = c.rtc in
  let b0: string = push_lit(buf, b"\"postconditions\":[{\"kind\":\"root_exists\",\"root\":\"") in
  let ko2: OS = push_kept(b0, o1in) in
  let b1: string = ko2.out in
  let o2: string = ko2.s in
  let b2: string = push_lit(b1, b"\"},{\"body\":") in
  let b3: string = push_str(b2, body) in
  let b4: string = push_lit(b3, b",\"effects\":[],\"kind\":\"function_source_matches\",\"module\":\"main\",\"name\":\"") in
  let kn3: OS = push_kept(b4, name) in
  let b5: string = kn3.out in
  let n3: string = kn3.s in
  let b6p0: string = push_lit(b5, b"\",\"params\":[") in
  let b6p1: string = push_str(b6p0, opparams) in
  let b6r: string = push_lit(b6p1, b"],\"region_params\":[],\"return_type\":\"") in
  let b6t: string = push_type_name(b6r, rtc) in
  let b6: string = push_lit(b6t, b"\"}],\"preconditions\":[{\"kind\":\"root_is_current\",\"root\":\"") in
  let b7: string = push_str(b6, gen) in
  let b8: string = push_lit(b7, b"\"},{\"kind\":\"name_is_available\",\"module\":\"main\",\"name\":\"") in
  let b9: string = push_str(b8, n3) in
  let b10: string = push_lit(b9, b"\"}]}") in
  let r: MigB = { pay: b10, o1: o2, mem: mem } in r

// Build the ProgramRoot for a two-function program from the functions ALREADY in canonical
// order (`first`, `second` — the caller, import_root, applies the dependency-driven toposort):
// build the first's single-symbol ProgramRoot (out1), fold it through the first migration into
// the running history (hh1), then build the final two-symbol ProgramRoot — the first symbol
// born at "genesis"/0, the second at hh1/1. The second function's body may call the first
// (resolved to its genesis/0 symbol by parse_call); the first, being the dependency, does not.
fn build_two_root(mem: string, first: Sl, second: Sl) -> string effects[alloc, state] =
  let r1: MH = build_root1(mem, first) in
  let m1: string = r1.mem in
  let out1: string = r1.hash in
  let genesis: string = build_genesis_root() in
  let mp: MigPar = null_field() in
  let mh: MH = build_mig1(genesis, mp.field, mp.par, out1, m1, first, 0) in
  let m2: string = mh.mem in
  let hh1: string = mh.hash in
  build_root2(m2, first, second, hh1)

// Concatenate two move-only strings into a FRESH buffer sized for both. Used to grow the
// chain's symbol/def/sig/param-name accumulators: appending into `a`'s own buffer would overflow
// it (a symbol hash is allocated at ~71-byte capacity, so push_str-ing a second hash traps).
fn concat2(a: string, b: string) -> string effects[alloc, state] =
  let cap: i64 = string_len(a) + string_len(b) + 16 in
  push_str(push_str(string_with_capacity(cap), a), b)

// Extract function `idx`'s source span from the packed spans array.
fn sl_at(spans: array<i64, 32>, idx: i64) -> Sl =
  let b: i64 = idx * 4 in
  let r: Sl = { ns: spans[b], ne: spans[b + 1], bs: spans[b + 2], rtc: spans[b + 3] } in r

// Write function `n`'s four span fields into the packed array (its own frame, so the four
// chained array<i64,32> values don't blow the caller's loop frame). Shared by parse_all +
// reorder_spans.
fn set_span(spans: array<i64, 32>, n: i64, ns: i64, ne: i64, bs: i64, rtc: i64) -> array<i64, 32> =
  let b: i64 = n * 4 in
  let a1: array<i64, 32> = array_set(spans, b, ns) in
  let a2: array<i64, 32> = array_set(a1, b + 1, ne) in
  let a3: array<i64, 32> = array_set(a2, b + 2, bs) in
  array_set(a3, b + 3, rtc)

// Reorder the packed `src` spans into canonical order given `perm` (perm[k] = the source index
// placed at canonical position k). A Copy loop with the per-row writes in set_span's frame.
fn reorder_spans(src: array<i64, 32>, perm: array<i64, 8>, n: i64) -> array<i64, 32> =
  let seed: RA = { arr: [0x0; 32], k: 0 } in
  let done: RA =
    loop a = seed while a.k < n do
      let cur: RA = a in
      let si: i64 = perm[cur.k] * 4 in
      let nx: array<i64, 32> = set_span(cur.arr, cur.k, src[si], src[si + 1], src[si + 2], src[si + 3]) in
      (let r: RA = { arr: nx, k: cur.k + 1 } in r)
  in done.arr

// Build the n×n call-adjacency bitmask for an n-function program (source-order spans, n <= 8):
// bit (i*n + j) is set iff function i's body calls function j by name. Self-calls (i == j) are
// included so a self-recursive function reads as a 1-cycle (rejected by kahnN). Function i's body
// span is [bs_i, be_i) where be_i is the NEXT function's name start (its `fn ` keyword plus
// whitespace contains no `identifier(` pattern, so it never matches a call) or `len` for the last
// function. body_calls matches the parser exactly (an identifier == the name IMMEDIATELY followed
// by `(`); it consumes and returns the move-only `mem`, so the loop accumulator carries it.
fn adjN(mem: string, spans: array<i64, 32>, n: i64, len: i64) -> Adj effects[alloc, state] =
  let seed: AdjAcc = { mask: 0, k: 0, mem: mem } in
  let done: AdjAcc =
    loop a = seed while a.k < n * n do
      let cur: AdjAcc = a in
      let i: i64 = cur.k / n in
      let j: i64 = cur.k - i * n in
      let bj: i64 = j * 4 in
      let bs: i64 = spans[i * 4 + 2] in
      let be: i64 = if i < n - 1 then spans[(i + 1) * 4] else len in
      let bc: REq = body_calls(cur.mem, bs, be, spans[bj], spans[bj + 1]) in
      let nbit: i64 = if bc.eq then (1 << cur.k) else 0 in
      (let r: AdjAcc = { mask: cur.mask | nbit, k: cur.k + 1, mem: bc.mem } in r)
  in
  let res: Adj = { mask: done.mask, mem: done.mem } in res

// Kahn toposort of an n-function call graph (the `mask` from adjN): repeatedly emit the
// alphabetically-smallest function whose callees are ALL already emitted (a callee is created
// before its caller). perm[k] = the source index emitted at canonical position k. `ok` is false
// when some round has no ready function — the graph has a cycle (a clique, a smaller SCC plus
// singletons, or a self-recursive function), which forms a recursion group and is deferred. Copy
// accumulators throughout; the name tie-break reuses name_le (which threads the owned `mem`).
// `allb` = the low-n-bit mask; `done ^ allb` is the complement-within-n-bits of `done`.
// One Kahn round: scan functions 0..n-1 and return the alphabetically-smallest READY one (not yet
// emitted, all callees emitted — its deps are a subset of `done`). best = -1 if none is ready (a
// cycle). Factored out of kahnN so its min-scan op tree lives in its own frame (kahnN's was over
// the v0 budget). name_le threads the owned `mem`; allb = the low-n-bit mask.
fn kahn_pick(done: i64, mask: i64, n: i64, spans: array<i64, 32>, mem: string) -> KMin =
  let allb: i64 = (1 << n) - 1 in
  let iseed: KMin = { best: 0 - 1, i: 0, mem: mem } in
  let done_pick: KMin =
    loop a = iseed while a.i < n do
      let inner: KMin = a in
      let isdone: bool = ((done >> inner.i) & 1) == 1 in
      let deps: i64 = (mask >> (inner.i * n)) & allb in
      // ready: not yet emitted AND every callee already emitted (deps is a subset of done,
      // i.e. deps AND the complement-within-n-bits of done is empty).
      let ready: bool = if isdone then false else (deps & (done ^ allb)) == 0 in
      if ready then
        if inner.best < 0 then (let r: KMin = { best: inner.i, i: inner.i + 1, mem: inner.mem } in r)
        else
          let ab: i64 = inner.i * 4 in
          let bb: i64 = inner.best * 4 in
          let le: REq = name_le(inner.mem, spans[ab], spans[ab + 1], spans[bb], spans[bb + 1]) in
          let nb: i64 = if le.eq then inner.i else inner.best in
          (let r: KMin = { best: nb, i: inner.i + 1, mem: le.mem } in r)
      else (let r: KMin = { best: inner.best, i: inner.i + 1, mem: inner.mem } in r)
  in
  let res: KMin = { best: done_pick.best, i: done_pick.i, mem: done_pick.mem } in res

fn kahnN(mem: string, spans: array<i64, 32>, mask: i64, n: i64) -> Topo3 effects[alloc, state] =
  let allb: i64 = (1 << n) - 1 in
  let oseed: KOut = { perm: [0x0; 8], done: 0, p: 0, mem: mem } in
  let fin: KOut =
    loop o = oseed while o.p < n do
      let cur: KOut = o in
      let br: KMin = kahn_pick(cur.done, mask, n, spans, cur.mem) in
      let chosen: i64 = br.best in
      // chosen < 0 means a cycle (no ready node); leave perm/done unchanged so `done` never
      // reaches `allb` and `ok` ends false. The `1 << chosen` is guarded by the `if` (never
      // shifts by a negative amount, since `if` is control flow, not the strict `&` operator).
      let np: array<i64, 8> = if chosen < 0 then cur.perm else array_set(cur.perm, cur.p, chosen) in
      let ndone: i64 = if chosen < 0 then cur.done else (cur.done | (1 << chosen)) in
      (let r: KOut = { perm: np, done: ndone, p: cur.p + 1, mem: br.mem } in r)
  in
  let res: Topo3 = { perm: fin.perm, mem: fin.mem, ok: fin.done == allb } in res

// Canonical ordering of an n-function program: build the call graph then Kahn-toposort it.
// For independent functions this is the alphabetical (display) order; a dependency edge forces
// the callee earlier, so canonical order diverges from display order (as the chain requires).
fn toposortN(mem: string, spans: array<i64, 32>, n: i64, len: i64) -> Topo3 effects[alloc, state] =
  let a: Adj = adjN(mem, spans, n, len) in
  kahnN(a.mem, spans, a.mask, n)

// Parse one top-level function at `pos`: its header then its body (only to locate the body's
// END, so the next `fn` or EOF is found — the body is re-parsed on demand later). Factored out
// of parse_all's loop so the HdrR / Pr / parameter-scope locals stay off the loop's frame.
fn parse_one(mem: string, pos: i64, len: i64) -> POne effects[alloc, state] =
  let hdr: HdrR = parse_header(mem, pos, len) in
  let np: i64 = hdr.params.n in
  let body: Pr = parse_bitor(hdr.mem, hdr.bodypos, len, hdr.params, np, hdr.rettyc) in
  let aw: MI = skip_ws(body.mem, body.next, len) in
  let r: POne = { mem: aw.mem, ns: hdr.ns, ne: hdr.ne, bs: hdr.bodypos, rtc: hdr.rettyc, next: aw.i } in r

// Scan every top-level `fn` declaration, recording each one's name range, body start, and
// return type into the packed spans array. Generalizes import_root's one-vs-two detection.
fn parse_all(mem: string, len: i64) -> Prog effects[alloc, state] =
  let seed: PAcc = { mem: mem, spans: [0x0; 32], n: 0, pos: 0 } in
  let done: PAcc =
    loop a = seed while a.pos < len do
      let cur: PAcc = a in
      let one: POne = parse_one(cur.mem, cur.pos, len) in
      let nx: array<i64, 32> = set_span(cur.spans, cur.n, one.ns, one.ne, one.bs, one.rtc) in
      (let r: PAcc = { mem: one.mem, spans: nx, n: cur.n + 1, pos: one.next } in r)
  in
  let r: Prog = { mem: done.mem, spans: done.spans, n: done.n } in r

// Append the extra-callee table entries for canonical ordinals [j, kmax) to `buf`: for each, the
// function's name (source `spans` range) + a `\0` separator + its 71-char symbol (the j-th slice
// of the canonical `syms` accumulator). Self-recursive (a one-member recursion group), threading
// the buffer plus the borrowed source + symbols. Empty when kmax <= 1 (only ordinal 0, the
// genesis default, precedes function 1). `\0` cannot appear in a name or a "sha256:"-hash, so it
// is an unambiguous separator that xc_scan splits on.
fn append_entries(buf: string, src: string, syms: string, spans: array<i64, 32>, j: i64, kmax: i64) -> EntAcc effects[state] =
  if j >= kmax then (let r: EntAcc = { buf: buf, src: src, syms: syms } in r)
  else
    let nm: PRR = push_range(buf, src, spans[j * 4], spans[j * 4 + 1]) in
    let b1: string = push_byte(nm.out, to_u8(0)) in
    let sx: PRR = push_range(b1, syms, j * 71, j * 71 + 71) in
    append_entries(sx.out, nm.mem, sx.mem, spans, j + 1, kmax)

// Build the augmented buffer for function k's typed-body parse: a COPY of the source followed by
// the extra-callee table (entries for canonical ordinals 1..k-1). build_fn_objs_xc parses it with
// the SOURCE length as the bound, so only parse_call reads the table (signalled by string_len >
// len). The PLAIN source is threaded back too (the migration's raw serialization needs it without
// the table), as is the symbol accumulator. push_kept copies the source while keeping the original.
fn build_augN(src: string, syms: string, spans: array<i64, 32>, k: i64) -> Aug2 effects[alloc, state] =
  let slen: i64 = string_len(src) in
  let cap: i64 = slen + k * 96 + 16 in
  let cp: OS = push_kept(string_with_capacity(cap), src) in
  let ent: EntAcc = append_entries(cp.out, cp.s, syms, spans, 1, k) in
  let r: Aug2 = { aug: ent.buf, src: ent.src, syms: ent.syms, slen: slen } in r

// Chain step 0: build the canonical-first function's objects (birth = genesis, ordinal 0; it calls
// nothing, so no extra-callee table), assemble its single-symbol root (out0), and run the first
// migration (null parent history) to the running history hh0. out0 is needed twice (this
// migration's output AND the next migration's input), so it is copied. `spans` is canonical-order.
fn bt0(mem: string, spans: array<i64, 32>) -> ChainAcc effects[alloc, state] =
  let sl0: Sl = sl_at(spans, 0) in
  let genstr: string = push_lit(string_with_capacity(16), b"genesis") in
  let foA: FObj = build_fn_objs(mem, sl0, genstr, 0) in
  let l0: i64 = string_len(foA.pn) in
  let pnoff: array<i64, 9> = array_set([0x0; 9], 1, l0) in
  let rin: RootStr = { mem: foA.mem, syms: foA.sym, defs: foA.def, sigs: foA.sig, pns: foA.pn } in
  let a: AsmOut = assemble_root(rin, spans, pnoff, 1) in
  let genroot: string = build_genesis_root() in
  let mp: MigPar = null_field() in
  let ko: OS = push_kept(string_with_capacity(80), a.hash) in
  let mig: MH = build_mig1(genroot, mp.field, mp.par, ko.s, a.mem, sl0, 0) in
  let r: ChainAcc = { mem: mig.mem, prevhist: mig.hash, prevroot: ko.out, syms: a.syms, defs: a.defs, sigs: a.sigs, pns: a.pns, pnoff: pnoff } in r

// A middle chain step (canonical ordinal 1 <= k <= n-2): build function k's objects (birth = the
// running history hh_{k-1}, used twice — birth AND migration parent — so copied), feeding its body
// parse the extra-callee table (calls to ordinals 1..k-1 take their real symbols; ordinal 0 the
// genesis default), accumulate, assemble out_k (the root of the first k+1 functions, copied — it
// is this migration's output AND the next migration's input), and run migration k to hh_k. The
// MIGRATION uses the plain source (ag.src) for its raw body serialization, not the augmented copy.
fn bt_mid(acc: ChainAcc, spans: array<i64, 32>, k: i64) -> ChainAcc effects[alloc, state] =
  let ag: Aug2 = build_augN(acc.mem, acc.syms, spans, k) in
  let kh: OS = push_kept(string_with_capacity(80), acc.prevhist) in
  let foC: FObj = build_fn_objs_xc(ag.aug, ag.slen, sl_at(spans, k), kh.out, k) in
  let lk: i64 = string_len(foC.pn) in
  let syms2: string = concat2(ag.syms, foC.sym) in
  let defs2: string = concat2(acc.defs, foC.def) in
  let sigs2: string = concat2(acc.sigs, foC.sig) in
  let pns2: string = concat2(acc.pns, foC.pn) in
  let pnoff2: array<i64, 9> = array_set(acc.pnoff, k + 1, acc.pnoff[k] + lk) in
  let rin: RootStr = { mem: ag.src, syms: syms2, defs: defs2, sigs: sigs2, pns: pns2 } in
  let a: AsmOut = assemble_root(rin, spans, pnoff2, k + 1) in
  let ko: OS = push_kept(string_with_capacity(80), a.hash) in
  let mp: MigPar = quote_field(kh.s) in
  let mig: MH = build_mig1(acc.prevroot, mp.field, mp.par, ko.s, a.mem, sl_at(spans, k), k) in
  let r: ChainAcc = { mem: mig.mem, prevhist: mig.hash, prevroot: ko.out, syms: a.syms, defs: a.defs, sigs: a.sigs, pns: a.pns, pnoff: pnoff2 } in r

// The last chain step (canonical ordinal k = n-1): build function k's objects (birth = hh_{k-1};
// no copy needed, no migration references it) with its extra-callee table, accumulate, and
// assemble the final n-symbol root. No migration — nothing references its history. Returns the root.
fn bt_last(acc: ChainAcc, spans: array<i64, 32>, k: i64) -> string effects[alloc, state] =
  let ag: Aug2 = build_augN(acc.mem, acc.syms, spans, k) in
  let foC: FObj = build_fn_objs_xc(ag.aug, ag.slen, sl_at(spans, k), acc.prevhist, k) in
  let lk: i64 = string_len(foC.pn) in
  let syms2: string = concat2(ag.syms, foC.sym) in
  let defs2: string = concat2(acc.defs, foC.def) in
  let sigs2: string = concat2(acc.sigs, foC.sig) in
  let pns2: string = concat2(acc.pns, foC.pn) in
  let pnoff2: array<i64, 9> = array_set(acc.pnoff, k + 1, acc.pnoff[k] + lk) in
  let rin: RootStr = { mem: ag.src, syms: syms2, defs: defs2, sigs: sigs2, pns: pns2 } in
  let a: AsmOut = assemble_root(rin, spans, pnoff2, k + 1) in
  a.hash

// Run the middle chain steps (canonical ordinals 1..n-2) by self-recursion (a one-member
// recursion group), each a create_function migration seeding the next symbol's birth. Stops at
// k = n-1 (the last function, which bt_last assembles with no migration). For n = 3 this is a
// single bt_mid (ordinal 1); for larger n it folds bt_mid over every middle ordinal.
fn chain_mid(acc: ChainAcc, k: i64, n: i64, spans: array<i64, 32>) -> ChainAcc effects[alloc, state] =
  if k >= n - 1 then acc
  else
    let ns: ChainAcc = bt_mid(acc, spans, k) in
    chain_mid(ns, k + 1, n, spans)

// Build the ProgramRoot for an n-function program (n >= 3) whose functions are already in
// canonical (toposort) order in `spans`. The chain: bt0 (the genesis-born first function + its
// migration), chain_mid (the middle functions' migrations, by recursion), bt_last (the final
// function + the n-symbol root). n-1 migrations seed the births of symbols 1..n-1.
fn build_chain_root(mem: string, spans: array<i64, 32>, n: i64) -> string effects[alloc, state] =
  let s0: ChainAcc = bt0(mem, spans) in
  let smid: ChainAcc = chain_mid(s0, 1, n, spans) in
  bt_last(smid, spans, n - 1)

// ---------------------------------------------------------------------------
// import: parse the header(s), parse the body(ies), build the objects and (for a
// multi-function program) the migration/history chain, return the ProgramRoot hash
// ---------------------------------------------------------------------------

// Adjacency-bit test: does function i call function j (bit i*3+j of adjN's 3-function mask)?
fn adjb(mask: i64, i: i64, j: i64) -> bool =
  ((mask >> (i * 3 + j)) & 1) == 1

// Can function i reach function j (i != j) in a THREE-node call graph? Exact via paths of length
// <= 2 (in a 3-node graph any reachable pair has a simple path through at most the one other node):
// direct edge i->j, or i->k->j where k is the third node. (Used only for the single-3-SCC test.)
fn reach3(mask: i64, i: i64, j: i64) -> bool =
  let k: i64 = 3 - i - j in
  if adjb(mask, i, j) then true
  else (adjb(mask, i, k) && adjb(mask, k, j))

// Is the three-function call graph a SINGLE strongly-connected component — all three mutually
// reachable? Distinguishes a single 3-clique (Inc 2) from a 2-member SCC plus a singleton or a
// self-loop plus independents (those form MULTIPLE groups -> a mixed root, deferred). All six
// ordered pairs must reach.
fn single3scc(mask: i64) -> bool =
  reach3(mask, 0, 1) && reach3(mask, 1, 0)
    && reach3(mask, 0, 2) && reach3(mask, 2, 0)
    && reach3(mask, 1, 2) && reach3(mask, 2, 1)

// Route by function count: three-or-more functions are ordered by a Kahn toposort (a callee is
// created before its caller; alphabetical tie-break — which collapses to the display order when the
// functions are independent) and handed to build_chain_root (the general n-function create_function
// chain). A toposort cycle means the functions form a recursion group. Inc 2 handles the simplest
// cyclic case: EXACTLY three functions forming a SINGLE 3-SCC whose 1-WL refinement discretizes ->
// build_clique3_root (one create_recursion_group, members WL-ordered). Other cyclic shapes (a
// non-discretizing/symmetric 3-clique, a 2-SCC + singleton, a self-loop + independents, or 4+
// cyclic functions) are routed away as a defined — if not yet correct — fallback (Inc 4). One or
// two functions take the original path (which detects self/mutual recursion). Eight is the current
// ceiling (the packed spans hold eight functions).
fn import_root(mem: string) -> string effects[alloc, state] =
  let len: i64 = string_len(mem) in
  let prog: Prog = parse_all(mem, len) in
  if prog.n >= 3 then
    let topo: Topo3 = toposortN(prog.mem, prog.spans, prog.n, len) in
    if topo.ok then
      let cspans: array<i64, 32> = reorder_spans(prog.spans, topo.perm, prog.n) in
      build_chain_root(topo.mem, cspans, prog.n)
    else
      // cyclic: a recursion group. Inc 2 = a single discretizing 3-clique (n == 3, one 3-SCC).
      if prog.n == 3 then
        let adj: Adj = adjN(topo.mem, prog.spans, 3, len) in
        let mok: string = adj.mem in
        if single3scc(adj.mask) then build_clique3_root(mok, prog.spans, len)
        else import_one_or_two(mok, len)
      else
        import_one_or_two(topo.mem, len)
  else
    import_one_or_two(prog.mem, len)

fn import_one_or_two(mem: string, len: i64) -> string effects[alloc, state] =
  let hdr0: HdrR = parse_header(mem, 0, len) in
  let m0: string = hdr0.mem in
  let rettyc: i64 = hdr0.rettyc in
  // The ONE combined scope starts as the parameter table (params at [0, np)); the body
  // parser pushes `let` bindings on top. `params` (a Copy) is reused after parsing to
  // build the signature's param list and the root's param_names.
  let params: Scope = hdr0.params in
  let np: i64 = params.n in
  // Parse fn0's body (any expression); its end (skip_ws past body.next) tells us whether a
  // second function follows. At EOF -> the single-function path (unchanged); otherwise the
  // two-function path (each body re-parsed on demand from its source start, so it may be any
  // expression — the typed parse already located fn0's body end, so no literal re-scan).
  let body: Pr = parse_bitor(m0, hdr0.bodypos, len, params, np, rettyc) in
  let mb: string = body.mem in
  let aw: MI = skip_ws(mb, body.next, len) in
  let mc: string = aw.mem in
  let pa: i64 = aw.i in
  if pa >= len then
    // One function. If its body calls its OWN name it is a one-member recursion group
    // (create_recursion_group, symbol recursion_group:0, a `recursion_groups` array, no chain —
    // the birth is genesis); build_rg_root re-parses the body with rgord = 0 so the self-call
    // resolves to that symbol. Otherwise an ordinary create_function (the EOF-detection parse's
    // body.hash is correct — rgord = -1, no self-call).
    let srr: REq = body_calls(mc, hdr0.bodypos, len, hdr0.ns, hdr0.ne) in
    let msr: string = srr.mem in
    if srr.eq then
      build_rg_root(msr, hdr0.ns, hdr0.ne, hdr0.bodypos, rettyc, len)
    else
      let sig: string = build_sig(rettyc, params) in
      let sym: string = build_sym() in
      let rd: DH = build_def(sig, sym, body.hash) in
      build_root_obj(rd.sym, rd.h, rd.sig, msr, params)
  else
    // Two functions: hand fn0's source span (f0) and fn1's start (`pa`) to the chain builder.
    // Factored out so the two-function locals stay off import_root's stack frame.
    let f0: Sl = { ns: hdr0.ns, ne: hdr0.ne, bs: hdr0.bodypos, rtc: rettyc } in
    import_two(mc, pa, len, f0)

// The two-function path: parse fn1's header (it begins at `pa`, just past fn0's body), detect the
// call-graph edges, and dispatch. If the two functions call EACH OTHER (c01 && c10) they form a
// MUTUAL-RECURSION clique — a two-member recursion group (create_recursion_group, both births
// genesis, no migration chain); the members are ordered alphabetically by name (ordinals 0,1) and
// handed to build_mutrec_root. Otherwise the dependency-driven toposort applies (a callee is created
// before its caller — put the callee first; independent functions fall back to alphabetical) and the
// ordered pair goes to build_two_root (two create_function migrations, a real chain). `f0` is fn0's
// source span. fn0's body is [f0.bs, pa) (pa = fn1's `fn`); fn1's is [hdr1.bodypos, len).
fn import_two(mem: string, pa: i64, len: i64, f0: Sl) -> string effects[alloc, state] =
  let hdr1: HdrR = parse_header(mem, pa, len) in
  let md: string = hdr1.mem in
  let c01r: REq = body_calls(md, f0.bs, pa, hdr1.ns, hdr1.ne) in
  let c01: bool = c01r.eq in
  let c10r: REq = body_calls(c01r.mem, hdr1.bodypos, len, f0.ns, f0.ne) in
  let c10: bool = c10r.eq in
  let f1: Sl = { ns: hdr1.ns, ne: hdr1.ne, bs: hdr1.bodypos, rtc: hdr1.rettyc } in
  let mutual: bool = c01 && c10 in
  if mutual then
    // mutual recursion: a two-member recursion group. Members are ordered by the WL canonical
    // refinement (NOT alphabetical for asymmetric cliques) — build_mutrec_root does that ordering,
    // so it takes the functions in SOURCE order.
    build_mutrec_root(c10r.mem, f0, f1, len)
  else
    // toposort: fn0 calls fn1 (only) -> fn1 first; fn1 calls fn0 (only) -> fn0 first; else alphabetical.
    let alc: REq = name_le(c10r.mem, f0.ns, f0.ne, hdr1.ns, hdr1.ne) in
    let mz: string = alc.mem in
    let f0le: bool = alc.eq in
    let f0first: bool = if c01 then false else (if c10 then true else f0le) in
    let first: Sl = if f0first then f0 else f1 in
    let second: Sl = if f0first then f1 else f0 in
    build_two_root(mz, first, second)

fn print_str<'r>(s: string) -> i64 effects[io, state, ffi, unsafe] =
  let n: i64 = string_len(s) in
  let seed: OB = { b: [0x0; 96], i: 0 } in
  let done: OB =
    loop st = seed while st.i < n do
      let nx: OB = { b: array_set(st.b, st.i, string_get(s, st.i)), i: st.i + 1 } in nx
  in
  let out: array<u8, 96> = array_set(done.b, n, 0xa) in
  std.platform.write(1, raw_ptr(&'r out[0]), n + 1)

fn main<'r>() -> i64 effects[io, alloc, state, ffi, unsafe] =
  let src: string = read_all(string_with_capacity(mem_cap())) in
  let root: string = import_root(src) in
  let printed: i64 = print_str(root) in
  0

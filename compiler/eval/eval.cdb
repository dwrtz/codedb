// compiler/eval/eval.cdb - the CodeDB-hosted reference evaluator (ladder rung 0).
//
// Stages 2+3 (scalar core + aggregates): read a CIR file (docs/PLAN_V3.md
// Phase 8; format doc in src/cir.rs) from STDIN, build per-function
// metadata, and EXECUTE the entry over a simulated byte machine: consts,
// params, every binary/unary operator width, int_cast, if, load/store/copy/
// move (aggregates are aliased addresses in cells; only Store copies bytes),
// borrows/derefs (address identity), records/enums/arrays through the
// explicit place offsets, enum tags (8 bytes at offset 0), case dispatch
// (last arm = default), fold and loop drivers over accumulator locals,
// slices ({ptr,len} pairs), static data (pool bytes addressed in the image),
// bounds/range checks, and calls with the hidden-return-slot + indirect-
// param-copy ABI the native backend uses. The heap ops (box/vec/string/argv)
// trap `unsupported_op` until Stage 4. Output protocol
// (compiler/eval/README.md): `ok:<value>` and exit 0, or `trap:<code>` and
// exit 101; a non-CIR input exits 65.
//
// The CIR arrives on stdin (`eval-bin < program.cir [args...]`): the v0
// backend gives every op's value id an 8-byte frame slot, so a `[0x0; N]`
// path/chunk buffer costs ~24N frame bytes and any N >= ~150 busts the
// 4095-byte arm64 frame budget; stdin needs only a 1-byte bounce buffer.
//
// Memory is ONE string (the byte machine): [CIR image | fn metadata | frame
// stack | heap (reserved)]. Addresses are byte offsets into it. The string
// threads by MOVE through every helper (returned inside a record); loops
// consume their move-only accumulator wholly per iteration and only ever
// READ outer storage. Operator semantics are inherited by construction: a
// CIR binary/unary/cast op is applied by casting the canonically-extended
// cell values to the .cdb type of the op's own width/signedness columns and
// using the .cdb operator itself - the same registry semantics the
// oracle-conformance corpus pins against the Rust evaluator and the native
// backend.

module std.platform {
extern fn write(fd: i64, ptr: raw_ptr<u8>, len: i64) -> i64 abi[c] effects[io, ffi, unsafe] link_name "write" library "c"
extern fn read(fd: i64, ptr: raw_mut_ptr<u8>, len: i64) -> i64 abi[c] effects[io, ffi, unsafe] link_name "read" library "c"
}

// ---------------------------------------------------------------------------
// shared records
// ---------------------------------------------------------------------------

// The memory string plus one scalar result: the return shape of every reader
// that consumes the memory by move and hands it back.
record RV {
  mem: string
  val: i64
}

// A Copy loop accumulator for summing pool byte-lengths in place.
record Sum {
  i: i64
  total: i64
}

// A Copy loop accumulator carrying a small output buffer under construction.
record OutBuf {
  b: array<u8, 32>
  i: i64
}

// The stdin pump's move-only loop accumulator.
record Pump {
  mem: string
  more: bool
}

// The file-global geometry, fixed once the header is walked (all Copy).
record Vm {
  fns: i64
  entry: i64
  table_base: i64
  region_base: i64
  meta_index: i64
  data_index: i64
  stack_base: i64
  stack_end: i64
}

// One function's execution context (all Copy): frame base, value-cell base,
// param count, the hidden-return flag, the copies/locals region bases, the
// function's meta-blob offset, and its type/layout table bases. The frame is
// [cells (hidden+pcount) x 8][indirect-param copies][locals][value cells].
record Frame {
  fb: i64
  vb: i64
  pcount: i64
  hidden: i64
  cb: i64
  lb: i64
  mb: i64
  tb: i64
  lt: i64
}

// A fold/loop driver step: the memory, a propagated status/value (an early
// return or trap from an iteration), and one auxiliary counter/flag.
record St4 {
  mem: string
  st: i64
  val: i64
  aux: i64
}

// The fold driver's decoded header (one Copy record: the v0 backend caps
// calls at 8 machine parameters).
record FoldArgs {
  id: i64
  tgt: i64
  ttref: i64
  lref: i64
  iref: i64
  islot: i64
  aslot: i64
  itslot: i64
  bpc: i64
  etref: i64
  atref: i64
  end: i64
}

// The loop driver's decoded header.
record LoopArgs {
  id: i64
  iref: i64
  aslot: i64
  cpc: i64
  bpc: i64
  atref: i64
  end: i64
}

// An execution step: the memory, the program counter after the step, a
// status (0 = fell through, 3 = returned, 2 = trapped), and the value
// (block/return result, or the trap code when status = 2).
record Ex {
  mem: string
  pc: i64
  status: i64
  val: i64
}

// Record constructors: the one literal site per shape. Every branch result
// is built through these, so branches stay nominally typed and a function's
// frame carries call ops instead of per-literal field stores.
fn mk_rv(mem: string, val: i64) -> RV =
  { mem: mem, val: val }

fn mk_ex(mem: string, pc: i64, status: i64, val: i64) -> Ex =
  { mem: mem, pc: pc, status: status, val: val }

fn mk_st4(mem: string, st: i64, val: i64, aux: i64) -> St4 =
  { mem: mem, st: st, val: val, aux: aux }

// trap codes (rendered by print_trap)
fn trap_div0() -> i64 = 1
fn trap_mod0() -> i64 = 2
fn trap_bounds() -> i64 = 3
fn trap_unsupported() -> i64 = 4
fn trap_stack_overflow() -> i64 = 5
fn trap_entry_params() -> i64 = 6
fn trap_malformed() -> i64 = 7
fn trap_heap() -> i64 = 8

// type-meta kinds (the CIR consumer column; src/cir.rs::typemeta)
fn tk_unit() -> i64 = 0
fn tk_bool() -> i64 = 1
fn tk_u64() -> i64 = 9
fn tk_pointer() -> i64 = 10

// memory geometry
fn mem_cap() -> i64 = 8388608
fn meta_size() -> i64 = 262144
fn stack_size() -> i64 = 1048576
fn heap_size() -> i64 = 2097152

fn align8(n: i64) -> i64 = (n + 7) & (0 - 8)

// ---------------------------------------------------------------------------
// byte readers/writers over the memory string
// ---------------------------------------------------------------------------

// Little-endian u32 read at `off`.
fn rd_u32(mem: string, off: i64) -> RV =
  let b0: i64 = to_i64(string_get(mem, off)) in
  let b1: i64 = to_i64(string_get(mem, off + 1)) in
  let b2: i64 = to_i64(string_get(mem, off + 2)) in
  let b3: i64 = to_i64(string_get(mem, off + 3)) in
  let v: i64 = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24) in
  mk_rv(mem, v)

// Little-endian u64 read at `off` (an i64 carrying the bit pattern).
fn rd_u64(mem: string, off: i64) -> RV =
  let lo: RV = rd_u32(mem, off) in
  let hi: RV = rd_u32(lo.mem, off + 4) in
  mk_rv(hi.mem, lo.val | (hi.val << 32))

// One byte as i64.
fn rd_byte(mem: string, off: i64) -> RV =
  let v: i64 = to_i64(string_get(mem, off)) in
  mk_rv(mem, v)

// Little-endian u32 write at `off`.
fn wr_u32(mem: string, off: i64, v: i64) -> string effects[state] =
  let s0: unit = string_set(mem, off, to_u8(v & 0xff)) in
  let s1: unit = string_set(mem, off + 1, to_u8((v >> 8) & 0xff)) in
  let s2: unit = string_set(mem, off + 2, to_u8((v >> 16) & 0xff)) in
  let s3: unit = string_set(mem, off + 3, to_u8((v >> 24) & 0xff)) in
  mem

// Little-endian u64 write at `off` (shifts in the u64 domain: the cell is a
// bit pattern and an arithmetic i64 shift would smear the sign).
fn wr_u64(mem: string, off: i64, v: i64) -> string effects[state] =
  let u: u64 = to_u64(v) in
  let lo: string = wr_u32(mem, off, to_i64(to_u32(u & 0xffffffff))) in
  wr_u32(lo, off + 4, to_i64(to_u32(u >> 32)))

// ---------------------------------------------------------------------------
// the stdin shell
// ---------------------------------------------------------------------------

// Append everything stdin yields onto `mem`, one byte per read() through a
// 1-byte stack bounce buffer (the todo_cli idiom, minimized so the frame
// stays small). A loop, not recursion, so the input size is bounded by the
// memory capacity alone.
fn read_all<'r>(mem: string) -> string effects[io, state, ffi, unsafe] =
  let bounce: array<u8, 1> = [0x0; 1] in
  let done: Pump =
    loop s = { mem: mem, more: true } while s.more do
      let cur: Pump = s in
      let m: string = cur.mem in
      let p: raw_mut_ptr<u8> = raw_mut_ptr(&'r mut bounce[0]) in
      let n: i64 = std.platform.read(0, p, 1) in
      if n <= 0 then
        let fin: Pump = { mem: m, more: false } in
        fin
      else
        let pushed: unit = string_push(m, bounce[0]) in
        let nxt: Pump = { mem: m, more: true } in
        nxt
  in
  done.mem

// Copy `n` bytes inside the memory from `src` to `dst` (the regions never
// overlap in practice: copies go place->place between distinct slots).
fn mem_copy(mem: string, dst: i64, src: i64, n: i64) -> string effects[state] =
  let done: St4 =
    loop s = mk_st4(mem, 0, 0, 0) while s.aux < n do
      let cur: St4 = s in
      let m: string = cur.mem in
      let b: unit = string_set(m, dst + cur.aux, string_get(m, src + cur.aux)) in
      mk_st4(m, 0, 0, cur.aux + 1)
  in
  done.mem

// Grow the memory with zero bytes until its length reaches `upto` (the
// metadata/stack/heap regions live past the image and need len coverage
// before string_set can write them).
fn zero_fill(mem: string, upto: i64) -> string effects[state] =
  loop m = mem while string_len(m) < upto do
    let pushed: unit = string_push(m, to_u8(0)) in
    m

// ---------------------------------------------------------------------------
// output: ok:<value> / trap:<code> over write(1)
// ---------------------------------------------------------------------------

// Copy a (short) heap string into a stack buffer and write(1) it, with a
// trailing newline.
fn print_line<'r>(s: string) -> i64 effects[io, state, ffi, unsafe] =
  let ln: i64 = string_len(s) in
  let done: OutBuf =
    loop st = { b: [0x0; 32], i: 0 } while st.i < ln do
      { b: array_set(st.b, st.i, string_get(s, st.i)), i: st.i + 1 }
  in
  let out: array<u8, 32> = array_set(done.b, ln, 0xa) in
  std.platform.write(1, raw_ptr(&'r out[0]), ln + 1)

fn print_static(s: slice<'static, u8>) -> i64 effects[io, ffi, unsafe] =
  std.platform.write(1, raw_ptr(&'static s[0]), len(s))

// Push the decimal digits of a u64 (most significant first; the whole walk
// stays in the u64 domain so values past i64::MAX render unsigned).
fn push_u64_digits(s: string, u: u64) -> string effects[state] =
  let next: string = if u >= 10 then push_u64_digits(s, u / 10) else s in
  let pushed: unit = string_push(next, std.fmt.digit_byte(to_i64(u % 10))) in
  next

// Render the entry result per its return-type meta kind (the consumer
// column): unit, bool as 0/1, u64 unsigned, every other scalar through the
// canonically-extended cell as signed decimal.
fn print_ok<'r>(kind: i64, v: i64) -> i64 effects[io, alloc, state, ffi, unsafe] =
  let prefix: i64 = print_static("ok:") in
  if kind == tk_unit() then print_static("unit\n")
  else if kind == tk_bool() then
    (if v == 0 then print_static("0\n") else print_static("1\n"))
  else if kind == tk_u64() then
    let s: string = string_with_capacity(20) in
    let filled: string = push_u64_digits(s, to_u64(v)) in
    print_line(filled)
  else
    print_line(std.fmt.i64_to_string(v))

fn print_trap<'r>(code: i64) -> i64 effects[io, ffi, unsafe] =
  let prefix: i64 = print_static("trap:") in
  if code == trap_div0() then print_static("division_by_zero\n")
  else if code == trap_mod0() then print_static("modulo_by_zero\n")
  else if code == trap_bounds() then print_static("bounds_check\n")
  else if code == trap_stack_overflow() then print_static("stack_overflow\n")
  else if code == trap_entry_params() then print_static("entry_params\n")
  else if code == trap_malformed() then print_static("malformed\n")
  else if code == trap_heap() then print_static("heap_exhausted\n")
  else print_static("unsupported_op\n")

// ---------------------------------------------------------------------------
// loader: header walk + per-function metadata
//
// Meta blob per function (u32 fields, abs offsets into the memory string):
//   +0 ops_base (offset of the body's op-count u32)
//   +4 type_base (first 17-byte type row)
//   +8 value_count | +12 param_count | +16 local_count | +20 locals_total
//   +24 return-type meta kind
//   +28.. local_count x local frame offset (relative to the locals region)
// Frame layout: [param cells 8 x p][locals locals_total][value cells 8 x v].
// ---------------------------------------------------------------------------

// Walk one function section and write its meta blob at `blob`; yields the
// next free blob offset. Section layout: 5 header strs, layout table
// (76-byte rows, incl. the buffer consumer columns), type table (17-byte
// rows), value table (4-byte rows),
// return tref, params (8-byte rows), locals (16-byte rows), op count.
// Blob (u32 fields): +0 ops_base, +4 type_base, +8 layout_base, +12
// value_count, +16 param_count, +20 local_count, +24 locals_total,
// +28 return meta kind, +32 return size, +36 copies_total, +40 per-param
// (copy_off, size) pairs, then per-local frame offsets.
fn build_fn_meta(mem: string, sec: i64, blob: i64) -> RV effects[state] =
  let layouts: RV = rd_u32(mem, sec + 20) in
  let tbase: i64 = sec + 24 + layouts.val * 76 in
  let types: RV = rd_u32(layouts.mem, tbase) in
  let vco: i64 = tbase + 4 + types.val * 17 in
  let vals: RV = rd_u32(types.mem, vco) in
  let rco: i64 = vco + 4 + vals.val * 4 in
  let rtref: RV = rd_u32(vals.mem, rco) in
  let rkind: RV = rd_byte(rtref.mem, tbase + 4 + rtref.val * 17 + 8) in
  let rsize: RV = rd_u64(rkind.mem, tbase + 4 + rtref.val * 17 + 9) in
  let pco: i64 = rco + 4 in
  let params: RV = rd_u32(rsize.mem, pco) in
  let lco: i64 = pco + 4 + params.val * 8 in
  let locals: RV = rd_u32(params.mem, lco) in
  let oco: i64 = lco + 4 + locals.val * 16 in
  let m1: string = wr_u32(locals.mem, blob, oco) in
  let m2: string = wr_u32(m1, blob + 4, tbase + 4) in
  let m2b: string = wr_u32(m2, blob + 8, sec + 24) in
  let m3: string = wr_u32(m2b, blob + 12, vals.val) in
  let m4: string = wr_u32(m3, blob + 16, params.val) in
  let m5: string = wr_u32(m4, blob + 20, locals.val) in
  let m6: string = wr_u32(m5, blob + 28, rkind.val) in
  let m6b: string = wr_u32(m6, blob + 32, rsize.val) in
  let pe: RV = write_param_entries(m6b, pco + 4, tbase + 4, blob + 40, params.val, 0, 0) in
  let m6c: string = wr_u32(pe.mem, blob + 36, pe.val) in
  // local offsets: 8-aligned running sum of the locals' declared sizes
  let lt: RV = write_local_offsets(m6c, lco + 4, blob + 40 + params.val * 8, locals.val, 0, 0) in
  let m7: string = wr_u32(lt.mem, blob + 24, lt.val) in
  mk_rv(m7, blob + 40 + params.val * 8 + locals.val * 4)

// Walk the 8-byte param rows from `row`, writing each param's
// (copy_off, size) pair at `out`: an aggregate-indirect param gets a copy
// slot (8-aligned running sum); everything else writes the no-copy sentinel.
// Yields the copies-region total.
fn write_param_entries(mem: string, row: i64, tb: i64, out: i64, count: i64, j: i64, copies: i64) -> RV effects[state] =
  if j >= count then mk_rv(mem, copies)
  else
    let tref: RV = rd_u32(mem, row + 4) in
    let kind: RV = rd_byte(tref.mem, tb + tref.val * 17 + 8) in
    let size: RV = rd_u64(kind.mem, tb + tref.val * 17 + 9) in
    if kind.val >= 12 then
      let m1: string = wr_u32(size.mem, out, copies) in
      let m2: string = wr_u32(m1, out + 4, size.val) in
      write_param_entries(m2, row + 8, tb, out + 8, count, j + 1, copies + align8(size.val))
    else
      let m1: string = wr_u32(size.mem, out, 0xffffffff) in
      let m2: string = wr_u32(m1, out + 4, size.val) in
      write_param_entries(m2, row + 8, tb, out + 8, count, j + 1, copies)

// Walk the 16-byte local rows from `row`, writing each local's frame offset
// (a running 8-aligned sum) at `out`; yields the locals-region total.
fn write_local_offsets(mem: string, row: i64, out: i64, count: i64, i: i64, off: i64) -> RV effects[state] =
  if i >= count then
    mk_rv(mem, off)
  else
    let size: RV = rd_u64(mem, row + 8) in
    let m1: string = wr_u32(size.mem, out, off) in
    write_local_offsets(m1, row + 16, out + 4, count, i + 1, off + align8(size.val))

// Build the data-pool offset index: entry i = the absolute image offset of
// data blob i (length prefixes at `lens`; concatenated bytes from `bytes`).
fn build_data_index(mem: string, lens: i64, bytes: i64, out: i64, count: i64, i: i64, off: i64) -> string effects[state] =
  if i >= count then mem
  else
    let l: RV = rd_u32(mem, lens + i * 4) in
    let m1: string = wr_u32(l.mem, out + i * 4, bytes + off) in
    build_data_index(m1, lens, bytes, out, count, i + 1, off + l.val)

// Build every function's meta blob and the meta index (fns x u32 blob
// offsets at meta_index). Recursion over the function table.
fn build_meta(mem: string, vm: Vm, i: i64, blob: i64) -> string effects[state] =
  if i >= vm.fns then mem
  else
    let secoff: RV = rd_u32(mem, vm.table_base + i * 12 + 4) in
    let m1: string = wr_u32(secoff.mem, vm.meta_index + i * 4, blob) in
    let next: RV = build_fn_meta(m1, vm.region_base + secoff.val, blob) in
    build_meta(next.mem, vm, i + 1, next.val)

// ---------------------------------------------------------------------------
// operator semantics, inherited from the language's own sized operators
// ---------------------------------------------------------------------------

// verbs (the CIR consumer column; src/cir.rs::opverb):
// 1 add 2 sub 3 mul 4 div 5 rem 6 and 7 or 8 xor 9 shl 10 shr
// 11 eq 12 ne 13 lt 14 le 15 gt 16 ge 17 neg 18 bitnot
// 19 and_bool 20 or_bool 21 not_bool

fn bin_i8(verb: i64, a: i64, b: i64) -> i64 =
  let x: i8 = to_i8(a) in
  let y: i8 = to_i8(b) in
  case verb of
    1 => to_i64(x + y) | 2 => to_i64(x - y) | 3 => to_i64(x * y)
  | 4 => to_i64(x / y) | 5 => to_i64(x % y) | 6 => to_i64(x & y)
  | 7 => to_i64((x | y)) | 8 => to_i64(x ^ y) | 9 => to_i64(x << y)
  | 10 => to_i64(x >> y)
  | 11 => (if x == y then 1 else 0) | 12 => (if x != y then 1 else 0)
  | 13 => (if x < y then 1 else 0) | 14 => (if x <= y then 1 else 0)
  | 15 => (if x > y then 1 else 0) | 16 => (if x >= y then 1 else 0)
  | _ => 0

fn bin_i16(verb: i64, a: i64, b: i64) -> i64 =
  let x: i16 = to_i16(a) in
  let y: i16 = to_i16(b) in
  case verb of
    1 => to_i64(x + y) | 2 => to_i64(x - y) | 3 => to_i64(x * y)
  | 4 => to_i64(x / y) | 5 => to_i64(x % y) | 6 => to_i64(x & y)
  | 7 => to_i64((x | y)) | 8 => to_i64(x ^ y) | 9 => to_i64(x << y)
  | 10 => to_i64(x >> y)
  | 11 => (if x == y then 1 else 0) | 12 => (if x != y then 1 else 0)
  | 13 => (if x < y then 1 else 0) | 14 => (if x <= y then 1 else 0)
  | 15 => (if x > y then 1 else 0) | 16 => (if x >= y then 1 else 0)
  | _ => 0

fn bin_i32(verb: i64, a: i64, b: i64) -> i64 =
  let x: i32 = to_i32(a) in
  let y: i32 = to_i32(b) in
  case verb of
    1 => to_i64(x + y) | 2 => to_i64(x - y) | 3 => to_i64(x * y)
  | 4 => to_i64(x / y) | 5 => to_i64(x % y) | 6 => to_i64(x & y)
  | 7 => to_i64((x | y)) | 8 => to_i64(x ^ y) | 9 => to_i64(x << y)
  | 10 => to_i64(x >> y)
  | 11 => (if x == y then 1 else 0) | 12 => (if x != y then 1 else 0)
  | 13 => (if x < y then 1 else 0) | 14 => (if x <= y then 1 else 0)
  | 15 => (if x > y then 1 else 0) | 16 => (if x >= y then 1 else 0)
  | _ => 0

fn bin_i64(verb: i64, a: i64, b: i64) -> i64 =
  case verb of
    1 => a + b | 2 => a - b | 3 => a * b
  | 4 => a / b | 5 => a % b | 6 => a & b
  | 7 => (a | b) | 8 => a ^ b | 9 => a << b
  | 10 => a >> b
  | 11 => (if a == b then 1 else 0) | 12 => (if a != b then 1 else 0)
  | 13 => (if a < b then 1 else 0) | 14 => (if a <= b then 1 else 0)
  | 15 => (if a > b then 1 else 0) | 16 => (if a >= b then 1 else 0)
  | _ => 0

fn bin_u8(verb: i64, a: i64, b: i64) -> i64 =
  let x: u8 = to_u8(a) in
  let y: u8 = to_u8(b) in
  case verb of
    1 => to_i64(x + y) | 2 => to_i64(x - y) | 3 => to_i64(x * y)
  | 4 => to_i64(x / y) | 5 => to_i64(x % y) | 6 => to_i64(x & y)
  | 7 => to_i64((x | y)) | 8 => to_i64(x ^ y) | 9 => to_i64(x << y)
  | 10 => to_i64(x >> y)
  | 11 => (if x == y then 1 else 0) | 12 => (if x != y then 1 else 0)
  | 13 => (if x < y then 1 else 0) | 14 => (if x <= y then 1 else 0)
  | 15 => (if x > y then 1 else 0) | 16 => (if x >= y then 1 else 0)
  | _ => 0

fn bin_u16(verb: i64, a: i64, b: i64) -> i64 =
  let x: u16 = to_u16(a) in
  let y: u16 = to_u16(b) in
  case verb of
    1 => to_i64(x + y) | 2 => to_i64(x - y) | 3 => to_i64(x * y)
  | 4 => to_i64(x / y) | 5 => to_i64(x % y) | 6 => to_i64(x & y)
  | 7 => to_i64((x | y)) | 8 => to_i64(x ^ y) | 9 => to_i64(x << y)
  | 10 => to_i64(x >> y)
  | 11 => (if x == y then 1 else 0) | 12 => (if x != y then 1 else 0)
  | 13 => (if x < y then 1 else 0) | 14 => (if x <= y then 1 else 0)
  | 15 => (if x > y then 1 else 0) | 16 => (if x >= y then 1 else 0)
  | _ => 0

fn bin_u32(verb: i64, a: i64, b: i64) -> i64 =
  let x: u32 = to_u32(a) in
  let y: u32 = to_u32(b) in
  case verb of
    1 => to_i64(x + y) | 2 => to_i64(x - y) | 3 => to_i64(x * y)
  | 4 => to_i64(x / y) | 5 => to_i64(x % y) | 6 => to_i64(x & y)
  | 7 => to_i64((x | y)) | 8 => to_i64(x ^ y) | 9 => to_i64(x << y)
  | 10 => to_i64(x >> y)
  | 11 => (if x == y then 1 else 0) | 12 => (if x != y then 1 else 0)
  | 13 => (if x < y then 1 else 0) | 14 => (if x <= y then 1 else 0)
  | 15 => (if x > y then 1 else 0) | 16 => (if x >= y then 1 else 0)
  | _ => 0

fn bin_u64(verb: i64, a: i64, b: i64) -> i64 =
  let x: u64 = to_u64(a) in
  let y: u64 = to_u64(b) in
  case verb of
    1 => to_i64(x + y) | 2 => to_i64(x - y) | 3 => to_i64(x * y)
  | 4 => to_i64(x / y) | 5 => to_i64(x % y) | 6 => to_i64(x & y)
  | 7 => to_i64((x | y)) | 8 => to_i64(x ^ y) | 9 => to_i64(x << y)
  | 10 => to_i64(x >> y)
  | 11 => (if x == y then 1 else 0) | 12 => (if x != y then 1 else 0)
  | 13 => (if x < y then 1 else 0) | 14 => (if x <= y then 1 else 0)
  | 15 => (if x > y then 1 else 0) | 16 => (if x >= y then 1 else 0)
  | _ => 0

// Apply a binary verb at (width, signed); the bool verbs ride on 0/1 cells.
fn apply_binary(verb: i64, width: i64, sgn: i64, a: i64, b: i64) -> i64 =
  if verb == 19 then (if a != 0 && b != 0 then 1 else 0)
  else if verb == 20 then (if a != 0 || b != 0 then 1 else 0)
  else if sgn == 1 then
    (if width == 8 then bin_i64(verb, a, b)
     else if width == 4 then bin_i32(verb, a, b)
     else if width == 2 then bin_i16(verb, a, b)
     else bin_i8(verb, a, b))
  else
    (if width == 8 then bin_u64(verb, a, b)
     else if width == 4 then bin_u32(verb, a, b)
     else if width == 2 then bin_u16(verb, a, b)
     else bin_u8(verb, a, b))

fn neg_at(width: i64, sgn: i64, a: i64) -> i64 =
  if sgn == 1 then
    (if width == 8 then 0 - a
     else if width == 4 then to_i64(to_i32(0) - to_i32(a))
     else if width == 2 then to_i64(to_i16(0) - to_i16(a))
     else to_i64(to_i8(0) - to_i8(a)))
  else
    (if width == 8 then to_i64(to_u64(0) - to_u64(a))
     else if width == 4 then to_i64(to_u32(0) - to_u32(a))
     else if width == 2 then to_i64(to_u16(0) - to_u16(a))
     else to_i64(to_u8(0) - to_u8(a)))

fn bitnot_at(width: i64, sgn: i64, a: i64) -> i64 =
  if sgn == 1 then
    (if width == 8 then ~a
     else if width == 4 then to_i64(~to_i32(a))
     else if width == 2 then to_i64(~to_i16(a))
     else to_i64(~to_i8(a)))
  else
    (if width == 8 then to_i64(~to_u64(a))
     else if width == 4 then to_i64(~to_u32(a))
     else if width == 2 then to_i64(~to_u16(a))
     else to_i64(~to_u8(a)))

// 17 neg / 18 bitnot / 21 not_bool over a canonically-extended cell.
fn apply_unary(verb: i64, width: i64, sgn: i64, a: i64) -> i64 =
  if verb == 21 then (if a == 0 then 1 else 0)
  else if verb == 17 then neg_at(width, sgn, a)
  else bitnot_at(width, sgn, a)

// int_cast: renormalize the cell to the target meta kind (truncate to the
// target width, re-extend by the target signedness) via the cast builtins.
fn apply_cast(kind: i64, v: i64) -> i64 =
  case kind of
    2 => to_i64(to_i8(v)) | 3 => to_i64(to_i16(v)) | 4 => to_i64(to_i32(v))
  | 5 => v
  | 6 => to_i64(to_u8(v)) | 7 => to_i64(to_u16(v)) | 8 => to_i64(to_u32(v))
  | 9 => to_i64(to_u64(v))
  | _ => v

// ---------------------------------------------------------------------------
// type rows, cells, and scalar memory access
// ---------------------------------------------------------------------------

// A type-table row's consumer columns: meta kind at row+8, size at row+9.
fn type_kind(mem: string, fr: Frame, tref: i64) -> RV =
  rd_byte(mem, fr.tb + tref * 17 + 8)

fn type_size(mem: string, fr: Frame, tref: i64) -> RV =
  rd_u64(mem, fr.tb + tref * 17 + 9)

// An array element's stride: its size rounded up to its alignment. Scalars
// (no layout row) have stride == size; layout-bearing types read align from
// their 36-byte layout row (size at +8, align at +16).
fn elem_stride(mem: string, fr: Frame, tref: i64) -> RV =
  let lref: RV = rd_u32(mem, fr.tb + tref * 17 + 4) in
  if lref.val == 0xffffffff then type_size(lref.mem, fr, tref)
  else
    let size: RV = rd_u64(lref.mem, fr.lt + lref.val * 76 + 8) in
    let align: RV = rd_u64(size.mem, fr.lt + lref.val * 76 + 16) in
    mk_rv(align.mem, ((size.val + align.val - 1) / align.val) * align.val)

// A vec/string layout's buffer consumer column (0 = ptr offset, 1 = len
// offset, 2 = capacity offset, 3 = element size, 4 = element stride), read
// from the type's 76-byte layout row.
fn buf_col(mem: string, fr: Frame, tref: i64, which: i64) -> RV =
  let lref: RV = rd_u32(mem, fr.tb + tref * 17 + 4) in
  rd_u64(lref.mem, fr.lt + lref.val * 76 + 36 + which * 8)

// Bump-allocate `size` bytes (alignment folded up to 8); the heap pointer
// cell lives at vm.stack_end and allocations grow toward the memory's
// length watermark. Exhaustion yields address 0 (the caller traps).
fn bump_alloc(mem: string, vm: Vm, size: i64) -> RV effects[state] =
  let hp: RV = rd_u64(mem, vm.stack_end) in
  let addr: i64 = align8(hp.val) in
  let limit: i64 = string_len(hp.mem) in
  if addr + (if size < 1 then 1 else size) > limit then mk_rv(hp.mem, 0)
  else
    let m: string = wr_u64(hp.mem, vm.stack_end, addr + (if size < 1 then 1 else size)) in
    mk_rv(m, addr)

fn cell_addr(fr: Frame, vref: i64) -> i64 = fr.vb + vref * 8

// Read/write `n` (<= 8) raw bytes little-endian: the cell form of a
// by-value aggregate (kind 11), an opaque byte pattern.
fn rd_bytes_le(mem: string, addr: i64, n: i64, i: i64, acc: i64) -> RV =
  if i >= n then mk_rv(mem, acc)
  else
    let b: i64 = to_i64(string_get(mem, addr + i)) in
    rd_bytes_le(mem, addr, n, i + 1, acc | (b << (i * 8)))

fn wr_bytes_le(mem: string, addr: i64, v: i64, n: i64, i: i64) -> string effects[state] =
  if i >= n then mem
  else
    let w: unit = string_set(mem, addr + i, to_u8((v >> (i * 8)) & 0xff)) in
    wr_bytes_le(mem, addr, v, n, i + 1)

// Load a value of `tref`'s type from `addr` into cell form: aggregates are
// not handled here (the callers alias); kind 11 reads its raw byte pattern.
fn load_cell(mem: string, fr: Frame, tref: i64, addr: i64) -> RV =
  let kind: RV = type_kind(mem, fr, tref) in
  if kind.val == 11 then
    let size: RV = type_size(kind.mem, fr, tref) in
    rd_bytes_le(size.mem, addr, size.val, 0, 0)
  else load_scalar(kind.mem, kind.val, addr)

fn cell_rd(mem: string, fr: Frame, vref: i64) -> RV =
  rd_u64(mem, fr.vb + vref * 8)

fn cell_wr(mem: string, fr: Frame, vref: i64, v: i64) -> string effects[state] =
  wr_u64(mem, fr.vb + vref * 8, v)

// Scalar load: read the kind's width at `addr`, canonically extended (the
// cast builtins do the sign/zero extension).
fn load_scalar(mem: string, kind: i64, addr: i64) -> RV =
  if kind == tk_unit() then
    mk_rv(mem, 0)
  else if kind == 2 then
    let b: RV = rd_byte(mem, addr) in
    mk_rv(b.mem, to_i64(to_i8(b.val)))
  else if kind == 3 then
    let b0: RV = rd_byte(mem, addr) in
    let b1: RV = rd_byte(b0.mem, addr + 1) in
    mk_rv(b1.mem, to_i64(to_i16(b0.val | (b1.val << 8))))
  else if kind == 4 then
    let w: RV = rd_u32(mem, addr) in
    mk_rv(w.mem, to_i64(to_i32(w.val)))
  else if kind == 5 || kind == 9 || kind == tk_pointer() then rd_u64(mem, addr)
  else if kind == 7 then
    let b0: RV = rd_byte(mem, addr) in
    let b1: RV = rd_byte(b0.mem, addr + 1) in
    mk_rv(b1.mem, b0.val | (b1.val << 8))
  else if kind == 8 then rd_u32(mem, addr)
  else
    // bool and u8: one zero-extended byte
    rd_byte(mem, addr)

// Scalar store: write the kind's width at `addr` from a canonical cell.
fn store_scalar(mem: string, kind: i64, addr: i64, v: i64) -> string effects[state] =
  if kind == tk_unit() then mem
  else if kind == tk_bool() || kind == 2 || kind == 6 then
    let s: unit = string_set(mem, addr, to_u8(v & 0xff)) in
    mem
  else if kind == 3 || kind == 7 then
    let s0: unit = string_set(mem, addr, to_u8(v & 0xff)) in
    let s1: unit = string_set(mem, addr + 1, to_u8((v >> 8) & 0xff)) in
    mem
  else if kind == 4 || kind == 8 then wr_u32(mem, addr, to_i64(to_u32(v)))
  else wr_u64(mem, addr, v)

// ---------------------------------------------------------------------------
// op skipping (structure-only walk; the not-taken branch of an `if`)
// ---------------------------------------------------------------------------

// Skip an optional string/value (flag u8 + u32 when present).
fn skip_opt(mem: string, pc: i64) -> RV =
  let flag: RV = rd_byte(mem, pc) in
  mk_rv(flag.mem, pc + 1 + (if flag.val == 0 then 0 else 4))

// Skip a place (kind u8 + fields; src/cir.rs::placekind).
fn skip_place(mem: string, pc: i64) -> RV =
  let kind: RV = rd_byte(mem, pc) in
  let body: i64 = pc + 1 in
  if kind.val == 0 then mk_rv(kind.mem, body + 9)
  else if kind.val == 1 then mk_rv(kind.mem, body + 8)
  else if kind.val == 2 then
    let o: RV = skip_opt(kind.mem, body + 8) in
    mk_rv(o.mem, o.val + 16)
  else if kind.val == 3 then
    let o: RV = skip_opt(kind.mem, body + 8) in
    mk_rv(o.mem, o.val + 24)
  else mk_rv(kind.mem, body + 16)

// Skip one op starting at `pc` (the opcode byte); yields the offset just
// past it. Field widths follow src/cir.rs::encode_op exactly.
fn skip_op(mem: string, pc: i64) -> RV =
  let code: RV = rd_byte(mem, pc) in
  let body: i64 = pc + 1 in
  if code.val < 12 then skip_op_low(code.mem, code.val, body)
  else if code.val < 21 then skip_op_ptr(code.mem, code.val, body)
  else if code.val < 43 then skip_op_mid(code.mem, code.val, body)
  else skip_op_high(code.mem, code.val, body)

// opcodes 0..11: params/consts/operators/control (the block-recursing ops).
fn skip_op_low(mem: string, code: i64, body: i64) -> RV =
  if code == 0 then mk_rv(mem, body + 12)
  else if code == 1 then mk_rv(mem, body + 16)
  else if code == 2 then mk_rv(mem, body + 9)
  else if code == 3 then mk_rv(mem, body + 8)
  else if code == 4 then mk_rv(mem, body + 19)
  else if code == 5 then mk_rv(mem, body + 12)
  else if code == 6 then
    let flag: RV = rd_byte(mem, body + 23) in
    mk_rv(flag.mem, body + 24 + (if flag.val == 0 then 0 else 8))
  else if code == 7 then
    let abi: RV = skip_opt(mem, body + 8) in
    let argc: RV = rd_u32(abi.mem, abi.val) in
    let ret: RV = skip_opt(argc.mem, abi.val + 4 + argc.val * 4) in
    mk_rv(ret.mem, ret.val + 4)
  else if code == 8 then
    let t: RV = skip_block(mem, body + 8) in
    let e: RV = skip_block(t.mem, t.val) in
    mk_rv(e.mem, e.val + 4)
  else if code == 9 then
    let arms: RV = rd_u32(mem, body + 8) in
    let done: RV = skip_case_arms(arms.mem, body + 12, arms.val) in
    mk_rv(done.mem, done.val + 4)
  else if code == 10 then
    let b: RV = skip_block(mem, body + 32) in
    mk_rv(b.mem, b.val + 12)
  else if code == 11 then
    let c: RV = skip_block(mem, body + 12) in
    let b: RV = skip_block(c.mem, c.val) in
    mk_rv(b.mem, b.val + 8)
  else mk_rv(mem, body)

// opcodes 12..20: borrows, derefs, box/heap intro, pointer casts.
fn skip_op_ptr(mem: string, code: i64, body: i64) -> RV =
  if code == 12 || code == 13 then mk_rv(mem, body + 20)
  else if code == 14 || code == 15 then mk_rv(mem, body + 12)
  else if code == 16 then mk_rv(mem, body + 16)
  else if code == 17 then mk_rv(mem, body + 20)
  else if code == 18 then mk_rv(mem, body + 28)
  else if code == 19 then mk_rv(mem, body + 16)
  else mk_rv(mem, body + 17)

// opcodes 21..42: addr-of places, static data, slices, vec/string, argv.
fn skip_op_mid(mem: string, code: i64, body: i64) -> RV =
  if code <= 25 then
    let p: RV = skip_place(mem, body + 4) in
    mk_rv(p.mem, p.val)
  else if code == 26 then mk_rv(mem, body + 24)
  else if code == 27 then mk_rv(mem, body + 24)
  else if code == 28 then mk_rv(mem, body + 16)
  else if code == 29 then mk_rv(mem, body + 16)
  else if code == 30 then mk_rv(mem, body + 24)
  else if code == 31 then mk_rv(mem, body + 24)
  else if code == 32 then mk_rv(mem, body + 24)
  else if code == 33 then mk_rv(mem, body + 16)
  else if code == 34 then mk_rv(mem, body + 28)
  else if code == 35 then mk_rv(mem, body + 16)
  else if code == 36 then mk_rv(mem, body + 16)
  else if code == 37 then mk_rv(mem, body + 20)
  else if code == 38 then mk_rv(mem, body + 20)
  else if code == 39 then mk_rv(mem, body + 24)
  else if code == 40 then mk_rv(mem, body + 8)
  else if code == 41 then mk_rv(mem, body + 12)
  else mk_rv(mem, body + 16)

// opcodes 43..55: checks, enum tags, load/store/copy/move/drop, returns.
fn skip_op_high(mem: string, code: i64, body: i64) -> RV =
  if code == 43 then
    let o: RV = skip_opt(mem, body + 16) in
    mk_rv(o.mem, o.val + 4)
  else if code == 44 then mk_rv(mem, body + 20)
  else if code == 45 then mk_rv(mem, body + 12)
  else if code == 46 then
    let o: RV = skip_opt(mem, body + 12) in
    mk_rv(o.mem, o.val + 8)
  else if code == 47 then mk_rv(mem, body + 12)
  else if code == 48 then mk_rv(mem, body + 12)
  else if code == 49 then mk_rv(mem, body + 12)
  else if code == 50 then mk_rv(mem, body + 12)
  else if code == 51 then mk_rv(mem, body + 8)
  else if code == 52 then mk_rv(mem, body + 8)
  else if code == 53 then
    let o: RV = skip_opt(mem, body + 5) in
    mk_rv(o.mem, o.val + 4)
  else mk_rv(mem, body + 8)

// Skip a whole block: count u32, count ops, result vref u32.
fn skip_block(mem: string, pc: i64) -> RV =
  let count: RV = rd_u32(mem, pc) in
  let done: RV = skip_ops(count.mem, pc + 4, count.val) in
  mk_rv(done.mem, done.val + 4)

fn skip_ops(mem: string, pc: i64, remaining: i64) -> RV =
  if remaining <= 0 then
    mk_rv(mem, pc)
  else
    let next: RV = skip_op(mem, pc) in
    skip_ops(next.mem, next.val, remaining - 1)

// Skip `case` arms: variant str, optional symbol, tag u64, payload tref,
// payload offset u64, block.
fn skip_case_arms(mem: string, pc: i64, remaining: i64) -> RV =
  if remaining <= 0 then
    mk_rv(mem, pc)
  else
    let o: RV = skip_opt(mem, pc + 4) in
    let b: RV = skip_block(o.mem, o.val + 20) in
    skip_case_arms(b.mem, b.val, remaining - 1)

// ---------------------------------------------------------------------------
// the executor
// ---------------------------------------------------------------------------

// Execute the ops of one block body in sequence. status 0 = fell through
// (pc points at the block's result vref); 3 = returned; 2 = trapped.
fn exec_ops(mem: string, vm: Vm, fr: Frame, pc: i64, remaining: i64) -> Ex effects[io, state] =
  if remaining <= 0 then
        mk_ex(mem, pc, 0, 0)
  else
    let step: Ex = exec_op(mem, vm, fr, pc) in
    if step.status == 0 then exec_ops(step.mem, vm, fr, step.pc, remaining - 1)
    else step

// Execute a block: run its ops; on fall-through read the result vref's cell.
fn exec_block(mem: string, vm: Vm, fr: Frame, pc: i64) -> Ex effects[io, state] =
  let count: RV = rd_u32(mem, pc) in
  let run: Ex = exec_ops(count.mem, vm, fr, pc + 4, count.val) in
  if run.status == 0 then
    let res: RV = rd_u32(run.mem, run.pc) in
    let v: RV = cell_rd(res.mem, fr, res.val) in
        mk_ex(v.mem, run.pc + 4, 0, v.val)
  else run

// One op. Dispatch by opcode range to keep each dispatcher's frame small.
fn exec_op(mem: string, vm: Vm, fr: Frame, pc: i64) -> Ex effects[io, state] =
  let code: RV = rd_byte(mem, pc) in
  let body: i64 = pc + 1 in
  if code.val <= 8 then exec_op_core(code.mem, vm, fr, code.val, body)
  else if code.val == 9 then exec_case(code.mem, vm, fr, body)
  else if code.val == 10 then exec_fold(code.mem, vm, fr, body)
  else if code.val == 11 then exec_loop(code.mem, vm, fr, body)
  else if code.val >= 43 then exec_op_mem(code.mem, vm, fr, code.val, body)
  else if code.val >= 12 && code.val <= 16 then exec_op_ref(code.mem, vm, fr, code.val, body)
  else if code.val == 19 || code.val == 20 then exec_op_ref(code.mem, vm, fr, code.val, body)
  else if code.val >= 21 && code.val <= 22 then exec_op_addr(code.mem, vm, fr, code.val, body)
  else if code.val >= 23 && code.val <= 25 then exec_op_addr_agg(code.mem, fr, code.val, body)
  else if code.val >= 26 && code.val <= 29 then exec_op_slice(code.mem, vm, fr, code.val, body)
  else if code.val == 17 || code.val == 18 then exec_op_heap(code.mem, vm, fr, code.val, body)
  else if code.val >= 30 && code.val <= 39 then exec_op_buf(code.mem, vm, fr, code.val, body)
  else if code.val >= 40 && code.val <= 42 then exec_op_argv(code.mem, fr, code.val, body)
  else
    mk_ex(code.mem, body, 2, trap_unsupported())

// opcodes 0..8: param, consts, unary, int_cast, binary, call, if - a thin
// router over the per-op handlers.
fn exec_op_core(mem: string, vm: Vm, fr: Frame, code: i64, body: i64) -> Ex effects[io, state] =
  if code == 0 then exec_param(mem, fr, body)
  else if code == 1 then exec_const_i64(mem, fr, body)
  else if code == 2 then exec_const_bool(mem, fr, body)
  else if code == 3 then exec_const_unit(mem, fr, body)
  else if code == 4 then exec_unary(mem, fr, body)
  else if code == 5 then exec_cast(mem, fr, body)
  else if code == 6 then exec_binary(mem, fr, body)
  else if code == 7 then exec_call(mem, vm, fr, body)
  else exec_if(mem, vm, fr, body)

// param: id, slot, tref -> the param cell.
fn exec_param(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let slot: RV = rd_u32(id.mem, body + 4) in
  let v: RV = rd_u64(slot.mem, fr.fb + (fr.hidden + slot.val) * 8) in
  let m: string = cell_wr(v.mem, fr, id.val, v.val) in
  mk_ex(m, body + 12, 0, 0)

// const_i64: id, value i64, tref.
fn exec_const_i64(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let v: RV = rd_u64(id.mem, body + 4) in
  let m: string = cell_wr(v.mem, fr, id.val, v.val) in
  mk_ex(m, body + 16, 0, 0)

// const_bool: id, value u8, tref.
fn exec_const_bool(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let v: RV = rd_byte(id.mem, body + 4) in
  let m: string = cell_wr(v.mem, fr, id.val, v.val) in
  mk_ex(m, body + 9, 0, 0)

// const_unit: id, tref.
fn exec_const_unit(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let m: string = cell_wr(id.mem, fr, id.val, 0) in
  mk_ex(m, body + 8, 0, 0)

// unary: id, kind str, verb/width/signed, value, tref.
fn exec_unary(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let verb: RV = rd_byte(id.mem, body + 8) in
  let width: RV = rd_byte(verb.mem, body + 9) in
  let sgn: RV = rd_byte(width.mem, body + 10) in
  let vref: RV = rd_u32(sgn.mem, body + 11) in
  let a: RV = cell_rd(vref.mem, fr, vref.val) in
  let m: string = cell_wr(a.mem, fr, id.val, apply_unary(verb.val, width.val, sgn.val, a.val)) in
  mk_ex(m, body + 19, 0, 0)

// int_cast: id, value, tref -> renormalize to the target type's meta kind.
fn exec_cast(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let vref: RV = rd_u32(id.mem, body + 4) in
  let tref: RV = rd_u32(vref.mem, body + 8) in
  let kind: RV = type_kind(tref.mem, fr, tref.val) in
  let a: RV = cell_rd(kind.mem, fr, vref.val) in
  let m: string = cell_wr(a.mem, fr, id.val, apply_cast(kind.val, a.val)) in
  mk_ex(m, body + 12, 0, 0)

// binary: id, kind str, verb/width/signed, left, right, tref, trap option.
// The trap option's presence marks div/mod; a zero right operand traps.
fn exec_binary(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let verb: RV = rd_byte(id.mem, body + 8) in
  let width: RV = rd_byte(verb.mem, body + 9) in
  let sgn: RV = rd_byte(width.mem, body + 10) in
  let lref: RV = rd_u32(sgn.mem, body + 11) in
  let rref: RV = rd_u32(lref.mem, body + 15) in
  let flag: RV = rd_byte(rref.mem, body + 23) in
  let end: i64 = body + 24 + (if flag.val == 0 then 0 else 8) in
  let a: RV = cell_rd(flag.mem, fr, lref.val) in
  let b: RV = cell_rd(a.mem, fr, rref.val) in
  if flag.val == 1 && b.val == 0 then
    mk_ex(b.mem, end, 2, (if verb.val == 4 then trap_div0() else trap_mod0()))
  else
    let m: string = cell_wr(b.mem, fr, id.val, apply_binary(verb.val, width.val, sgn.val, a.val, b.val)) in
    mk_ex(m, end, 0, 0)

// call: id, target fn index, abi opt, argc, args, return-address opt, tref.
// Scalar calls only in Stage 2: a present return address traps unsupported.
fn exec_call(mem: string, vm: Vm, fr: Frame, body: i64) -> Ex effects[io, state] =
  let id: RV = rd_u32(mem, body) in
  let target: RV = rd_u32(id.mem, body + 4) in
  let abi: RV = skip_opt(target.mem, body + 8) in
  let argc: RV = rd_u32(abi.mem, abi.val) in
  let retflag: RV = rd_byte(argc.mem, abi.val + 4 + argc.val * 4) in
  let shift: i64 = if retflag.val == 0 then 0 else 1 in
  let end: i64 = abi.val + 4 + argc.val * 4 + 1 + shift * 4 + 4 in
  // the callee frame sits just past this frame's value cells
  let vcount: RV = rd_u32(retflag.mem, fr.mb + 12) in
  let callee_fb: i64 = fr.vb + vcount.val * 8 in
  // a hidden return slot rides as implicit cell 0 of the callee frame
  let dest: RV =
    (if retflag.val == 0 then mk_rv(vcount.mem, 0)
     else
       let rref: RV = rd_u32(vcount.mem, abi.val + 4 + argc.val * 4 + 1) in
       cell_rd(rref.mem, fr, rref.val)) in
  let seeded: string =
    (if retflag.val == 0 then dest.mem
     else wr_u64(dest.mem, callee_fb, dest.val)) in
  let copied: Ex = copy_args(seeded, fr, abi.val + 4, argc.val, callee_fb + shift * 8, 0) in
  if copied.status != 0 then copied
  else
    let run: Ex = call_function(copied.mem, vm, target.val, callee_fb) in
    if run.status == 2 then run
    else
      let result: i64 = if retflag.val == 0 then run.val else dest.val in
      let m: string = cell_wr(run.mem, fr, id.val, result) in
      mk_ex(m, end, 0, 0)

// Copy `argc` argument cells (vrefs at `argp`) into the callee's param
// slots starting at `callee_fb`.
fn copy_args(mem: string, fr: Frame, argp: i64, argc: i64, callee_fb: i64, j: i64) -> Ex effects[state] =
  if j >= argc then
        mk_ex(mem, argp, 0, 0)
  else
    let aref: RV = rd_u32(mem, argp) in
    let v: RV = cell_rd(aref.mem, fr, aref.val) in
    let m: string = wr_u64(v.mem, callee_fb + j * 8, v.val) in
    copy_args(m, fr, argp + 4, argc, callee_fb, j + 1)

// if: id, cond, then block, else block, tref. Execute the taken branch,
// skip the other, store the branch result into the if's own cell.
fn exec_if(mem: string, vm: Vm, fr: Frame, body: i64) -> Ex effects[io, state] =
  let id: RV = rd_u32(mem, body) in
  let cref: RV = rd_u32(id.mem, body + 4) in
  let c: RV = cell_rd(cref.mem, fr, cref.val) in
  if c.val != 0 then
    let t: Ex = exec_block(c.mem, vm, fr, body + 8) in
    (if t.status != 0 then t
     else
       let e: RV = skip_block(t.mem, t.pc) in
       let m: string = cell_wr(e.mem, fr, id.val, t.val) in
              mk_ex(m, e.val + 4, 0, 0))
  else
    let tskip: RV = skip_block(c.mem, body + 8) in
    let e: Ex = exec_block(tskip.mem, vm, fr, tskip.val) in
    (if e.status != 0 then e
     else
       let m: string = cell_wr(e.mem, fr, id.val, e.val) in
              mk_ex(m, e.pc + 4, 0, 0))

// opcodes 12..16, 19..20: borrows yield their referent's address; derefs
// (shared/mut/box/raw) and ptr_cast are the identity on an address cell (a
// reference, box, or raw pointer IS an address in this machine; the actual
// read is the subsequent load through it - backend parity).
fn exec_op_ref(mem: string, vm: Vm, fr: Frame, code: i64, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let vref: RV = rd_u32(id.mem, body + 4) in
  let v: RV = cell_rd(vref.mem, fr, vref.val) in
  let m: string = cell_wr(v.mem, fr, id.val, v.val) in
  let end: i64 = body +
    (if code <= 13 then 20
     else if code <= 15 then 12
     else if code == 16 then 16
     else if code == 19 then 16
     else 17) in
  mk_ex(m, end, 0, 0)

// opcodes 21..22: addr_of_param / addr_of_local.
fn exec_op_addr(mem: string, vm: Vm, fr: Frame, code: i64, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let pk: RV = rd_byte(id.mem, body + 4) in
  let slot: RV = rd_u32(pk.mem, body + 5) in
  if code == 21 then
    let ind: RV = rd_byte(slot.mem, body + 13) in
    (if ind.val != 0 then
       let coff: RV = rd_u32(ind.mem, fr.mb + 40 + slot.val * 8) in
       let m: string = cell_wr(coff.mem, fr, id.val, fr.cb + coff.val) in
       mk_ex(m, body + 14, 0, 0)
     else
       let m: string = cell_wr(ind.mem, fr, id.val, fr.fb + (fr.hidden + slot.val) * 8) in
       mk_ex(m, body + 14, 0, 0))
  else
    let loff: RV = rd_u32(slot.mem, fr.mb + 40 + fr.pcount * 8 + slot.val * 4) in
    let m: string = cell_wr(loff.mem, fr, id.val, fr.lb + loff.val) in
    mk_ex(m, body + 13, 0, 0)

// opcodes 23..25: addresses through aggregate places, all carrying their
// explicit byte offsets (the CIR consumer design): field/payload = base
// address + offset; index = base + index * element stride.
fn exec_op_addr_agg(mem: string, fr: Frame, code: i64, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let base: RV = rd_u32(id.mem, body + 5) in
  let baddr: RV = cell_rd(base.mem, fr, base.val) in
  if code == 25 then
    let iref: RV = rd_u32(baddr.mem, body + 9) in
    let etref: RV = rd_u32(iref.mem, body + 13) in
    let stride: RV = elem_stride(etref.mem, fr, etref.val) in
    let idx: RV = cell_rd(stride.mem, fr, iref.val) in
    let m: string = cell_wr(idx.mem, fr, id.val, baddr.val + idx.val * stride.val) in
    mk_ex(m, body + 21, 0, 0)
  else
    let flag: RV = rd_byte(baddr.mem, body + 13) in
    let sym: i64 = if flag.val == 0 then 0 else 4 in
    if code == 23 then
      let off: RV = rd_u64(flag.mem, body + 18 + sym) in
      let m: string = cell_wr(off.mem, fr, id.val, baddr.val + off.val) in
      mk_ex(m, body + 30 + sym, 0, 0)
    else
      let poff: RV = rd_u64(flag.mem, body + 26 + sym) in
      let m: string = cell_wr(poff.mem, fr, id.val, baddr.val + poff.val) in
      mk_ex(m, body + 38 + sym, 0, 0)

// opcodes 26..29: static data (pool bytes addressed in the image), slice
// construction ({data_ptr, len} at the slice place), and the two reads.
fn exec_op_slice(mem: string, vm: Vm, fr: Frame, code: i64, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  if code == 26 then
    let didx: RV = rd_u32(id.mem, body + 8) in
    let blob: RV = rd_u32(didx.mem, vm.data_index + didx.val * 4) in
    let m: string = cell_wr(blob.mem, fr, id.val, blob.val) in
    mk_ex(m, body + 24, 0, 0)
  else if code == 27 then
    let aref: RV = rd_u32(id.mem, body + 4) in
    let dref: RV = rd_u32(aref.mem, body + 8) in
    let lref: RV = rd_u32(dref.mem, body + 12) in
    let addr: RV = cell_rd(lref.mem, fr, aref.val) in
    let data: RV = cell_rd(addr.mem, fr, dref.val) in
    let len: RV = cell_rd(data.mem, fr, lref.val) in
    let m1: string = wr_u64(len.mem, addr.val, data.val) in
    let m2: string = wr_u64(m1, addr.val + 8, len.val) in
    let m3: string = cell_wr(m2, fr, id.val, addr.val) in
    mk_ex(m3, body + 24, 0, 0)
  else
    let sref: RV = rd_u32(id.mem, body + 4) in
    let saddr: RV = cell_rd(sref.mem, fr, sref.val) in
    let v: RV = rd_u64(saddr.mem, saddr.val + (if code == 28 then 8 else 0)) in
    let m: string = cell_wr(v.mem, fr, id.val, v.val) in
    mk_ex(m, body + 16, 0, 0)

// case: id, scrutinee, enum tref, arm count, arms, tref. Read the 8-byte
// tag at the enum's address, then try arms in order; the LAST arm runs
// unconditionally (backend parity: it is the default).
fn exec_case(mem: string, vm: Vm, fr: Frame, body: i64) -> Ex effects[io, state] =
  let id: RV = rd_u32(mem, body) in
  let scr: RV = rd_u32(id.mem, body + 4) in
  let armc: RV = rd_u32(scr.mem, body + 12) in
  let saddr: RV = cell_rd(armc.mem, fr, scr.val) in
  let tag: RV = rd_u64(saddr.mem, saddr.val) in
  run_case_arms(tag.mem, vm, fr, id.val, tag.val, body + 16, armc.val)

// One case arm: variant str, symbol opt, tag u64, payload tref, payload
// offset u64, block. On a match (or the last arm) run the block, store its
// result, and skip the remaining arms to land past the case's tail tref.
fn run_case_arms(mem: string, vm: Vm, fr: Frame, id: i64, tag: i64, pc: i64, remaining: i64) -> Ex effects[io, state] =
  let o: RV = skip_opt(mem, pc + 4) in
  let atag: RV = rd_u64(o.mem, o.val) in
  let bpc: i64 = o.val + 20 in
  if remaining <= 1 || atag.val == tag then
    let ex: Ex = exec_block(atag.mem, vm, fr, bpc) in
    (if ex.status != 0 then ex
     else
       let rest: RV = skip_case_arms(ex.mem, ex.pc, remaining - 1) in
       let m: string = cell_wr(rest.mem, fr, id, ex.val) in
       mk_ex(m, rest.val + 4, 0, 0))
  else
    let sk: RV = skip_block(atag.mem, bpc) in
    run_case_arms(sk.mem, vm, fr, id, tag, sk.val, remaining - 1)

// Store a block result into an accumulator/item local: aggregates memcpy
// their bytes; scalars write the full 8-byte cell (backend parity).
fn store_to_local(mem: string, fr: Frame, tref: i64, addr: i64, v: i64) -> string effects[state] =
  let kind: RV = type_kind(mem, fr, tref) in
  if kind.val >= 12 then
    let size: RV = type_size(kind.mem, fr, tref) in
    mem_copy(size.mem, addr, v, size.val)
  else wr_u64(kind.mem, addr, v)

// The local-offset read shared by the fold/loop drivers.
fn local_addr(mem: string, fr: Frame, slot: i64) -> RV =
  let loff: RV = rd_u32(mem, fr.mb + 40 + fr.pcount * 8 + slot * 4) in
  mk_rv(loff.mem, fr.lb + loff.val)

// The fold target's element base: an array's address directly, a slice's
// data pointer (kind 13) through one deref.
fn fold_base(mem: string, fr: Frame, ttref: i64, tgt: i64) -> RV =
  let tkind: RV = type_kind(mem, fr, ttref) in
  let base0: RV = cell_rd(tkind.mem, fr, tgt) in
  if tkind.val == 13 then rd_u64(base0.mem, base0.val) else mk_rv(base0.mem, base0.val)

// Seed an accumulator local from a value cell.
fn seed_local(mem: string, fr: Frame, tref: i64, addr: i64, vref: i64) -> string effects[state] =
  let v: RV = cell_rd(mem, fr, vref) in
  store_to_local(v.mem, fr, tref, addr, v.val)

// fold: id, target address, target tref, len, init, index/acc/item slots,
// body block, element tref, acc tref, tref. Drive the body once per index:
// the item local gets the element's bytes, the acc local the body result.
fn exec_fold(mem: string, vm: Vm, fr: Frame, body: i64) -> Ex effects[io, state] =
  let id: RV = rd_u32(mem, body) in
  let tgt: RV = rd_u32(id.mem, body + 4) in
  let ttref: RV = rd_u32(tgt.mem, body + 8) in
  let lref: RV = rd_u32(ttref.mem, body + 12) in
  let iref: RV = rd_u32(lref.mem, body + 16) in
  let islot: RV = rd_u32(iref.mem, body + 20) in
  let aslot: RV = rd_u32(islot.mem, body + 24) in
  let itslot: RV = rd_u32(aslot.mem, body + 28) in
  let bpc: i64 = body + 32 in
  let sk: RV = skip_block(itslot.mem, bpc) in
  let etref: RV = rd_u32(sk.mem, sk.val) in
  let atref: RV = rd_u32(etref.mem, sk.val + 4) in
  let a: FoldArgs = { id: id.val, tgt: tgt.val, ttref: ttref.val, lref: lref.val, iref: iref.val, islot: islot.val, aslot: aslot.val, itslot: itslot.val, bpc: bpc, etref: etref.val, atref: atref.val, end: sk.val + 12 } in
  fold_drive(atref.mem, vm, fr, a)

// The fold driver proper (split from the header parse for frame size; the
// decoded header rides in one Copy record - the 8-machine-param cap).
fn fold_drive(mem: string, vm: Vm, fr: Frame, a: FoldArgs) -> Ex effects[io, state] =
  let base: RV = fold_base(mem, fr, a.ttref, a.tgt) in
  let stride: RV = elem_stride(base.mem, fr, a.etref) in
  let esize: RV = type_size(stride.mem, fr, a.etref) in
  let len: RV = cell_rd(esize.mem, fr, a.lref) in
  let ia: RV = local_addr(len.mem, fr, a.islot) in
  let aa: RV = local_addr(ia.mem, fr, a.aslot) in
  let ita: RV = local_addr(aa.mem, fr, a.itslot) in
  let seeded: string = seed_local(ita.mem, fr, a.atref, aa.val, a.iref) in
  let done: St4 =
    loop st = mk_st4(seeded, 0, 0, 0) while st.st == 0 && st.aux < len.val do
      let cur: St4 = st in
      let m1: string = wr_u64(cur.mem, ia.val, cur.aux) in
      let m2: string = mem_copy(m1, ita.val, base.val + cur.aux * stride.val, esize.val) in
      let ex: Ex = exec_block(m2, vm, fr, a.bpc) in
      if ex.status != 0 then mk_st4(ex.mem, ex.status, ex.val, cur.aux)
      else
        let m3: string = store_to_local(ex.mem, fr, a.atref, aa.val, ex.val) in
        mk_st4(m3, 0, 0, cur.aux + 1)
  in
  if done.st != 0 then mk_ex(done.mem, a.end, done.st, done.val)
  else fold_finish(done.mem, fr, a.id, a.atref, aa.val, a.end)

// The fold/loop result: an aggregate accumulator yields its local's
// address; a scalar yields the cell stored there.
fn fold_finish(mem: string, fr: Frame, id: i64, atref: i64, aa: i64, end: i64) -> Ex effects[state] =
  let kind: RV = type_kind(mem, fr, atref) in
  if kind.val >= 12 then
    let m: string = cell_wr(kind.mem, fr, id, aa) in
    mk_ex(m, end, 0, 0)
  else
    let v: RV = rd_u64(kind.mem, aa) in
    let m: string = cell_wr(v.mem, fr, id, v.val) in
    mk_ex(m, end, 0, 0)

// loop: id, acc slot, init, cond block, body block, acc tref, tref. Seed
// the accumulator local, then: run cond; 0 exits; run body; store the acc.
fn exec_loop(mem: string, vm: Vm, fr: Frame, body: i64) -> Ex effects[io, state] =
  let id: RV = rd_u32(mem, body) in
  let aslot: RV = rd_u32(id.mem, body + 4) in
  let iref: RV = rd_u32(aslot.mem, body + 8) in
  let cpc: i64 = body + 12 in
  let sk1: RV = skip_block(iref.mem, cpc) in
  let sk2: RV = skip_block(sk1.mem, sk1.val) in
  let atref: RV = rd_u32(sk2.mem, sk2.val) in
  let a: LoopArgs = { id: id.val, iref: iref.val, aslot: aslot.val, cpc: cpc, bpc: sk1.val, atref: atref.val, end: sk2.val + 8 } in
  loop_drive(atref.mem, vm, fr, a)

// The loop driver proper (split from the header parse for frame size; the
// decoded header rides in one Copy record - the 8-machine-param cap).
fn loop_drive(mem: string, vm: Vm, fr: Frame, a: LoopArgs) -> Ex effects[io, state] =
  let aa: RV = local_addr(mem, fr, a.aslot) in
  let seeded: string = seed_local(aa.mem, fr, a.atref, aa.val, a.iref) in
  let done: St4 =
    loop st = mk_st4(seeded, 0, 0, 1) while st.st == 0 && st.aux == 1 do
      let cur: St4 = st in
      let c: Ex = exec_block(cur.mem, vm, fr, a.cpc) in
      if c.status != 0 then mk_st4(c.mem, c.status, c.val, 0)
      else if c.val == 0 then mk_st4(c.mem, 0, 0, 0)
      else
        let b: Ex = exec_block(c.mem, vm, fr, a.bpc) in
        if b.status != 0 then mk_st4(b.mem, b.status, b.val, 0)
        else
          let m3: string = store_to_local(b.mem, fr, a.atref, aa.val, b.val) in
          mk_st4(m3, 0, 0, 1)
  in
  if done.st != 0 then mk_ex(done.mem, a.end, done.st, done.val)
  else fold_finish(done.mem, fr, a.id, a.atref, aa.val, a.end)

// opcodes 17..18: unbox (copy the payload out, shell free is a no-op over
// the bump heap) and heap_alloc (bump; the backend's malloc).
fn exec_op_heap(mem: string, vm: Vm, fr: Frame, code: i64, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  if code == 18 then
    let size: RV = rd_u64(id.mem, body + 4) in
    let a: RV = bump_alloc(size.mem, vm, size.val) in
    (if a.val == 0 then mk_ex(a.mem, body + 28, 2, trap_heap())
     else
       let m: string = cell_wr(a.mem, fr, id.val, a.val) in
       mk_ex(m, body + 28, 0, 0))
  else
    let bref: RV = rd_u32(id.mem, body + 4) in
    let etref: RV = rd_u32(bref.mem, body + 12) in
    let dslot: RV = rd_u32(etref.mem, body + 16) in
    let kind: RV = type_kind(dslot.mem, fr, etref.val) in
    let payload: RV = cell_rd(kind.mem, fr, bref.val) in
    if kind.val >= 12 then
      let size: RV = type_size(payload.mem, fr, etref.val) in
      let da: RV = local_addr(size.mem, fr, dslot.val) in
      let m1: string = mem_copy(da.mem, da.val, payload.val, size.val) in
      let m2: string = cell_wr(m1, fr, id.val, da.val) in
      mk_ex(m2, body + 20, 0, 0)
    else
      let v: RV = load_cell(payload.mem, fr, etref.val, payload.val) in
      let m: string = cell_wr(v.mem, fr, id.val, v.val) in
      mk_ex(m, body + 20, 0, 0)

// opcodes 30..39: the dynamic buffers (vec and string share one {ptr,len,
// capacity} header described by the layout's buffer consumer columns).
fn exec_op_buf(mem: string, vm: Vm, fr: Frame, code: i64, body: i64) -> Ex effects[state] =
  if code == 30 then exec_buf_new(mem, vm, fr, body, 0)
  else if code == 31 || code == 37 then exec_buf_push(mem, fr, code, body)
  else if code == 32 || code == 38 then exec_buf_get(mem, fr, code, body)
  else if code == 33 || code == 35 then exec_buf_len(mem, fr, body)
  else if code == 34 then exec_string_new(mem, vm, fr, body)
  else if code == 36 then exec_buf_new(mem, vm, fr, body, 1)
  else exec_buf_set(mem, fr, body)

// vec_new (capacity a u64 literal; runtime = 0) / string_with_capacity
// (capacity a value; runtime = 1): bump the payload, write the header
// {ptr, 0, capacity} at the buffer place, yield the header address.
fn exec_buf_new(mem: string, vm: Vm, fr: Frame, body: i64, runtime: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let aref: RV = rd_u32(id.mem, body + 4) in
  let cap: RV =
    (if runtime == 0 then rd_u64(aref.mem, body + 8)
     else
       let cref: RV = rd_u32(aref.mem, body + 8) in
       cell_rd(cref.mem, fr, cref.val)) in
  let tref: RV = rd_u32(cap.mem, body + (if runtime == 0 then 20 else 12)) in
  let stride: RV = buf_col(tref.mem, fr, tref.val, 4) in
  let payload: RV = bump_alloc(stride.mem, vm, cap.val * stride.val) in
  let end: i64 = body + (if runtime == 0 then 24 else 16) in
  if payload.val == 0 then mk_ex(payload.mem, end, 2, trap_heap())
  else
    let h: RV = write_buf_header(payload.mem, fr, aref.val, tref.val, payload.val, 0, cap.val) in
    let m: string = cell_wr(h.mem, fr, id.val, h.val) in
    mk_ex(m, end, 0, 0)

// string_new: bump len bytes, copy the static blob in, header {ptr,len,len}.
fn exec_string_new(mem: string, vm: Vm, fr: Frame, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let aref: RV = rd_u32(id.mem, body + 4) in
  let didx: RV = rd_u32(aref.mem, body + 12) in
  let len: RV = rd_u64(didx.mem, body + 16) in
  let tref: RV = rd_u32(len.mem, body + 24) in
  let blob: RV = rd_u32(tref.mem, vm.data_index + didx.val * 4) in
  let payload: RV = bump_alloc(blob.mem, vm, len.val) in
  if payload.val == 0 then mk_ex(payload.mem, body + 28, 2, trap_heap())
  else
    let m1: string = mem_copy(payload.mem, payload.val, blob.val, len.val) in
    let h: RV = write_buf_header(m1, fr, aref.val, tref.val, payload.val, len.val, len.val) in
    let m2: string = cell_wr(h.mem, fr, id.val, h.val) in
    mk_ex(m2, body + 28, 0, 0)

// Write a buffer header {ptr, len, capacity} at the buffer place's address
// (per the layout's buffer columns) and yield the header address.
fn write_buf_header(mem: string, fr: Frame, aref: i64, tref: i64, ptr: i64, len: i64, cap: i64) -> RV effects[state] =
  let po: RV = buf_col(mem, fr, tref, 0) in
  let lo: RV = buf_col(po.mem, fr, tref, 1) in
  let co: RV = buf_col(lo.mem, fr, tref, 2) in
  let haddr: RV = cell_rd(co.mem, fr, aref) in
  let m1: string = wr_u64(haddr.mem, haddr.val + po.val, ptr) in
  let m2: string = wr_u64(m1, haddr.val + lo.val, len) in
  let m3: string = wr_u64(m2, haddr.val + co.val, cap) in
  mk_rv(m3, haddr.val)

// vec_push (31) / string_push (37): trap at capacity, write the element at
// ptr + len*stride (1- or 8-byte elements), bump len.
fn exec_buf_push(mem: string, fr: Frame, code: i64, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let aref: RV = rd_u32(id.mem, body + 4) in
  let vref: RV = rd_u32(aref.mem, body + 8) in
  let tref: RV = rd_u32(vref.mem, body + 12) in
  let end: i64 = body + (if code == 31 then 24 else 20) in
  let h: RV = cell_rd(tref.mem, fr, aref.val) in
  let lo: RV = buf_col(h.mem, fr, tref.val, 1) in
  let len: RV = rd_u64(lo.mem, h.val + lo.val) in
  let co: RV = buf_col(len.mem, fr, tref.val, 2) in
  let cap: RV = rd_u64(co.mem, h.val + co.val) in
  if to_u64(len.val) >= to_u64(cap.val) then mk_ex(cap.mem, end, 2, trap_bounds())
  else
    let m1: string = buf_elem_write(cap.mem, fr, tref.val, h.val, len.val, vref.val) in
    let m2: string = wr_u64(m1, h.val + lo.val, len.val + 1) in
    mk_ex(m2, end, 0, 0)

// The push element write: ptr + len*stride gets the value's low element
// bytes (the backend supports 1- and 8-byte buffer elements).
fn buf_elem_write(mem: string, fr: Frame, tref: i64, h: i64, len: i64, vref: i64) -> string effects[state] =
  let po: RV = buf_col(mem, fr, tref, 0) in
  let ptr: RV = rd_u64(po.mem, h + po.val) in
  let stride: RV = buf_col(ptr.mem, fr, tref, 4) in
  let esize: RV = buf_col(stride.mem, fr, tref, 3) in
  let v: RV = cell_rd(esize.mem, fr, vref) in
  if esize.val == 1 then
    let b: unit = string_set(v.mem, ptr.val + len * stride.val, to_u8(v.val & 0xff)) in
    v.mem
  else wr_u64(v.mem, ptr.val + len * stride.val, v.val)

// vec_get (32) / string_get (38): trap unless index < len, then read the
// element (1-byte elements zero-extend, backend parity).
fn exec_buf_get(mem: string, fr: Frame, code: i64, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let aref: RV = rd_u32(id.mem, body + 4) in
  let iref: RV = rd_u32(aref.mem, body + 8) in
  let tref: RV = rd_u32(iref.mem, body + 12) in
  let end: i64 = body + (if code == 32 then 24 else 20) in
  let h: RV = cell_rd(tref.mem, fr, aref.val) in
  let lo: RV = buf_col(h.mem, fr, tref.val, 1) in
  let len: RV = rd_u64(lo.mem, h.val + lo.val) in
  let idx: RV = cell_rd(len.mem, fr, iref.val) in
  if to_u64(idx.val) >= to_u64(len.val) then mk_ex(idx.mem, end, 2, trap_bounds())
  else
    let v: RV = buf_elem_read(idx.mem, fr, tref.val, h.val, idx.val) in
    let m: string = cell_wr(v.mem, fr, id.val, v.val) in
    mk_ex(m, end, 0, 0)

fn buf_elem_read(mem: string, fr: Frame, tref: i64, h: i64, idx: i64) -> RV =
  let po: RV = buf_col(mem, fr, tref, 0) in
  let ptr: RV = rd_u64(po.mem, h + po.val) in
  let stride: RV = buf_col(ptr.mem, fr, tref, 4) in
  let esize: RV = buf_col(stride.mem, fr, tref, 3) in
  if esize.val == 1 then rd_byte(esize.mem, ptr.val + idx * stride.val)
  else rd_u64(esize.mem, ptr.val + idx * stride.val)

// vec_len (33) / string_len (35): read the header's len field.
fn exec_buf_len(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let aref: RV = rd_u32(id.mem, body + 4) in
  let tref: RV = rd_u32(aref.mem, body + 8) in
  let h: RV = cell_rd(tref.mem, fr, aref.val) in
  let lo: RV = buf_col(h.mem, fr, tref.val, 1) in
  let len: RV = rd_u64(lo.mem, h.val + lo.val) in
  let m: string = cell_wr(len.mem, fr, id.val, len.val) in
  mk_ex(m, body + 16, 0, 0)

// string_set (39): trap unless index < len, then overwrite the byte.
fn exec_buf_set(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let aref: RV = rd_u32(id.mem, body + 4) in
  let iref: RV = rd_u32(aref.mem, body + 8) in
  let vref: RV = rd_u32(iref.mem, body + 12) in
  let tref: RV = rd_u32(vref.mem, body + 16) in
  let h: RV = cell_rd(tref.mem, fr, aref.val) in
  let lo: RV = buf_col(h.mem, fr, tref.val, 1) in
  let len: RV = rd_u64(lo.mem, h.val + lo.val) in
  let idx: RV = cell_rd(len.mem, fr, iref.val) in
  if to_u64(idx.val) >= to_u64(len.val) then mk_ex(idx.mem, body + 24, 2, trap_bounds())
  else
    let m: string = buf_elem_write(idx.mem, fr, tref.val, h.val, idx.val, vref.val) in
    mk_ex(m, body + 24, 0, 0)

// opcodes 40..42: the evaluated program's process arguments are the host's,
// 1:1 (the CIR arrives on stdin, so no argument is consumed by the shell).
fn exec_op_argv(mem: string, fr: Frame, code: i64, body: i64) -> Ex effects[io, state] =
  let id: RV = rd_u32(mem, body) in
  if code == 40 then
    let m: string = cell_wr(id.mem, fr, id.val, arg_count()) in
    mk_ex(m, body + 8, 0, 0)
  else if code == 41 then
    let iref: RV = rd_u32(id.mem, body + 4) in
    let i: RV = cell_rd(iref.mem, fr, iref.val) in
    let m: string = cell_wr(i.mem, fr, id.val, arg_len(i.val)) in
    mk_ex(m, body + 12, 0, 0)
  else
    let iref: RV = rd_u32(id.mem, body + 4) in
    let jref: RV = rd_u32(iref.mem, body + 8) in
    let i: RV = cell_rd(jref.mem, fr, iref.val) in
    let j: RV = cell_rd(i.mem, fr, jref.val) in
    let m: string = cell_wr(j.mem, fr, id.val, to_i64(arg_byte(i.val, j.val))) in
    mk_ex(m, body + 16, 0, 0)

// opcodes 43..55: bounds check, scalar load/store/copy/move, drop (no-op),
// borrow_debug (no-op), return, early_return - a thin router; the data ops
// live in their own functions to keep every frame inside the v0 budget.
fn exec_op_mem(mem: string, vm: Vm, fr: Frame, code: i64, body: i64) -> Ex effects[state] =
  if code == 43 then exec_bounds(mem, fr, body)
  else if code == 44 then exec_range_check(mem, fr, body)
  else if code == 45 then exec_load_enum_tag(mem, fr, body)
  else if code == 46 then exec_store_enum_tag(mem, fr, body)
  else if code == 47 || code == 50 then exec_load_move(mem, fr, body)
  else if code == 48 then exec_store(mem, fr, body)
  else if code == 49 then exec_copy_cell(mem, fr, body)
  else if code == 51 || code == 52 then mk_ex(mem, body + 8, 0, 0)
  else if code == 53 then exec_bdebug(mem, body)
  else if code == 54 || code == 55 then exec_return(mem, fr, body)
  else mk_ex(mem, body, 2, trap_unsupported())

// load / move: id, address, tref -> scalar read through the address cell.
fn exec_load_move(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let aref: RV = rd_u32(id.mem, body + 4) in
  let tref: RV = rd_u32(aref.mem, body + 8) in
  let kind: RV = type_kind(tref.mem, fr, tref.val) in
  if kind.val >= 12 then
    // an aggregate value IS its address: alias the cell (backend parity)
    let addr: RV = cell_rd(kind.mem, fr, aref.val) in
    let m: string = cell_wr(addr.mem, fr, id.val, addr.val) in
    mk_ex(m, body + 12, 0, 0)
  else
    // scalars extend canonically; a by-value aggregate (11) is its raw
    // byte pattern in the cell
    let addr: RV = cell_rd(kind.mem, fr, aref.val) in
    let v: RV = load_cell(addr.mem, fr, tref.val, addr.val) in
    let m: string = cell_wr(v.mem, fr, id.val, v.val) in
    mk_ex(m, body + 12, 0, 0)

// store: address, value, tref -> scalar write through the address cell.
fn exec_store(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let aref: RV = rd_u32(mem, body) in
  let vref: RV = rd_u32(aref.mem, body + 4) in
  let tref: RV = rd_u32(vref.mem, body + 8) in
  let kind: RV = type_kind(tref.mem, fr, tref.val) in
  if kind.val >= 12 then
    // aggregate store: memcpy the value's bytes to the destination place
    let size: RV = type_size(kind.mem, fr, tref.val) in
    let addr: RV = cell_rd(size.mem, fr, aref.val) in
    let v: RV = cell_rd(addr.mem, fr, vref.val) in
    let m: string = mem_copy(v.mem, addr.val, v.val, size.val) in
    mk_ex(m, body + 12, 0, 0)
  else if kind.val == 11 then
    let size: RV = type_size(kind.mem, fr, tref.val) in
    let addr: RV = cell_rd(size.mem, fr, aref.val) in
    let v: RV = cell_rd(addr.mem, fr, vref.val) in
    let m: string = wr_bytes_le(v.mem, addr.val, v.val, size.val, 0) in
    mk_ex(m, body + 12, 0, 0)
  else
    let addr: RV = cell_rd(kind.mem, fr, aref.val) in
    let v: RV = cell_rd(addr.mem, fr, vref.val) in
    let m: string = store_scalar(v.mem, kind.val, addr.val, v.val) in
    mk_ex(m, body + 12, 0, 0)

// copy: id, value, tref -> cell copy.
fn exec_copy_cell(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let vref: RV = rd_u32(id.mem, body + 4) in
  let v: RV = cell_rd(vref.mem, fr, vref.val) in
  let m: string = cell_wr(v.mem, fr, id.val, v.val) in
  mk_ex(m, body + 12, 0, 0)

// borrow_debug: address, mutable u8, region opt, tref -> no-op.
fn exec_bdebug(mem: string, body: i64) -> Ex =
  let o: RV = skip_opt(mem, body + 5) in
  mk_ex(o.mem, o.val + 4, 0, 0)

// return / early_return: value, tref -> unwind to the function boundary.
// An indirect-returning function copies the value's bytes to the hidden
// return slot (cell 0) and yields that destination address.
fn exec_return(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let vref: RV = rd_u32(mem, body) in
  let v: RV = cell_rd(vref.mem, fr, vref.val) in
  if fr.hidden == 0 then mk_ex(v.mem, body + 8, 3, v.val)
  else
    let rsize: RV = rd_u32(v.mem, fr.mb + 32) in
    let dest: RV = rd_u64(rsize.mem, fr.fb) in
    let m: string = mem_copy(dest.mem, dest.val, v.val, rsize.val) in
    mk_ex(m, body + 8, 3, dest.val)

// slice_range_check: id, start, len, source_len, tref. Unsigned compares
// (a negative start/len is huge unsigned and traps): start <= source_len and
// len <= source_len - start, else trap; the result is unit.
fn exec_range_check(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let sref: RV = rd_u32(id.mem, body + 4) in
  let lref: RV = rd_u32(sref.mem, body + 8) in
  let nref: RV = rd_u32(lref.mem, body + 12) in
  let start: RV = cell_rd(nref.mem, fr, sref.val) in
  let len: RV = cell_rd(start.mem, fr, lref.val) in
  let src: RV = cell_rd(len.mem, fr, nref.val) in
  if to_u64(start.val) > to_u64(src.val) || to_u64(len.val) > to_u64(src.val) - to_u64(start.val) then
    mk_ex(src.mem, body + 20, 2, trap_bounds())
  else
    let m: string = cell_wr(src.mem, fr, id.val, 0) in
    mk_ex(m, body + 20, 0, 0)

// load_enum_tag: id, address, tref -> the 8-byte tag at the enum's base.
fn exec_load_enum_tag(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let aref: RV = rd_u32(id.mem, body + 4) in
  let addr: RV = cell_rd(aref.mem, fr, aref.val) in
  let tag: RV = rd_u64(addr.mem, addr.val) in
  let m: string = cell_wr(tag.mem, fr, id.val, tag.val) in
  mk_ex(m, body + 12, 0, 0)

// store_enum_tag: address, tref, variant str, symbol opt, tag u64.
fn exec_store_enum_tag(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let aref: RV = rd_u32(mem, body) in
  let o: RV = skip_opt(aref.mem, body + 12) in
  let tag: RV = rd_u64(o.mem, o.val) in
  let addr: RV = cell_rd(tag.mem, fr, aref.val) in
  let m: string = wr_u64(addr.mem, addr.val, tag.val) in
  mk_ex(m, o.val + 8, 0, 0)

// bounds_check: id, index, len u64, len_value opt, tref. Out of range traps.
fn exec_bounds(mem: string, fr: Frame, body: i64) -> Ex effects[state] =
  let id: RV = rd_u32(mem, body) in
  let iref: RV = rd_u32(id.mem, body + 4) in
  let len: RV = rd_u64(iref.mem, body + 8) in
  let flag: RV = rd_byte(len.mem, body + 16) in
  let lv: RV = (if flag.val == 0 then
    mk_rv(flag.mem, len.val)
  else
    let lref: RV = rd_u32(flag.mem, body + 17) in
    cell_rd(lref.mem, fr, lref.val)) in
  let end: i64 = body + 17 + (if flag.val == 0 then 0 else 4) + 4 in
  let idx: RV = cell_rd(lv.mem, fr, iref.val) in
  if idx.val < 0 || idx.val >= lv.val then
    mk_ex(idx.mem, end, 2, trap_bounds())
  else
    let m: string = cell_wr(idx.mem, fr, id.val, idx.val) in
    mk_ex(m, end, 0, 0)

// Run function `fidx` with its params already written at `frame_base`.
// status 3 (returned) is the normal outcome; falling off the end without a
// terminal return is malformed.
fn call_function(mem: string, vm: Vm, fidx: i64, frame_base: i64) -> Ex effects[io, state] =
  let mb: RV = rd_u32(mem, vm.meta_index + fidx * 4) in
  let ops_base: RV = rd_u32(mb.mem, mb.val) in
  let tb: RV = rd_u32(ops_base.mem, mb.val + 4) in
  let lt: RV = rd_u32(tb.mem, mb.val + 8) in
  let vcount: RV = rd_u32(lt.mem, mb.val + 12) in
  let pcount: RV = rd_u32(vcount.mem, mb.val + 16) in
  let ltotal: RV = rd_u32(pcount.mem, mb.val + 24) in
  let rkind: RV = rd_u32(ltotal.mem, mb.val + 28) in
  let ctotal: RV = rd_u32(rkind.mem, mb.val + 36) in
  let hidden: i64 = if rkind.val >= 12 then 1 else 0 in
  let cb: i64 = frame_base + (hidden + pcount.val) * 8 in
  let lb: i64 = cb + ctotal.val in
  let vb: i64 = lb + ltotal.val in
  let frame_end: i64 = vb + vcount.val * 8 in
  if frame_end > vm.stack_end then
    mk_ex(ctotal.mem, 0, 2, trap_stack_overflow())
  else
    let fr: Frame = { fb: frame_base, vb: vb, pcount: pcount.val, hidden: hidden, cb: cb, lb: lb, mb: mb.val, tb: tb.val, lt: lt.val } in
    let copied: string = copy_indirect_params(ctotal.mem, fr, 0) in
    let count: RV = rd_u32(copied, ops_base.val) in
    let run: Ex = exec_ops(count.mem, vm, fr, ops_base.val + 4, count.val) in
    if run.status == 0 then
      mk_ex(run.mem, run.pc, 2, trap_malformed())
    else run

// The callee prologue's ownership copies: each aggregate-indirect param's
// pointed-to bytes are copied into the frame's copy slot (the param CELL
// keeps the caller's address; addr_of_param(indirect) yields the copy).
fn copy_indirect_params(mem: string, fr: Frame, j: i64) -> string effects[state] =
  if j >= fr.pcount then mem
  else
    let entry: i64 = fr.mb + 40 + j * 8 in
    let coff: RV = rd_u32(mem, entry) in
    if coff.val == 0xffffffff then copy_indirect_params(coff.mem, fr, j + 1)
    else
      let size: RV = rd_u32(coff.mem, entry + 4) in
      let src: RV = rd_u64(size.mem, fr.fb + (fr.hidden + j) * 8) in
      let m1: string = mem_copy(src.mem, fr.cb + coff.val, src.val, size.val) in
      copy_indirect_params(m1, fr, j + 1)

// ---------------------------------------------------------------------------
// entry
// ---------------------------------------------------------------------------

// Look up the entry's meta blob and run it on a fresh stack, rendering the
// result (or trap) through the output protocol.
fn execute_entry<'r>(mem: string, vm: Vm) -> i64 effects[io, alloc, state, ffi, unsafe] =
  let emb: RV = rd_u32(mem, vm.meta_index + vm.entry * 4) in
  let epcount: RV = rd_u32(emb.mem, emb.val + 16) in
  let rkind0: RV = rd_u32(epcount.mem, emb.val + 28) in
  if epcount.val > 0 || rkind0.val >= 11 then
    // a param-taking or aggregate-result entry is outside the rung-0
    // protocol (the corpus is scalar-result programs)
    let t: i64 = print_trap(trap_entry_params()) in
    101
  else
    let rkind: RV = mk_rv(rkind0.mem, rkind0.val) in
    let result: Ex = call_function(rkind.mem, vm, vm.entry, vm.stack_base) in
    if result.status == 3 then
      let p: i64 = print_ok(rkind.val, result.val) in
      0
    else
      let t: i64 = print_trap(result.val) in
      101

// Header walk (probe-validated in Stage 1): magic/version, the two pools,
// target/entry/function count, the function table. Then build the metadata
// region, zero-fill the machine regions, and execute the entry.
fn run(mem: string) -> i64 effects[io, alloc, state, ffi, unsafe] =
  if string_len(mem) < 32 then 65
  else
    let magic: RV = rd_u32(mem, 0) in
    let g1: i64 = (if magic.val == 0x52494443 then 0 else return 65) in
    let version: RV = rd_u32(magic.mem, 4) in
    let g2: i64 = (if version.val == 0 then 0 else return 65) in
    let strs: RV = rd_u32(version.mem, 8) in
    let strbytes: RV = sum_lens(strs.mem, 12, strs.val) in
    let doff: i64 = 12 + strs.val * 4 + strbytes.val in
    let datas: RV = rd_u32(strbytes.mem, doff) in
    let databytes: RV = sum_lens(datas.mem, doff + 4, datas.val) in
    let tail: i64 = doff + 4 + datas.val * 4 + databytes.val in
    let entry: RV = rd_u32(databytes.mem, tail + 4) in
    let fns: RV = rd_u32(entry.mem, tail + 8) in
    let image_len: i64 = string_len(fns.mem) in
    let meta_base: i64 = align8(image_len) in
    let stack_base: i64 = meta_base + meta_size() in
    let vm: Vm = {
      fns: fns.val,
      entry: entry.val,
      table_base: tail + 12,
      region_base: tail + 12 + fns.val * 12,
      meta_index: meta_base,
      data_index: meta_base + fns.val * 4,
      stack_base: stack_base,
      stack_end: stack_base + stack_size()
    } in
    let filled: string = zero_fill(fns.mem, vm.stack_end + 8 + heap_size()) in
    let heap_seeded: string = wr_u64(filled, vm.stack_end, vm.stack_end + 8) in
    let with_data: string = build_data_index(heap_seeded, doff + 4, doff + 4 + datas.val * 4, vm.data_index, datas.val, 0, 0) in
    let built: string = build_meta(with_data, vm, 0, vm.data_index + datas.val * 4) in
    execute_entry(built, vm)

// Sum `count` little-endian u32s starting at `base` (a pool's byte-length
// prefix -> the pool's total byte size). The u32 assembly is inlined because
// a loop body may only read outer storage, never move it into a call; the
// final record is anchored by a typed let (the structural-literal gap).
fn sum_lens(mem: string, base: i64, count: i64) -> RV =
  let done: Sum =
    loop s = { i: 0, total: 0 } while s.i < count do
      let off: i64 = base + s.i * 4 in
      let b0: i64 = to_i64(string_get(mem, off)) in
      let b1: i64 = to_i64(string_get(mem, off + 1)) in
      let b2: i64 = to_i64(string_get(mem, off + 2)) in
      let b3: i64 = to_i64(string_get(mem, off + 3)) in
      let next: Sum = { i: s.i + 1, total: s.total + (b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)) } in
      next
  in
  mk_rv(mem, done.total)

// eval-bin < program.cir [program-args...]: the CIR arrives on stdin; every
// process argument belongs to the evaluated program (forwarded from Stage 4).
fn main<'r>() -> i64 effects[io, alloc, state, ffi, unsafe] =
  run(read_all(string_with_capacity(mem_cap())))

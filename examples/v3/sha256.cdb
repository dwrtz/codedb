// sha256.cdb - SHA-256 of the test vector "abc" (single 512-bit block).
//
// Phase 9 forcing function for the bitwise / sized / cast stack (R4/R5/R6): real
// u32 wrapping arithmetic, bitwise & | ^ ~, shifts, and 32-bit rotates (shift+or),
// over the layout model. The padded "abc" block is the 16 input words in
// `schedule`; the 48 derived words and the 64 compression rounds are unrolled
// (loops are a later milestone) and split into `schedule` (the word array) and
// `compress` (the working state) so neither exceeds the migration-JSON nesting
// bound. The reference evaluator is the oracle here: the unrolled hash's per-
// function stack frame exceeds the v0 native backend's size bound, so this is an
// eval-verified fixture; the underlying u32 ops are native-checked by
// tests/oracle_conformance.rs and examples/fnv1a.cdb.
//
//   reference: sha256("abc") = ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad

fn rotr(x: u32, n: u32) -> u32 = (x >> n) | (x << (32 - n))
fn ssig0(x: u32) -> u32 = rotr(x, 7) ^ rotr(x, 18) ^ (x >> 3)
fn ssig1(x: u32) -> u32 = rotr(x, 17) ^ rotr(x, 19) ^ (x >> 10)
fn bsig0(x: u32) -> u32 = rotr(x, 2) ^ rotr(x, 13) ^ rotr(x, 22)
fn bsig1(x: u32) -> u32 = rotr(x, 6) ^ rotr(x, 11) ^ rotr(x, 25)
fn ch(x: u32, y: u32, z: u32) -> u32 = (x & y) ^ (~x & z)
fn maj(x: u32, y: u32, z: u32) -> u32 = (x & y) ^ (x & z) ^ (y & z)

record State {
  a: u32
  b: u32
  c: u32
  d: u32
  e: u32
  f: u32
  g: u32
  h: u32
}

fn round(s: State, k: u32, w: u32) -> State =
  let t1: u32 = s.h + bsig1(s.e) + ch(s.e, s.f, s.g) + k + w in
  let t2: u32 = bsig0(s.a) + maj(s.a, s.b, s.c) in
  { a: t1 + t2, b: s.a, c: s.b, d: s.c, e: s.d + t1, f: s.e, g: s.f, h: s.g }

fn schedule() -> array<u32, 64> =
  let w0: u32 = 0x61626380 in
  let w1: u32 = 0x0 in
  let w2: u32 = 0x0 in
  let w3: u32 = 0x0 in
  let w4: u32 = 0x0 in
  let w5: u32 = 0x0 in
  let w6: u32 = 0x0 in
  let w7: u32 = 0x0 in
  let w8: u32 = 0x0 in
  let w9: u32 = 0x0 in
  let w10: u32 = 0x0 in
  let w11: u32 = 0x0 in
  let w12: u32 = 0x0 in
  let w13: u32 = 0x0 in
  let w14: u32 = 0x0 in
  let w15: u32 = 0x18 in
  let w16: u32 = ssig1(w14) + w9 + ssig0(w1) + w0 in
  let w17: u32 = ssig1(w15) + w10 + ssig0(w2) + w1 in
  let w18: u32 = ssig1(w16) + w11 + ssig0(w3) + w2 in
  let w19: u32 = ssig1(w17) + w12 + ssig0(w4) + w3 in
  let w20: u32 = ssig1(w18) + w13 + ssig0(w5) + w4 in
  let w21: u32 = ssig1(w19) + w14 + ssig0(w6) + w5 in
  let w22: u32 = ssig1(w20) + w15 + ssig0(w7) + w6 in
  let w23: u32 = ssig1(w21) + w16 + ssig0(w8) + w7 in
  let w24: u32 = ssig1(w22) + w17 + ssig0(w9) + w8 in
  let w25: u32 = ssig1(w23) + w18 + ssig0(w10) + w9 in
  let w26: u32 = ssig1(w24) + w19 + ssig0(w11) + w10 in
  let w27: u32 = ssig1(w25) + w20 + ssig0(w12) + w11 in
  let w28: u32 = ssig1(w26) + w21 + ssig0(w13) + w12 in
  let w29: u32 = ssig1(w27) + w22 + ssig0(w14) + w13 in
  let w30: u32 = ssig1(w28) + w23 + ssig0(w15) + w14 in
  let w31: u32 = ssig1(w29) + w24 + ssig0(w16) + w15 in
  let w32: u32 = ssig1(w30) + w25 + ssig0(w17) + w16 in
  let w33: u32 = ssig1(w31) + w26 + ssig0(w18) + w17 in
  let w34: u32 = ssig1(w32) + w27 + ssig0(w19) + w18 in
  let w35: u32 = ssig1(w33) + w28 + ssig0(w20) + w19 in
  let w36: u32 = ssig1(w34) + w29 + ssig0(w21) + w20 in
  let w37: u32 = ssig1(w35) + w30 + ssig0(w22) + w21 in
  let w38: u32 = ssig1(w36) + w31 + ssig0(w23) + w22 in
  let w39: u32 = ssig1(w37) + w32 + ssig0(w24) + w23 in
  let w40: u32 = ssig1(w38) + w33 + ssig0(w25) + w24 in
  let w41: u32 = ssig1(w39) + w34 + ssig0(w26) + w25 in
  let w42: u32 = ssig1(w40) + w35 + ssig0(w27) + w26 in
  let w43: u32 = ssig1(w41) + w36 + ssig0(w28) + w27 in
  let w44: u32 = ssig1(w42) + w37 + ssig0(w29) + w28 in
  let w45: u32 = ssig1(w43) + w38 + ssig0(w30) + w29 in
  let w46: u32 = ssig1(w44) + w39 + ssig0(w31) + w30 in
  let w47: u32 = ssig1(w45) + w40 + ssig0(w32) + w31 in
  let w48: u32 = ssig1(w46) + w41 + ssig0(w33) + w32 in
  let w49: u32 = ssig1(w47) + w42 + ssig0(w34) + w33 in
  let w50: u32 = ssig1(w48) + w43 + ssig0(w35) + w34 in
  let w51: u32 = ssig1(w49) + w44 + ssig0(w36) + w35 in
  let w52: u32 = ssig1(w50) + w45 + ssig0(w37) + w36 in
  let w53: u32 = ssig1(w51) + w46 + ssig0(w38) + w37 in
  let w54: u32 = ssig1(w52) + w47 + ssig0(w39) + w38 in
  let w55: u32 = ssig1(w53) + w48 + ssig0(w40) + w39 in
  let w56: u32 = ssig1(w54) + w49 + ssig0(w41) + w40 in
  let w57: u32 = ssig1(w55) + w50 + ssig0(w42) + w41 in
  let w58: u32 = ssig1(w56) + w51 + ssig0(w43) + w42 in
  let w59: u32 = ssig1(w57) + w52 + ssig0(w44) + w43 in
  let w60: u32 = ssig1(w58) + w53 + ssig0(w45) + w44 in
  let w61: u32 = ssig1(w59) + w54 + ssig0(w46) + w45 in
  let w62: u32 = ssig1(w60) + w55 + ssig0(w47) + w46 in
  let w63: u32 = ssig1(w61) + w56 + ssig0(w48) + w47 in
  [w0, w1, w2, w3, w4, w5, w6, w7, w8, w9, w10, w11, w12, w13, w14, w15, w16, w17, w18, w19, w20, w21, w22, w23, w24, w25, w26, w27, w28, w29, w30, w31, w32, w33, w34, w35, w36, w37, w38, w39, w40, w41, w42, w43, w44, w45, w46, w47, w48, w49, w50, w51, w52, w53, w54, w55, w56, w57, w58, w59, w60, w61, w62, w63]

fn compress(w: array<u32, 64>) -> State =
  let s0: State = { a: 0x6a09e667, b: 0xbb67ae85, c: 0x3c6ef372, d: 0xa54ff53a, e: 0x510e527f, f: 0x9b05688c, g: 0x1f83d9ab, h: 0x5be0cd19 } in
  let s1: State = round(s0, 0x428a2f98, w[0]) in
  let s2: State = round(s1, 0x71374491, w[1]) in
  let s3: State = round(s2, 0xb5c0fbcf, w[2]) in
  let s4: State = round(s3, 0xe9b5dba5, w[3]) in

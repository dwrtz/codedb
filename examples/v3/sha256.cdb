fn digest_0() -> u32 = let s: State = compress(schedule()) in 0x6a09e667 + s.a
fn digest_1() -> u32 = let s: State = compress(schedule()) in 0xbb67ae85 + s.b
fn digest_2() -> u32 = let s: State = compress(schedule()) in 0x3c6ef372 + s.c
fn digest_3() -> u32 = let s: State = compress(schedule()) in 0xa54ff53a + s.d
fn digest_4() -> u32 = let s: State = compress(schedule()) in 0x510e527f + s.e
fn digest_5() -> u32 = let s: State = compress(schedule()) in 0x9b05688c + s.f
fn digest_6() -> u32 = let s: State = compress(schedule()) in 0x1f83d9ab + s.g
fn digest_7() -> u32 = let s: State = compress(schedule()) in 0x5be0cd19 + s.h
